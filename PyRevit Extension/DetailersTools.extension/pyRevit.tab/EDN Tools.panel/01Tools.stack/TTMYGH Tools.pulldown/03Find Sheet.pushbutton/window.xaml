<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Find Sheet"
        Width="520" Height="500"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">

    <Window.Resources>
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#005A9E"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#CCCCCC"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#0078D4"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#0078D4"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E8F4FC"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ModernComboBox" TargetType="ComboBox">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- Tooltip Icon Style -->
        <Style x:Key="TooltipIcon" TargetType="Border">
            <Setter Property="Width" Value="16"/>
            <Setter Property="Height" Value="16"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Background" Value="#6B7280"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style x:Key="TooltipText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Text" Value="?"/>
        </Style>

        <Style x:Key="ResultItem" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd" 
                                Background="White" 
                                CornerRadius="4" 
                                BorderBrush="#E0E0E0"
                                BorderThickness="1"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F0F7FF"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#0078D4"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E3F2FD"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#0078D4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,14">
            <TextBlock Text="Find Sheet" FontSize="18" FontWeight="Bold" Foreground="#333"/>
            <TextBlock Text="Search for a view by name, or pre-select views in Project Browser and click Check Selection" 
                       FontSize="12" Foreground="#666" Margin="0,4,0,0" TextWrapping="Wrap"/>
        </StackPanel>

        <!-- Search Dropdown -->
        <Border Grid.Row="1" Background="White" CornerRadius="6" Padding="14" Margin="0,0,0,10">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="Search Views" FontWeight="SemiBold" FontSize="12" Foreground="#666" Margin="0"/>
                    <Border Style="{StaticResource TooltipIcon}">
                        <Border.ToolTip>
                            <ToolTip>
                                <TextBlock MaxWidth="260" TextWrapping="Wrap">
                                    Type any part of a view name to filter the list.
                                    <LineBreak/><LineBreak/>
                                    Select a result from the dropdown to see which sheet(s)
                                    that view is placed on. If a view appears on multiple
                                    sheets, all matches are listed below.
                                    <LineBreak/><LineBreak/>
                                    Tip: search is case-insensitive and matches anywhere
                                    in the name (not just prefix).
                                </TextBlock>
                            </ToolTip>
                        </Border.ToolTip>
                        <TextBlock Style="{StaticResource TooltipText}"/>
                    </Border>
                </StackPanel>
                <ComboBox x:Name="cmbViewSearch"
                          Style="{StaticResource ModernComboBox}"
                          Height="38"
                          IsEditable="True"
                          IsTextSearchEnabled="False"
                          StaysOpenOnEdit="True"
                          SelectionChanged="OnViewSelected"
                          KeyUp="OnSearchKeyUp"
                          GotFocus="OnSearchFocus">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" Padding="2"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>
        </Border>

        <!-- Check Selection Button -->
        <Border Grid.Row="2" Background="White" CornerRadius="6" Padding="14" Margin="0,0,0,10">
            <Button x:Name="btnCheckSelection" 
                    Content="🔍 Check Browser Selection" 
                    Style="{StaticResource SecondaryButton}"
                    Height="38"
                    HorizontalAlignment="Stretch"
                    Click="OnCheckSelection"
                    ToolTip="Pre-select views in Project Browser, then click this"/>
        </Border>

        <!-- Results -->
        <Border Grid.Row="3" Background="White" CornerRadius="6" Padding="14">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock x:Name="txtResultsHeader"
                               Text="Results" 
                               FontWeight="SemiBold" 
                               FontSize="13"/>
                    <Border Style="{StaticResource TooltipIcon}">
                        <Border.ToolTip>
                            <ToolTip>
                                <TextBlock MaxWidth="260" TextWrapping="Wrap">
                                    Each result shows the view name and which sheet(s) it lives on.
                                    <LineBreak/><LineBreak/>
                                    <Bold>On Sheet</Bold> -- view is placed. Click the row and press
                                    "Go to Sheet" to navigate, or double-click to jump immediately.
                                    <LineBreak/>
                                    <Bold>Not Placed</Bold> -- view exists but is not on any sheet yet.
                                    <LineBreak/><LineBreak/>
                                    If a view is on multiple sheets, all matches are shown.
                                </TextBlock>
                            </ToolTip>
                        </Border.ToolTip>
                        <TextBlock Style="{StaticResource TooltipText}"/>
                    </Border>
                </StackPanel>
                
                <TextBlock x:Name="txtNoResults" 
                           Text="Type above to search, or select views in Project Browser first"
                           FontSize="12"
                           Foreground="#888"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"/>
                
                <ListBox x:Name="lstResults"
                         BorderThickness="0"
                         Background="Transparent"
                         ItemContainerStyle="{StaticResource ResultItem}"
                         Visibility="Collapsed"
                         SelectionChanged="OnResultSelected"
                         MouseDoubleClick="OnResultDoubleClick">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding ViewName}" 
                                               FontWeight="Medium" 
                                               FontSize="13"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding SheetInfo}" 
                                               FontSize="11" 
                                               Foreground="#666"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                                
                                <Border Grid.Column="1" 
                                        CornerRadius="4" 
                                        Padding="10,4"
                                        VerticalAlignment="Center"
                                        Background="{Binding StatusBg}">
                                    <TextBlock Text="{Binding StatusText}" 
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               Foreground="{Binding StatusFg}"/>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- Footer -->
        <Grid Grid.Row="4" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <Button x:Name="btnClose" 
                    Grid.Column="0"
                    Content="Close" 
                    Style="{StaticResource SecondaryButton}"
                    Height="36"
                    Width="80"
                    Click="OnClose"/>
            
            <TextBlock x:Name="txtStatus" 
                       Grid.Column="1"
                       Text="Ready" 
                       FontSize="11" 
                       Foreground="#888"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"/>
            
            <Button x:Name="btnGoToSheet" 
                    Grid.Column="2"
                    Content="Go to Sheet →" 
                    Style="{StaticResource ModernButton}"
                    Height="36"
                    IsEnabled="False"
                    Click="OnGoToSheet"/>
        </Grid>
    </Grid>
</Window>
