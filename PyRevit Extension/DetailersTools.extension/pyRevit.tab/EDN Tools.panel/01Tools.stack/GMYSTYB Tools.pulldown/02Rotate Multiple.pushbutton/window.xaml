<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Rotate Multiple"
    Width="780" Height="560"
    MinWidth="700" MinHeight="480"
    WindowStartupLocation="CenterScreen"
    Background="#F5F7FB"
    FontFamily="Segoe UI"
    FontSize="13"
    SnapsToDevicePixels="True"
    UseLayoutRounding="True"
    ResizeMode="CanResizeWithGrip">

    <!-- ========= THEME & STYLES ========= -->
    <Window.Resources>
        <Color x:Key="ColBg">#F5F7FB</Color>
        <Color x:Key="ColCard">#FFFFFFFF</Color>
        <Color x:Key="ColStroke">#E5E8F0</Color>
        <Color x:Key="ColText">#1F2937</Color>
        <Color x:Key="ColSubtle">#6B7280</Color>
        <Color x:Key="ColAccent">#2563EB</Color>
        <Color x:Key="ColSuccess">#10B981</Color>
        <Color x:Key="ColWarning">#F59E0B</Color>
        <Color x:Key="ColDanger">#EF4444</Color>
        <SolidColorBrush x:Key="BrushBg"      Color="{StaticResource ColBg}"/>
        <SolidColorBrush x:Key="BrushCard"    Color="{StaticResource ColCard}"/>
        <SolidColorBrush x:Key="BrushStroke"  Color="{StaticResource ColStroke}"/>
        <SolidColorBrush x:Key="BrushText"    Color="{StaticResource ColText}"/>
        <SolidColorBrush x:Key="BrushSubtle"  Color="{StaticResource ColSubtle}"/>
        <SolidColorBrush x:Key="BrushAccent"  Color="{StaticResource ColAccent}"/>
        <SolidColorBrush x:Key="BrushSuccess" Color="{StaticResource ColSuccess}"/>
        <SolidColorBrush x:Key="BrushWarning" Color="{StaticResource ColWarning}"/>
        <SolidColorBrush x:Key="BrushDanger"  Color="{StaticResource ColDanger}"/>

        <!-- Tooltip Icon -->
        <Style x:Key="TooltipIcon" TargetType="Border">
            <Setter Property="Width" Value="16"/>
            <Setter Property="Height" Value="16"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Background" Value="#A0AEC0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="4,0,0,0"/>
            <Setter Property="Cursor" Value="Help"/>
        </Style>
        <Style x:Key="TooltipText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Text" Value="?"/>
        </Style>

        <!-- Ghost Button -->
        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="Foreground"      Value="{StaticResource BrushText}"/>
            <Setter Property="Background"      Value="{StaticResource BrushCard}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BrushStroke}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="10,6"/>
            <Setter Property="Margin"          Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="#C9CFDA"/>
                                <Setter Property="Background"  Value="#FDFEFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#F0F3F9"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource GhostButton}">
            <Setter Property="Background"  Value="#EDF2FE"/>
            <Setter Property="BorderBrush" Value="#CBD7FB"/>
            <Setter Property="Foreground"  Value="{StaticResource BrushAccent}"/>
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource GhostButton}">
            <Setter Property="Background"  Value="{StaticResource BrushAccent}"/>
            <Setter Property="BorderBrush" Value="#1D4ED8"/>
            <Setter Property="Foreground"  Value="White"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="FontSize"    Value="14"/>
        </Style>
        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource GhostButton}">
            <Setter Property="Background"  Value="#FEF2F2"/>
            <Setter Property="BorderBrush" Value="#FECACA"/>
            <Setter Property="Foreground"  Value="{StaticResource BrushDanger}"/>
        </Style>

        <!-- Card -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background"      Value="{StaticResource BrushCard}"/>
            <Setter Property="CornerRadius"     Value="10"/>
            <Setter Property="BorderBrush"      Value="{StaticResource BrushStroke}"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="Padding"          Value="14,12"/>
            <Setter Property="Margin"           Value="0,0,0,8"/>
        </Style>
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="FontSize"    Value="12"/>
            <Setter Property="Foreground"  Value="{StaticResource BrushSubtle}"/>
            <Setter Property="Margin"      Value="0,0,0,6"/>
        </Style>
        <Style x:Key="CardRadio" TargetType="RadioButton">
            <Setter Property="Foreground"  Value="{StaticResource BrushText}"/>
            <Setter Property="FontSize"    Value="13"/>
            <Setter Property="Margin"      Value="0,2"/>
            <Setter Property="Cursor"      Value="Hand"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Height"          Value="30"/>
            <Setter Property="Padding"         Value="6,4"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BrushStroke}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background"      Value="White"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground"  Value="{StaticResource BrushText}"/>
            <Setter Property="FontSize"    Value="13"/>
            <Setter Property="Margin"      Value="0,2"/>
            <Setter Property="Cursor"      Value="Hand"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <!-- ========= MAIN GRID ========= -->
    <Grid Background="{StaticResource BrushBg}" Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ===== HEADER ===== -->
        <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,0,0,4">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="Rotate Multiple"
                           FontSize="17" FontWeight="Bold"
                           Foreground="{StaticResource BrushText}"
                           VerticalAlignment="Center"/>
                <TextBlock Text="  v0.2"
                           FontSize="11"
                           Foreground="{StaticResource BrushSubtle}"
                           VerticalAlignment="Center"
                           Margin="4,2,0,0"/>
            </StackPanel>
        </Border>

        <!-- ===== TWO-COLUMN BODY ===== -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="280"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*" MinWidth="320"/>
            </Grid.ColumnDefinitions>

            <!-- ============ LEFT COLUMN: Elements + Deselect ============ -->
            <ScrollViewer Grid.Column="0"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel>

                    <!-- ELEMENTS -->
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <TextBlock Style="{StaticResource SectionLabel}"
                                           Text="ELEMENTS" Margin="0"/>
                                <Border Style="{StaticResource TooltipIcon}" Margin="6,0,0,0">
                                    <Border.ToolTip>
                                        <TextBlock MaxWidth="280" TextWrapping="Wrap">
                                            <Bold>Element Selection</Bold>
                                            <LineBreak/><LineBreak/>
                                            Pre-selects whatever is currently selected in Revit.
                                            Use "Pick Elements" to go pick more.
                                            Use the Deselect panel below to refine.
                                        </TextBlock>
                                    </Border.ToolTip>
                                    <TextBlock Style="{StaticResource TooltipText}"/>
                                </Border>
                            </StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="TxtElementCount"
                                           Grid.Column="0" Text="(none)"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource BrushText}"
                                           Margin="0,0,10,0"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <Button x:Name="BtnPickElements"
                                            Style="{StaticResource AccentButton}"
                                            Content="Pick Elements"
                                            Padding="8,5" Margin="0,0,4,0"/>
                                    <Border Style="{StaticResource TooltipIcon}">
                                        <Border.ToolTip>
                                            <TextBlock MaxWidth="260" TextWrapping="Wrap">
                                                <Bold>Pick Elements</Bold>
                                                <LineBreak/><LineBreak/>
                                                Select elements in the model to rotate.
                                                Replaces the current selection.
                                            </TextBlock>
                                        </Border.ToolTip>
                                        <TextBlock Style="{StaticResource TooltipText}"/>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- DESELECT -->
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <TextBlock Style="{StaticResource SectionLabel}"
                                           Text="DESELECT" Margin="0"/>
                                <Border Style="{StaticResource TooltipIcon}" Margin="6,0,0,0">
                                    <Border.ToolTip>
                                        <TextBlock MaxWidth="300" TextWrapping="Wrap">
                                            <Bold>Deselect Elements</Bold>
                                            <LineBreak/><LineBreak/>
                                            Remove elements from the selection.
                                            <LineBreak/>
                                            Choose a mode, select items from the list
                                            (Ctrl+Click for multiple), then click Deselect.
                                        </TextBlock>
                                    </Border.ToolTip>
                                    <TextBlock Style="{StaticResource TooltipText}"/>
                                </Border>
                            </StackPanel>

                            <!-- Mode radios (2x2) -->
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <RadioButton x:Name="RbDeselectIndividual"
                                             Style="{StaticResource CardRadio}"
                                             Content="Individual" GroupName="DeselectMode"
                                             IsChecked="True"
                                             Grid.Row="0" Grid.Column="0"/>
                                <RadioButton x:Name="RbDeselectCategory"
                                             Style="{StaticResource CardRadio}"
                                             Content="Category" GroupName="DeselectMode"
                                             Grid.Row="0" Grid.Column="1"/>
                                <RadioButton x:Name="RbDeselectFamily"
                                             Style="{StaticResource CardRadio}"
                                             Content="Family" GroupName="DeselectMode"
                                             Grid.Row="1" Grid.Column="0"/>
                                <RadioButton x:Name="RbDeselectType"
                                             Style="{StaticResource CardRadio}"
                                             Content="Type" GroupName="DeselectMode"
                                             Grid.Row="1" Grid.Column="1"/>
                            </Grid>

                            <!-- List -->
                            <Border BorderBrush="{StaticResource BrushStroke}"
                                    BorderThickness="1" CornerRadius="6"
                                    Margin="0,0,0,6">
                                <ListBox x:Name="LstDeselect"
                                         SelectionMode="Extended"
                                         MinHeight="60" MaxHeight="180"
                                         BorderThickness="0"
                                         Background="White">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Name}"
                                                           Width="200"
                                                           Margin="0,0,6,0"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding Count}"
                                                           Foreground="{StaticResource BrushSubtle}"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Border>

                            <!-- Buttons -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button x:Name="BtnDeselect"
                                        Style="{StaticResource GhostButton}"
                                        Content="Deselect"
                                        Padding="8,5" Margin="0,0,6,0"/>
                                <Button x:Name="BtnDeselectAll"
                                        Style="{StaticResource DangerButton}"
                                        Content="Deselect All"
                                        Padding="8,5"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- ============ RIGHT COLUMN: Settings ============ -->
            <ScrollViewer Grid.Column="2"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel>

                    <!-- ANGLE MODE -->
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionLabel}" Text="ANGLE MODE"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <RadioButton x:Name="RbManual"
                                             Style="{StaticResource CardRadio}"
                                             Content="Manual" GroupName="AngleMode"
                                             IsChecked="True" Margin="0,0,4,0"/>
                                <Border Style="{StaticResource TooltipIcon}" Margin="0,0,12,0">
                                    <Border.ToolTip>
                                        <TextBlock MaxWidth="240" TextWrapping="Wrap">
                                            <Bold>Manual Angle</Bold>
                                            <LineBreak/><LineBreak/>
                                            Type a rotation angle in degrees.
                                            <LineBreak/>Positive = CCW, Negative = CW.
                                        </TextBlock>
                                    </Border.ToolTip>
                                    <TextBlock Style="{StaticResource TooltipText}"/>
                                </Border>
                                <RadioButton x:Name="RbAlign"
                                             Style="{StaticResource CardRadio}"
                                             Content="Align to Reference"
                                             GroupName="AngleMode" Margin="0,0,4,0"/>
                                <Border Style="{StaticResource TooltipIcon}">
                                    <Border.ToolTip>
                                        <TextBlock MaxWidth="280" TextWrapping="Wrap">
                                            <Bold>Align to Reference</Bold>
                                            <LineBreak/><LineBreak/>
                                            Pick a duct, pipe, line, grid, scope box,
                                            family, or two points. Each element rotates
                                            to match that direction.
                                        </TextBlock>
                                    </Border.ToolTip>
                                    <TextBlock Style="{StaticResource TooltipText}"/>
                                </Border>
                            </StackPanel>

                            <!-- Manual input -->
                            <StackPanel x:Name="PnlManual" Margin="0,2,0,0">
                                <TextBox x:Name="TxtAngle" Text="90" Width="100"
                                         HorizontalAlignment="Left"/>
                            </StackPanel>

                            <!-- Align panel -->
                            <StackPanel x:Name="PnlAlign" Visibility="Collapsed"
                                        Margin="0,2,0,0">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <Button x:Name="BtnPickRef"
                                            Style="{StaticResource AccentButton}"
                                            Content="Pick Reference"
                                            Padding="8,5" Margin="0,0,4,0"/>
                                    <Border Style="{StaticResource TooltipIcon}" Margin="0,0,6,0">
                                        <Border.ToolTip>
                                            <TextBlock MaxWidth="260" TextWrapping="Wrap">
                                                <Bold>Pick Reference Element</Bold>
                                                <LineBreak/><LineBreak/>
                                                Duct, Pipe, Conduit, Cable Tray,
                                                Lines, Grids, Scope Boxes, Families.
                                            </TextBlock>
                                        </Border.ToolTip>
                                        <TextBlock Style="{StaticResource TooltipText}"/>
                                    </Border>
                                    <Button x:Name="BtnPickPts"
                                            Style="{StaticResource GhostButton}"
                                            Content="Two Points"
                                            Padding="8,5" Margin="0,0,4,0"/>
                                    <Border Style="{StaticResource TooltipIcon}">
                                        <Border.ToolTip>
                                            <TextBlock MaxWidth="240" TextWrapping="Wrap">
                                                <Bold>Pick Two Points</Bold>
                                                <LineBreak/><LineBreak/>
                                                Click two points to define a direction.
                                            </TextBlock>
                                        </Border.ToolTip>
                                        <TextBlock Style="{StaticResource TooltipText}"/>
                                    </Border>
                                </StackPanel>

                                <!-- Ref status -->
                                <Border Background="#F8FAFC" CornerRadius="6"
                                        BorderBrush="{StaticResource BrushStroke}"
                                        BorderThickness="1"
                                        Padding="8,6" Margin="0,0,0,6">
                                    <TextBlock x:Name="TxtRefStatus"
                                               Text="(none selected)"
                                               FontSize="11.5"
                                               Foreground="{StaticResource BrushText}"
                                               TextWrapping="Wrap"/>
                                </Border>

                                <!-- Parallel / Perpendicular -->
                                <StackPanel Orientation="Horizontal">
                                    <RadioButton x:Name="RbParallel"
                                                 Style="{StaticResource CardRadio}"
                                                 Content="Parallel" GroupName="Alignment"
                                                 IsChecked="True" Margin="0,0,4,0"/>
                                    <Border Style="{StaticResource TooltipIcon}" Margin="0,0,12,0">
                                        <Border.ToolTip>
                                            <TextBlock MaxWidth="220" TextWrapping="Wrap">
                                                Match the reference direction.
                                            </TextBlock>
                                        </Border.ToolTip>
                                        <TextBlock Style="{StaticResource TooltipText}"/>
                                    </Border>
                                    <RadioButton x:Name="RbPerpendicular"
                                                 Style="{StaticResource CardRadio}"
                                                 Content="Perpendicular" GroupName="Alignment"
                                                 Margin="0,0,4,0"/>
                                    <Border Style="{StaticResource TooltipIcon}">
                                        <Border.ToolTip>
                                            <TextBlock MaxWidth="220" TextWrapping="Wrap">
                                                90 degrees to the reference direction.
                                            </TextBlock>
                                        </Border.ToolTip>
                                        <TextBlock Style="{StaticResource TooltipText}"/>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- AXIS + CENTER (side by side) -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Axis -->
                        <Border Grid.Column="0" Style="{StaticResource Card}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <TextBlock Style="{StaticResource SectionLabel}"
                                               Text="AXIS" Margin="0"/>
                                    <Border Style="{StaticResource TooltipIcon}" Margin="6,0,0,0">
                                        <Border.ToolTip>
                                            <TextBlock MaxWidth="240" TextWrapping="Wrap">
                                                <Bold>World Z:</Bold> Plan-view rotation.
                                                <LineBreak/>
                                                <Bold>View Normal:</Bold> Sections/elevations.
                                            </TextBlock>
                                        </Border.ToolTip>
                                        <TextBlock Style="{StaticResource TooltipText}"/>
                                    </Border>
                                </StackPanel>
                                <RadioButton x:Name="RbWorldZ"
                                             Style="{StaticResource CardRadio}"
                                             Content="World Z (Up)"
                                             GroupName="Axis" IsChecked="True"/>
                                <RadioButton x:Name="RbViewNormal"
                                             Style="{StaticResource CardRadio}"
                                             Content="View Normal"
                                             GroupName="Axis"/>
                            </StackPanel>
                        </Border>

                        <!-- Center -->
                        <Border Grid.Column="2" Style="{StaticResource Card}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <TextBlock Style="{StaticResource SectionLabel}"
                                               Text="CENTER" Margin="0"/>
                                    <Border Style="{StaticResource TooltipIcon}" Margin="6,0,0,0">
                                        <Border.ToolTip>
                                            <TextBlock MaxWidth="260" TextWrapping="Wrap">
                                                <Bold>Auto:</Bold> Insertion point, then BBox.
                                                <LineBreak/>
                                                <Bold>Force BBox:</Bold> Always bounding box center.
                                            </TextBlock>
                                        </Border.ToolTip>
                                        <TextBlock Style="{StaticResource TooltipText}"/>
                                    </Border>
                                </StackPanel>
                                <RadioButton x:Name="RbCenterAuto"
                                             Style="{StaticResource CardRadio}"
                                             Content="Auto"
                                             GroupName="Center" IsChecked="True"/>
                                <RadioButton x:Name="RbCenterBBox"
                                             Style="{StaticResource CardRadio}"
                                             Content="Force BBox"
                                             GroupName="Center"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- OPTIONS -->
                    <Border Style="{StaticResource Card}">
                        <StackPanel Orientation="Horizontal">
                            <CheckBox x:Name="ChkUnpin"
                                      Content="Auto-unpin/re-pin pinned elements"
                                      IsChecked="True" Margin="0,0,4,0"/>
                            <Border Style="{StaticResource TooltipIcon}">
                                <Border.ToolTip>
                                    <TextBlock MaxWidth="260" TextWrapping="Wrap">
                                        <Bold>Checked:</Bold> Temporarily unpins, rotates, re-pins.
                                        <LineBreak/>
                                        <Bold>Unchecked:</Bold> Pinned elements are skipped.
                                    </TextBlock>
                                </Border.ToolTip>
                                <TextBlock Style="{StaticResource TooltipText}"/>
                            </Border>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- ===== FOOTER ===== -->
        <Border Grid.Row="2" Style="{StaticResource Card}" Margin="0,4,0,0"
                Padding="12,10">
            <DockPanel LastChildFill="True">
                <Button x:Name="BtnCancel"
                        Style="{StaticResource GhostButton}"
                        Content="Cancel"
                        DockPanel.Dock="Right"
                        Width="90" Margin="8,0,0,0"/>
                <Button x:Name="BtnGo"
                        Style="{StaticResource PrimaryButton}"
                        Content="Rotate"
                        DockPanel.Dock="Right"
                        Width="120"/>
                <TextBlock x:Name="TxtStatus"
                           Foreground="{StaticResource BrushSubtle}"
                           VerticalAlignment="Center"
                           Text="Configure options, then click Rotate"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
