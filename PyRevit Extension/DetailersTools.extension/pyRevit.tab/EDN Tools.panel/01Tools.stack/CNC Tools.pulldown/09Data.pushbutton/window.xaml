<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Data"
    Width="620" Height="480"
    MinWidth="500" MinHeight="400"
    WindowStartupLocation="CenterScreen"
    Background="#F5F7FB"
    FontFamily="Segoe UI"
    FontSize="12"
    SnapsToDevicePixels="True"
    UseLayoutRounding="True"
    ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <!-- Surface -->
        <SolidColorBrush x:Key="PageBg"       Color="#F5F7FB"/>
        <SolidColorBrush x:Key="CardBg"       Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="CardBgAlt"    Color="#FAFAFC"/>
        <SolidColorBrush x:Key="StrokePrimary"   Color="#E5E8F0"/>

        <!-- Text -->
        <SolidColorBrush x:Key="TextPrimary"   Color="#1F2937"/>
        <SolidColorBrush x:Key="TextMuted"     Color="#6B7280"/>

        <!-- Accent -->
        <SolidColorBrush x:Key="AccentPrimary" Color="#2563EB"/>

        <!-- Typography -->
        <Style x:Key="WindowTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        </Style>
        <Style x:Key="WindowSubtitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
            <Setter Property="Margin" Value="0,2,0,0"/>
        </Style>
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
        <Style x:Key="Caption" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
        </Style>

        <!-- Tooltip Icon -->
        <Style x:Key="TooltipIcon" TargetType="Border">
            <Setter Property="Width" Value="16"/>
            <Setter Property="Height" Value="16"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Background" Value="#A0AEC0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style x:Key="TooltipText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Text" Value="?"/>
        </Style>

        <!-- Containers -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBg}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="BorderBrush" Value="{StaticResource StrokePrimary}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <!-- Button System -->
        <Style x:Key="Btn_Base" TargetType="Button">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="Btn_Primary" TargetType="Button" BasedOn="{StaticResource Btn_Base}">
            <Setter Property="Background" Value="{StaticResource AccentPrimary}"/>
            <Setter Property="BorderBrush" Value="#1D4ED8"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <Style x:Key="Btn_Ghost" TargetType="Button" BasedOn="{StaticResource Btn_Base}">
            <Setter Property="Background" Value="{StaticResource CardBg}"/>
            <Setter Property="BorderBrush" Value="{StaticResource StrokePrimary}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        </Style>

        <!-- Radio -->
        <Style x:Key="CardRadio" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,3"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <StackPanel Grid.Row="0" Margin="0,0,0,14">
            <TextBlock Text="Data"
                       Style="{StaticResource WindowTitle}"/>
            <TextBlock Text="Import and export native duct geometry and family data"
                       Style="{StaticResource WindowSubtitle}"/>
        </StackPanel>

        <!-- CONTENT -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT SIDEBAR -->
            <StackPanel Grid.Column="0" Margin="0,0,12,0">

                <!-- DATA TYPE -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Style="{StaticResource SectionLabel}"
                                       Text="DATA TYPE" Margin="0"/>
                            <Border Style="{StaticResource TooltipIcon}">
                                <Border.ToolTip>
                                    <TextBlock MaxWidth="260" TextWrapping="Wrap">
                                        Native Duct: ducts and duct fittings
                                        (straights, elbows, transitions, taps).
                                        Family: loadable Revit families with
                                        parameters, geometry, and connectors.
                                    </TextBlock>
                                </Border.ToolTip>
                                <TextBlock Style="{StaticResource TooltipText}"/>
                            </Border>
                        </StackPanel>
                        <RadioButton x:Name="RbNativeDuct"
                                     Style="{StaticResource CardRadio}"
                                     Content="Native Duct"
                                     GroupName="DataType" IsChecked="True"/>
                        <RadioButton x:Name="RbFamily"
                                     Style="{StaticResource CardRadio}"
                                     Content="Family"
                                     GroupName="DataType"/>
                    </StackPanel>
                </Border>

                <!-- OPERATION -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Style="{StaticResource SectionLabel}"
                                       Text="OPERATION" Margin="0"/>
                            <Border Style="{StaticResource TooltipIcon}">
                                <Border.ToolTip>
                                    <TextBlock MaxWidth="260" TextWrapping="Wrap">
                                        Export: write element data to JSONL + CSV files.
                                        Import: read data files and create elements in Revit.
                                    </TextBlock>
                                </Border.ToolTip>
                                <TextBlock Style="{StaticResource TooltipText}"/>
                            </Border>
                        </StackPanel>
                        <RadioButton x:Name="RbExport"
                                     Style="{StaticResource CardRadio}"
                                     Content="Export"
                                     GroupName="Operation" IsChecked="True"/>
                        <RadioButton x:Name="RbImport"
                                     Style="{StaticResource CardRadio}"
                                     Content="Import"
                                     GroupName="Operation"/>
                    </StackPanel>
                </Border>

                <!-- RUN -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <Button x:Name="BtnRun"
                                Style="{StaticResource Btn_Primary}"
                                Content="Export Native Duct Data"
                                Height="40"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- RIGHT PANEL: DESCRIPTION -->
            <Border Grid.Column="1" Style="{StaticResource Card}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="TxtDescription"
                               TextWrapping="Wrap"
                               Foreground="{StaticResource TextPrimary}"
                               FontSize="13"
                               LineHeight="20"
                               Text=""/>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- FOOTER -->
        <DockPanel Grid.Row="2" Margin="0,2,0,0">
            <TextBlock x:Name="TxtStatus"
                       Style="{StaticResource Caption}"
                       DockPanel.Dock="Left"
                       Text="Choose a data type and operation, then click Run"
                       VerticalAlignment="Center"/>
            <StackPanel Orientation="Horizontal"
                        DockPanel.Dock="Right">
                <Button x:Name="BtnClose"
                        Style="{StaticResource Btn_Ghost}"
                        Content="Close"
                        Width="90"
                        IsCancel="True"/>
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
