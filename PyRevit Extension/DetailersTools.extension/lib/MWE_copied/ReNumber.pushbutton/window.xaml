<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Renumber" Height="1000" Width="1000"
        WindowStartupLocation="CenterScreen" 
        FontSize="12"
        ShowInTaskbar="False"
        ResizeMode="CanResize">
    
    <Window.Resources>
        <!-- Tooltip Icon Style -->
        <Style x:Key="TooltipIcon" TargetType="Border">
            <Setter Property="Width" Value="16"/>
            <Setter Property="Height" Value="16"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Background" Value="#A0AEC0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="4,0,0,0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        
        <Style x:Key="TooltipText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Text" Value="?"/>
        </Style>
    </Window.Resources>
    
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="440"/>
            <ColumnDefinition Width="10"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ===== LEFT PANEL: SET OPTIONS ===== -->
        <GroupBox Grid.Column="0" Grid.Row="0" Padding="10">
            <GroupBox.Header>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Set Options" FontWeight="SemiBold"/>
                    <Border Style="{StaticResource TooltipIcon}">
                        <Border.ToolTip>
                            <ToolTip>
                                <TextBlock MaxWidth="280" TextWrapping="Wrap">
                                    Configure renumbering settings, including target parameters, numbering options, and ordering modes.
                                    <LineBreak/><LineBreak/>
                                    Supports multiple workflows: manual picking, automatic ordering, and grouping by category/family/type.
                                </TextBlock>
                            </ToolTip>
                        </Border.ToolTip>
                        <TextBlock Style="{StaticResource TooltipText}"/>
                    </Border>
                </StackPanel>
            </GroupBox.Header>
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <!-- Pick Elements and Profile Buttons -->
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="65"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="115"/>
                            <ColumnDefinition Width="115"/>
                        </Grid.ColumnDefinitions>

                        <Label Name="PickedCountLbl" 
                               Grid.Column="0"
                               Content="(none)" 
                               VerticalAlignment="Center"
                               HorizontalAlignment="Left"
                               Padding="0"/>

                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Name="PickElemsBtn" 
                                    Content="Pick Elements"
                                    Padding="8,5"
                                    Click="OnPickElements"/>
                            <Border Style="{StaticResource TooltipIcon}" Margin="3,0,0,0">
                                <Border.ToolTip>
                                    <ToolTip>
                                        <TextBlock MaxWidth="280" TextWrapping="Wrap">
                                            Click to select elements in the model that you want to renumber.
                                            <LineBreak/><LineBreak/>
                                            <Bold>Usage:</Bold> Select multiple elements using standard Revit selection methods (click, window, filter).
                                            <LineBreak/><LineBreak/>
                                            Works with Fabrication Parts, standard Revit elements, and all element types.
                                        </TextBlock>
                                    </ToolTip>
                                </Border.ToolTip>
                                <TextBlock Style="{StaticResource TooltipText}"/>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Name="SaveProfileBtn" 
                                    Content="Save Profile"
                                    Padding="5,5"
                                    Width="92"
                                    Click="OnSaveProfile"/>
                            <Border Style="{StaticResource TooltipIcon}" Margin="3,0,0,0">
                                <Border.ToolTip>
                                    <ToolTip>
                                        <TextBlock MaxWidth="280" TextWrapping="Wrap">
                                            Save the current configuration as a reusable profile.
                                            <LineBreak/><LineBreak/>
                                            <Bold>Saves:</Bold> All numbering options, target parameters, compare fields, and grouping settings.
                                            <LineBreak/><LineBreak/>
                                            Profiles are saved as XML files and can be loaded later for quick reuse.
                                        </TextBlock>
                                    </ToolTip>
                                </Border.ToolTip>
                                <TextBlock Style="{StaticResource TooltipText}"/>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Column="3" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Name="LoadProfileBtn" 
                                    Content="Load Profile"
                                    Padding="5,5"
                                    Width="92"
                                    Click="OnLoadProfile"/>
                            <Border Style="{StaticResource TooltipIcon}" Margin="3,0,0,0">
                                <Border.ToolTip>
                                    <ToolTip>
                                        <TextBlock MaxWidth="280" TextWrapping="Wrap">
                                            Load a previously saved configuration profile.
                                            <LineBreak/><LineBreak/>
                                            <Bold>Action:</Bold> Opens a file browser to select an XML profile file.
                                            <LineBreak/><LineBreak/>
                                            All settings from the profile will be restored, including targets, compare options, and numbering preferences.
                                        </TextBlock>
                                    </ToolTip>
                                </Border.ToolTip>
                                <TextBlock Style="{StaticResource TooltipText}"/>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <!-- NEW: Filter Selection Box -->
                    <GroupBox Name="FilterBox" 
                              Margin="0,0,0,10" 
                              Padding="10"
                              Visibility="Collapsed">
                        <GroupBox.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Filter Selection" FontWeight="SemiBold"/>
                                <Border Style="{StaticResource TooltipIcon}">
                                    <Border.ToolTip>
                                        <ToolTip>
                                            <TextBlock MaxWidth="280" TextWrapping="Wrap">
                                                Filter picked elements by a specific parameter value.
                                                <LineBreak/><LineBreak/>
                                                <Bold>Use Case:</Bold> Narrow down your selection after picking elements.
                                                <LineBreak/><LineBreak/>
                                                Example: Filter to only "6 inch" pipe sizes, or only "Domestic Cold Water" services.
                                            </TextBlock>
                                        </ToolTip>
                                    </Border.ToolTip>
                                    <TextBlock Style="{StaticResource TooltipText}"/>
                                </Border>
                            </StackPanel>
                        </GroupBox.Header>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="110"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <TextBlock Grid.Row="0" Grid.Column="0" 
                                     Text="Parameter:" 
                                     VerticalAlignment="Center" 
                                     Margin="0,0,10,5"/>
                            <ComboBox Name="FilterParamBox" 
                                    Grid.Row="0" Grid.Column="1"
                                    IsEditable="True"
                                    Margin="0,0,5,5"/>
                            
                            <StackPanel Grid.Row="0" Grid.Column="2" Grid.RowSpan="2" 
                                       Orientation="Vertical" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Name="FilterApplyBtn" 
                                            Content="Apply Filter"
                                            Width="90"
                                            Padding="5"
                                            Click="OnFilterApply"/>
                                    <Border Style="{StaticResource TooltipIcon}" Margin="3,0,0,0">
                                        <Border.ToolTip>
                                            <ToolTip>
                                                <TextBlock MaxWidth="280" TextWrapping="Wrap">
                                                    Apply the filter to reduce the element list.
                                                    <LineBreak/><LineBreak/>
                                                    Only elements matching the parameter value will remain selected.
                                                    <LineBreak/><LineBreak/>
                                                    Click again to clear the filter and restore all picked elements.
                                                </TextBlock>
                                            </ToolTip>
                                        </Border.ToolTip>
                                        <TextBlock Style="{StaticResource TooltipText}"/>
                                    </Border>
                                </StackPanel>
                                <TextBlock Name="FilterStatusLbl" 
                                         Text="(clear filter)" 
                                         HorizontalAlignment="Center"
                                         FontSize="10"
                                         Foreground="Gray"
                                         Margin="0,3,0,0"/>
                            </StackPanel>

                            <TextBlock Grid.Row="1" Grid.Column="0" 
                                     Text="Value:" 
                                     VerticalAlignment="Center" 
                                     Margin="0,0,10,5"/>
                            <TextBox Name="FilterValueBox" 
                                   Grid.Row="1" Grid.Column="1"
                                   Margin="0,0,5,5"/>
                        </Grid>
                    </GroupBox>

                    <!-- Target Parameters -->
                    <GroupBox Margin="0,0,0,10" 
                              Padding="10">
                        <GroupBox.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Target Parameters (write number to up to 3)" FontWeight="SemiBold"/>
                                <Border Style="{StaticResource TooltipIcon}">
                                    <Border.ToolTip>
                                        <ToolTip>
                                            <TextBlock MaxWidth="280" TextWrapping="Wrap">
                                                Specify up to 3 parameters where the renumbered value will be written.
                                                <LineBreak/><LineBreak/>
                                                <Bold>Common Targets:</Bold> Item Number, Mark, Assembly Mark, Number, Tag, or any custom parameter.
                                                <LineBreak/><LineBreak/>
                                                All three targets will receive the same generated number (prefix + number + suffix).
                                            </TextBlock>
                                        </ToolTip>
                                    </Border.ToolTip>
                                    <TextBlock Style="{StaticResource TooltipText}"/>
                                </Border>
                            </StackPanel>
                        </GroupBox.Header>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" 
                                     Text="Target A:" 
                                     VerticalAlignment="Center" 
                                     Margin="0,0,10,5"/>
                            <ComboBox Name="TargetParamBoxA" 
                                    Grid.Row="0" Grid.Column="1"
                                    IsEditable="True"
                                    Margin="0,0,0,5"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" 
                                     Text="Target B:" 
                                     VerticalAlignment="Center" 
                                     Margin="0,0,10,5"/>
                            <ComboBox Name="TargetParamBoxB" 
                                    Grid.Row="1" Grid.Column="1"
                                    IsEditable="True"
                                    Margin="0,0,0,5"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" 
                                     Text="Target C:" 
                                     VerticalAlignment="Center" 
                                     Margin="0,0,10,5"/>
                            <ComboBox Name="TargetParamBoxC" 
                                    Grid.Row="2" Grid.Column="1"
                                    IsEditable="True"
                                    Margin="0,0,0,5"/>
                        </Grid>
                    </GroupBox>

                    <!-- Numbering Options -->
                    <GroupBox Margin="0,0,0,10" 
                              Padding="10">
                        <GroupBox.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Numbering Options" FontWeight="SemiBold"/>
                                <Border Style="{StaticResource TooltipIcon}">
                                    <Border.ToolTip>
                                        <ToolTip>
                                            <TextBlock MaxWidth="280" TextWrapping="Wrap">
                                                Configure prefix, suffix, and starting number for the renumbering sequence.
                                                <LineBreak/><LineBreak/>
                                                These settings determine the format of each generated number.
                                            </TextBlock>
                                        </ToolTip>
                                    </Border.ToolTip>
                                    <TextBlock Style="{StaticResource TooltipText}"/>
                                </Border>
                            </StackPanel>
                        </GroupBox.Header>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Prefix -->
                            <TextBlock Grid.Row="0" Grid.Column="0" 
                                     Text="Prefix:" 
                                     VerticalAlignment="Center" 
                                     Margin="0,0,10,5"/>
                            <TextBox Name="PrefixBox" 
                                   Grid.Row="0" Grid.Column="1"
                                   Margin="0,0,0,5"/>

                            <!-- Suffix -->
                            <TextBlock Grid.Row="1" Grid.Column="0" 
                                     Text="Suffix:" 
                                     VerticalAlignment="Center" 
                                     Margin="0,0,10,5"/>
                            <TextBox Name="SuffixBox" 
                                   Grid.Row="1" Grid.Column="1"
                                   Margin="0,0,0,5"/>

                            <!-- Start Number -->
                            <TextBlock Grid.Row="2" Grid.Column="0" 
                                     Text="Start Number:" 
                                     VerticalAlignment="Center" 
                                     Margin="0,0,10,5"/>
                            <TextBox Name="StartNumberBox" 
                                   Grid.Row="2" Grid.Column="1"
                                   Text="1"
                                   Margin="0,0,0,5"/>
                        </Grid>
                    </GroupBox>

                    <!-- Ordering Options -->
                    <GroupBox Margin="0,0,0,10" 
                              Padding="10">
                        <GroupBox.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Ordering Options" FontWeight="SemiBold"/>
                                <Border Style="{StaticResource TooltipIcon}">
                                    <Border.ToolTip>
                                        <ToolTip>
                                            <TextBlock MaxWidth="280" TextWrapping="Wrap">
                                                Configure how elements are grouped and ordered for numbering.
                                                <LineBreak/><LineBreak/>
                                                Includes grouping mode, group order, and element ordering method.
                                            </TextBlock>
                                        </ToolTip>
                                    </Border.ToolTip>
                                    <TextBlock Style="{StaticResource TooltipText}"/>
                                </Border>
                            </StackPanel>
                        </GroupBox.Header>
                        <StackPanel>
                            <!-- Numbering Group -->
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="115"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" 
                                         Text="Numbering Group:" 
                                         VerticalAlignment="Center"/>
                                <ComboBox Name="GroupingModeBox" 
                                        Grid.Column="1"/>
                            </Grid>

                            <!-- Group Order ListBox -->
                            <GroupBox Name="GroupOrderBox" 
                                      Margin="0,0,0,10" 
                                      Padding="10"
                                      Visibility="Collapsed">
                                <GroupBox.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Group Order" FontWeight="SemiBold"/>
                                        <Border Style="{StaticResource TooltipIcon}">
                                            <Border.ToolTip>
                                                <ToolTip>
                                                    <TextBlock MaxWidth="280" TextWrapping="Wrap">
                                                        Define the order in which groups are numbered.
                                                        <LineBreak/><LineBreak/>
                                                        <Bold>Available when:</Bold> Numbering Group is "By Category", "By Family", "By Type", or "Order by Parameter"
                                                        <LineBreak/><LineBreak/>
                                                        Use Move Up/Down buttons to reorder. Numbers increment across groups in this order.
                                                        <LineBreak/><LineBreak/>
                                                        For "Order by Parameter" mode, this shows the distinct parameter values found in your selection.
                                                    </TextBlock>
                                                </ToolTip>
                                            </Border.ToolTip>
                                            <TextBlock Style="{StaticResource TooltipText}"/>
                                        </Border>
                                    </StackPanel>
                                </GroupBox.Header>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <ListBox Name="GroupOrderList" 
                                             Grid.Column="0" 
                                             Height="150"
                                             DisplayMemberPath="Name"/>
                                    
                                    <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                                        <Button Name="MoveUpBtn" 
                                                Content="Move Up" 
                                                Width="80" 
                                                Padding="5" 
                                                Margin="0,0,0,5"
                                                Click="OnMoveUp"/>
                                        <Button Name="MoveDownBtn" 
                                                Content="Move Down" 
                                                Width="80" 
                                                Padding="5"
                                                Click="OnMoveDown"/>
                                    </StackPanel>
                                </Grid>
                            </GroupBox>
                            
                            <!-- Order Mode Dropdown -->
                            <Grid Margin="0,0,0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="115"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" 
                                         Text="Order Mode:" 
                                         VerticalAlignment="Center"/>
                                <ComboBox Name="OrderModeBox" 
                                        Grid.Column="1"/>
                            </Grid>

                            <!-- Pick Curve Button -->
                            <Grid Margin="0,5,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="120"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Name="CurvePickedLabel" 
                                         Grid.Column="0"
                                         Text="(none)" 
                                         VerticalAlignment="Center"
                                         FontSize="10"
                                         Foreground="Gray"/>

                                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Name="PickCurveBtn" 
                                          Content="Pick Curve"
                                          Padding="8,5"
                                          Width="95"
                                          IsEnabled="False"
                                          Click="OnPickCurve"/>
                                    <Border Style="{StaticResource TooltipIcon}" Margin="3,0,0,0">
                                        <Border.ToolTip>
                                            <ToolTip>
                                                <TextBlock MaxWidth="280" TextWrapping="Wrap">
                                                    Pick a spline or curve to follow when ordering elements.
                                                    <LineBreak/><LineBreak/>
                                                    <Bold>Enabled when:</Bold> Order Mode is set to "Follow spline"
                                                    <LineBreak/><LineBreak/>
                                                    Elements will be numbered based on their distance along the selected curve.
                                                </TextBlock>
                                            </ToolTip>
                                        </Border.ToolTip>
                                        <TextBlock Style="{StaticResource TooltipText}"/>
                                    </Border>
                                </StackPanel>
                            </Grid>
                            
                            <!-- Order by Parameter Controls -->
                            <GroupBox Name="OrderByParameterBox" 
                                      Margin="0,10,0,0" 
                                      Padding="10"
                                      Visibility="Collapsed">
                                <GroupBox.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Parameter Grouping" FontWeight="SemiBold"/>
                                        <Border Style="{StaticResource TooltipIcon}">
                                            <Border.ToolTip>
                                                <ToolTip>
                                                    <TextBlock MaxWidth="280" TextWrapping="Wrap">
                                                        Select which parameter to use for grouping elements.
                                                        <LineBreak/><LineBreak/>
                                                        <Bold>Enabled when:</Bold> Numbering Group is set to "Order by Parameter"
                                                        <LineBreak/><LineBreak/>
                                                        Elements will be grouped by this parameter's value. Each unique value becomes a group in the Group Order list, which you can reorder.
                                                        <LineBreak/><LineBreak/>
                                                        Within each group, elements are ordered by the selected Order Mode (Largest to Smallest, Clockwise, etc.).
                                                    </TextBlock>
                                                </ToolTip>
                                            </Border.ToolTip>
                                            <TextBlock Style="{StaticResource TooltipText}"/>
                                        </Border>
                                    </StackPanel>
                                </GroupBox.Header>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <TextBlock Grid.Column="0" 
                                             Text="Parameter:" 
                                             VerticalAlignment="Center"/>
                                    <ComboBox Name="OrderParameterBox" 
                                            Grid.Column="1"
                                            IsEditable="True"/>
                                </Grid>
                            </GroupBox>
                        </StackPanel>
                    </GroupBox>

                    <!-- Additional Options -->
                    <GroupBox Margin="0,0,0,10" 
                              Padding="10">
                        <GroupBox.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Additional Options" FontWeight="SemiBold"/>
                                <Border Style="{StaticResource TooltipIcon}">
                                    <Border.ToolTip>
                                        <ToolTip>
                                            <TextBlock MaxWidth="280" TextWrapping="Wrap">
                                                Special renumbering options and behaviors.
                                                <LineBreak/><LineBreak/>
                                                Includes TextNote placement, identical part matching, and manual ordering.
                                            </TextBlock>
                                        </ToolTip>
                                    </Border.ToolTip>
                                    <TextBlock Style="{StaticResource TooltipText}"/>
                                </Border>
                            </StackPanel>
                        </GroupBox.Header>
                        <StackPanel>
                            <CheckBox Name="PlaceTagsChk" 
                                    Content="Place tags (TextNotes)" 
                                    Margin="0,3"/>

                            <CheckBox Name="PromptPosChk" 
                                    Content="Prompt for text positions" 
                                    Margin="0,3"/>

                            <CheckBox Name="SameIdentChk" 
                                    Content="Same number for identical parts" 
                                    Margin="0,3"/>
                            
                            <CheckBox Name="IncludeNestedChk" 
                                    Content="Include nested family components" 
                                    Margin="0,3">
                                <CheckBox.ToolTip>
                                    <ToolTip>
                                        <TextBlock MaxWidth="280" TextWrapping="Wrap">
                                            When checked, automatically includes:
                                            <LineBreak/><LineBreak/>
                                            • Nested components within selected families (GetSubComponentIds)
                                            <LineBreak/>
                                            • Child instances via SuperComponent property
                                            <LineBreak/><LineBreak/>
                                            Useful for door/window assemblies, equipment with nested parts, and complex families.
                                        </TextBlock>
                                    </ToolTip>
                                </CheckBox.ToolTip>
                            </CheckBox>
                            
                            <!-- Manual Pick Order with Button -->
                            <StackPanel Margin="0,3">
                                <CheckBox Name="SpecifyOrderChk" 
                                        Content="Manual pick order" 
                                        Margin="0,0,0,5"/>
                                
                                <Grid Margin="20,0,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="120"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Name="OrderStatusLabel" 
                                             Grid.Column="0"
                                             Text="(not set)" 
                                             VerticalAlignment="Center"
                                             FontSize="10"
                                             Foreground="Gray"/>

                                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                        <Button Name="PickOrderBtn" 
                                              Content="Pick Order"
                                              Padding="8,4"
                                              Width="95"
                                              IsEnabled="False"
                                              Click="OnPickOrder"/>
                                        <Border Style="{StaticResource TooltipIcon}" Margin="3,0,0,0">
                                            <Border.ToolTip>
                                                <ToolTip>
                                                    <TextBlock MaxWidth="280" TextWrapping="Wrap">
                                                        Click to manually pick elements in numbering order.
                                                        <LineBreak/><LineBreak/>
                                                        <Bold>Instructions:</Bold>
                                                        <LineBreak/>
                                                        1. Click elements in the model in the desired order
                                                        <LineBreak/>
                                                        2. Press ESC when finished
                                                        <LineBreak/>
                                                        3. Elements will be numbered in the exact order picked
                                                        <LineBreak/><LineBreak/>
                                                        <Bold>Enabled when:</Bold> "Manual pick order" is checked
                                                    </TextBlock>
                                                </ToolTip>
                                            </Border.ToolTip>
                                            <TextBlock Style="{StaticResource TooltipText}"/>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>

                </StackPanel>
            </ScrollViewer>
        </GroupBox>

        <!-- ===== RIGHT PANEL: COMPARE OPTIONS ===== -->
        <GroupBox Grid.Column="2" Grid.Row="0" 
                  Padding="10">
            <GroupBox.Header>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Item Compare Options" FontWeight="SemiBold"/>
                    <Border Style="{StaticResource TooltipIcon}">
                        <Border.ToolTip>
                            <ToolTip>
                                <TextBlock MaxWidth="280" TextWrapping="Wrap">
                                    Select which fields to compare when determining if elements are "identical".
                                    <LineBreak/><LineBreak/>
                                    <Bold>Used when:</Bold> "Same number for identical parts" is enabled
                                    <LineBreak/><LineBreak/>
                                    Elements must match ALL checked fields to be considered identical and receive the same number.
                                </TextBlock>
                            </ToolTip>
                        </Border.ToolTip>
                        <TextBlock Style="{StaticResource TooltipText}"/>
                    </Border>
                </StackPanel>
            </GroupBox.Header>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Check All/None Buttons -->
                <StackPanel Grid.Row="0" 
                           Orientation="Horizontal" 
                           HorizontalAlignment="Right"
                           Margin="0,0,0,10">
                    <StackPanel Orientation="Horizontal" Margin="0,0,3,0">
                        <Button Name="CheckAllBtn" 
                                Content="Check All"
                                Width="80"
                                Padding="5"
                                Click="OnCheckAll"/>
                        <Border Style="{StaticResource TooltipIcon}" Margin="2,0,0,0">
                            <Border.ToolTip>
                                <ToolTip>
                                    <TextBlock MaxWidth="280" TextWrapping="Wrap">
                                        Check all comparison fields at once.
                                        <LineBreak/><LineBreak/>
                                        Elements must match every field to be considered identical.
                                    </TextBlock>
                                </ToolTip>
                            </Border.ToolTip>
                            <TextBlock Style="{StaticResource TooltipText}"/>
                        </Border>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Button Name="CheckNoneBtn" 
                                Content="Check None"
                                Width="80"
                                Padding="5"
                                Click="OnCheckNone"/>
                        <Border Style="{StaticResource TooltipIcon}" Margin="2,0,0,0">
                            <Border.ToolTip>
                                <ToolTip>
                                    <TextBlock MaxWidth="280" TextWrapping="Wrap">
                                        Uncheck all comparison fields at once.
                                        <LineBreak/><LineBreak/>
                                        Useful for starting fresh when selecting specific comparison criteria.
                                    </TextBlock>
                                </ToolTip>
                            </Border.ToolTip>
                            <TextBlock Style="{StaticResource TooltipText}"/>
                        </Border>
                    </StackPanel>
                </StackPanel>

                <!-- Options List -->
                <Border Grid.Row="1" 
                        BorderBrush="LightGray" 
                        BorderThickness="1"
                        Padding="5"
                        MaxHeight="220">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl Name="OptionsList">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="2"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox Content="{Binding Name}"
                                            IsChecked="{Binding Include, Mode=TwoWay}"
                                            Margin="3"
                                            VerticalAlignment="Center"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>

                <!-- NEW Separator -->
                <Separator Grid.Row="2" Margin="0,10,0,5" />

                <!-- Deselect Elements Section -->
                <GroupBox Grid.Row="3" Padding="10" MaxHeight="330">
                    <GroupBox.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Deselect Elements" FontWeight="SemiBold"/>
                            <Border Style="{StaticResource TooltipIcon}">
                                <Border.ToolTip>
                                    <ToolTip>
                                        <TextBlock MaxWidth="320" TextWrapping="Wrap">
                                            Remove elements from the current selection using multiple deselection methods.
                                            <LineBreak/><LineBreak/>
                                            <Bold>Deselect By:</Bold>
                                            <LineBreak/>• <Bold>Individual</Bold> - Select and remove specific elements by ID
                                            <LineBreak/>• <Bold>Category</Bold> - Remove all elements of selected categories
                                            <LineBreak/>• <Bold>Family</Bold> - Remove all elements of selected families
                                            <LineBreak/>• <Bold>Type</Bold> - Remove all elements of selected types
                                            <LineBreak/>• <Bold>Parameter Value</Bold> - Remove elements by parameter values (choose parameter, select values to exclude)
                                            <LineBreak/><LineBreak/>
                                            <Bold>Workflow:</Bold>
                                            <LineBreak/>1. Select deselection mode
                                            <LineBreak/>2. For Parameter Value mode: choose parameter from dropdown
                                            <LineBreak/>3. Select item(s) from list (Ctrl+Click for multiple)
                                            <LineBreak/>4. Click "Deselect" to remove selected items
                                            <LineBreak/><LineBreak/>
                                            List shows element counts for each item. Use "Deselect All" to clear entire selection.
                                        </TextBlock>
                                    </ToolTip>
                                </Border.ToolTip>
                                <TextBlock Style="{StaticResource TooltipText}"/>
                            </Border>
                        </StackPanel>
                    </GroupBox.Header>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Deselect Mode Selector -->
                        <Grid Grid.Row="0" Margin="0,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <TextBlock Grid.Row="0" Grid.Column="0"
                                     Text="Deselect by:" 
                                     VerticalAlignment="Center" 
                                     Margin="0,0,10,0"/>
                            
                            <StackPanel Grid.Row="0" Grid.Column="1" Grid.RowSpan="2" Orientation="Vertical">
                                <RadioButton Name="DeselectIndividualRadio" 
                                           Content="Individual" 
                                           GroupName="DeselectMode"
                                           IsChecked="True"
                                           Margin="0,0,0,3"
                                           Checked="OnDeselectModeChanged"/>
                                <RadioButton Name="DeselectCategoryRadio" 
                                           Content="Category" 
                                           GroupName="DeselectMode"
                                           Margin="0,0,0,3"
                                           Checked="OnDeselectModeChanged"/>
                                <RadioButton Name="DeselectFamilyRadio" 
                                           Content="Family" 
                                           GroupName="DeselectMode"
                                           Margin="0,0,0,3"
                                           Checked="OnDeselectModeChanged"/>
                                <RadioButton Name="DeselectTypeRadio" 
                                           Content="Type" 
                                           GroupName="DeselectMode"
                                           Margin="0,0,0,3"
                                           Checked="OnDeselectModeChanged"/>
                                <RadioButton Name="DeselectParameterRadio" 
                                           Content="Parameter Value" 
                                           GroupName="DeselectMode"
                                           Checked="OnDeselectModeChanged"/>
                            </StackPanel>
                        </Grid>

                        <!-- Parameter selection (only visible when Parameter Value mode is selected) -->
                        <Grid Name="DeselectParameterControls" 
                              Grid.Row="0" 
                              Margin="0,5,0,5"
                              Visibility="Collapsed">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                     Text="Parameter:" 
                                     VerticalAlignment="Center" 
                                     Margin="0,0,10,0"/>
                            <ComboBox Name="DeselectParameterCombo" 
                                    Grid.Column="1"
                                    IsEditable="True"/>
                        </Grid>

                        <!-- List of items to deselect -->
                        <Border Grid.Row="1" 
                                BorderBrush="LightGray" 
                                BorderThickness="1"
                                Margin="0,0,0,5">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ListBox Name="DeselectItemsList" 
                                         SelectionMode="Extended"
                                         MinHeight="80">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Name}" 
                                                         Width="310"
                                                         Margin="0,0,10,0"
                                                         TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding Count}" 
                                                         Width="60"
                                                         Foreground="Gray"
                                                         TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </ScrollViewer>
                        </Border>

                        <!-- Deselect buttons -->
                        <StackPanel Grid.Row="2" 
                                   Orientation="Horizontal" 
                                   HorizontalAlignment="Right">
                            <StackPanel Orientation="Horizontal" Margin="0,0,3,0">
                                <Button Name="DeselectSelectedBtn" 
                                        Content="Deselect"
                                        Width="80"
                                        Padding="5"
                                        Click="OnDeselectSelected"/>
                                <Border Style="{StaticResource TooltipIcon}" Margin="2,0,0,0">
                                    <Border.ToolTip>
                                        <ToolTip>
                                            <TextBlock MaxWidth="280" TextWrapping="Wrap">
                                                Remove the selected items from the list.
                                                <LineBreak/><LineBreak/>
                                                Behavior depends on mode:
                                                <LineBreak/>• Individual: Removes specific elements
                                                <LineBreak/>• Category/Family/Type: Removes all elements matching selection
                                            </TextBlock>
                                        </ToolTip>
                                    </Border.ToolTip>
                                    <TextBlock Style="{StaticResource TooltipText}"/>
                                </Border>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Button Name="DeselectAllBtn" 
                                        Content="Deselect All"
                                        Width="80"
                                        Padding="5"
                                        Click="OnDeselectAll"/>
                                <Border Style="{StaticResource TooltipIcon}" Margin="2,0,0,0">
                                    <Border.ToolTip>
                                        <ToolTip>
                                            <TextBlock MaxWidth="280" TextWrapping="Wrap">
                                                Clear all selected elements.
                                                <LineBreak/><LineBreak/>
                                                Removes all elements from the selection, allowing you to start fresh.
                                            </TextBlock>
                                        </ToolTip>
                                    </Border.ToolTip>
                                    <TextBlock Style="{StaticResource TooltipText}"/>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </GroupBox>

                <!-- NEW Separator -->
                <Separator Grid.Row="4" Margin="0,10,0,5" />

                <!-- NEW GroupBox for Dynamic Compare Parameters -->
                <GroupBox Grid.Row="5" Padding="10">
                    <GroupBox.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Additional Compare Parameters" FontWeight="SemiBold"/>
                            <Border Style="{StaticResource TooltipIcon}">
                                <Border.ToolTip>
                                    <ToolTip>
                                        <TextBlock MaxWidth="280" TextWrapping="Wrap">
                                            Add custom parameters for comparing elements beyond the standard fields.
                                            <LineBreak/><LineBreak/>
                                            <Bold>Use Case:</Bold> Compare elements using project-specific or custom shared parameters.
                                            <LineBreak/><LineBreak/>
                                            Elements must match these parameters (in addition to checked fields above) to be considered identical.
                                        </TextBlock>
                                    </ToolTip>
                                </Border.ToolTip>
                                <TextBlock Style="{StaticResource TooltipText}"/>
                            </Border>
                        </StackPanel>
                    </GroupBox.Header>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" 
                                 Text="Param 1:" 
                                 VerticalAlignment="Center" 
                                 Margin="0,0,10,5"/>
                        <ComboBox Name="CompareParamBox1" 
                                Grid.Row="0" Grid.Column="1"
                                IsEditable="True"
                                Margin="0,0,0,5"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" 
                                 Text="Param 2:" 
                                 VerticalAlignment="Center" 
                                 Margin="0,0,10,5"/>
                        <ComboBox Name="CompareParamBox2" 
                                Grid.Row="1" Grid.Column="1"
                                IsEditable="True"
                                Margin="0,0,0,5"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" 
                                 Text="Param 3:" 
                                 VerticalAlignment="Center" 
                                 Margin="0,0,10,5"/>
                        <ComboBox Name="CompareParamBox3" 
                                Grid.Row="2" Grid.Column="1"
                                IsEditable="True"
                                Margin="0,0,0,5"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" 
                                 Text="Param 4:" 
                                 VerticalAlignment="Center" 
                                 Margin="0,0,10,5"/>
                        <ComboBox Name="CompareParamBox4" 
                                Grid.Row="3" Grid.Column="1"
                                IsEditable="True"
                                Margin="0,0,0,5"/>
                    </Grid>
                </GroupBox>
            </Grid>
        </GroupBox>

        <!-- ===== BOTTOM BUTTONS ===== -->
        <StackPanel Grid.Column="0" 
                    Grid.ColumnSpan="3" 
                    Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0">
            <StackPanel Orientation="Horizontal" Margin="0,0,5,0">
                <Button Name="CancelBtn" 
                        Content="Cancel"
                        Width="90"
                        Padding="10,8"
                        IsCancel="True"
                        Click="OnCancel"/>
                <Border Style="{StaticResource TooltipIcon}" Margin="3,0,0,0">
                    <Border.ToolTip>
                        <ToolTip>
                            <TextBlock MaxWidth="280" TextWrapping="Wrap">
                                Close the dialog without making changes.
                                <LineBreak/><LineBreak/>
                                No elements will be renumbered and current settings will be preserved.
                            </TextBlock>
                        </ToolTip>
                    </Border.ToolTip>
                    <TextBlock Style="{StaticResource TooltipText}"/>
                </Border>
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <Button Name="OKBtn" 
                        Content="OK"
                        Width="90"
                        Padding="10,8"
                        IsDefault="True"
                        Click="OnOK"/>
                <Border Style="{StaticResource TooltipIcon}" Margin="3,0,0,0">
                    <Border.ToolTip>
                        <ToolTip>
                            <TextBlock MaxWidth="280" TextWrapping="Wrap">
                                Apply renumbering to all selected elements.
                                <LineBreak/><LineBreak/>
                                Elements will be renumbered according to your configured settings.
                                <LineBreak/><LineBreak/>
                                <Bold>Requirements:</Bold> At least one element must be selected and one target parameter must be specified.
                            </TextBlock>
                        </ToolTip>
                    </Border.ToolTip>
                    <TextBlock Style="{StaticResource TooltipText}"/>
                </Border>
            </StackPanel>
        </StackPanel>

    </Grid>
</Window>
