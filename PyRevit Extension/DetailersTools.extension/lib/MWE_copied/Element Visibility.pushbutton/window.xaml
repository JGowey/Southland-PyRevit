<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Element Visibility Analyzer"
        Width="600" Height="800"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F5F5F5">

    <Window.Resources>
        <!-- Modern Button Style -->
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#005A9E"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#CCCCCC"/>
                    <Setter Property="Cursor" Value="Arrow"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Secondary Button Style -->
        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#0078D4"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#0078D4"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F0F0F0"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Section Header Style -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <!-- Info Text Style -->
        <Style x:Key="InfoText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#666666"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <!-- ComboBox Style -->
        <Style x:Key="ModernComboBox" TargetType="ComboBox">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Element Visibility Analyzer" FontSize="20" FontWeight="Bold" Foreground="#333333"/>
            <TextBlock Text="Diagnose why an element is visible in one view but hidden in another" 
                       Style="{StaticResource InfoText}" Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Main Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Step 1: Element Selection -->
                <Border Background="White" CornerRadius="6" Padding="16" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Step 1: Select Element" Style="{StaticResource SectionHeader}"/>
                        <TextBlock Text="Choose the element instance that is visible in one view but missing in another. You can reselect as many times as needed." 
                                   Style="{StaticResource InfoText}" Margin="0,0,0,12"/>

                        <!-- Last Element Button (conditional) -->
                        <Button x:Name="btnUseLastElement" 
                                Content="Use Last Element (Id: ---)" 
                                Style="{StaticResource SecondaryButton}"
                                Height="40"
                                Margin="0,0,0,8"
                                Click="OnUseLastElement"
                                Visibility="Collapsed"/>

                        <!-- Element Selection Buttons -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Button x:Name="btnPickElement" 
                                    Grid.Column="0"
                                    Content="Pick Element in Model" 
                                    Style="{StaticResource ModernButton}"
                                    Height="40"
                                    Click="OnPickElement"/>

                            <Button x:Name="btnEnterElementId" 
                                    Grid.Column="2"
                                    Content="Enter ElementId" 
                                    Style="{StaticResource SecondaryButton}"
                                    Height="40"
                                    Click="OnEnterElementId"/>
                        </Grid>

                        <!-- Selected Element Display -->
                        <Border x:Name="selectedElementPanel" 
                                Background="#E8F5E9" 
                                CornerRadius="4" 
                                Padding="12" 
                                Margin="0,12,0,0"
                                Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock Text="✓ Selected Element:" FontWeight="SemiBold" FontSize="11" Foreground="#2E7D32"/>
                                <TextBlock x:Name="txtSelectedElement" 
                                           Text="Element Name (Id: 123456)" 
                                           FontSize="13" 
                                           Foreground="#1B5E20"
                                           Margin="0,4,0,0"/>
                                <TextBlock Text="Click buttons above to select a different element" 
                                           FontSize="10" 
                                           FontStyle="Italic"
                                           Foreground="#4CAF50"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Step 2: Source View -->
                <Border Background="White" CornerRadius="6" Padding="16" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Step 2: Source View (Element IS Visible)" Style="{StaticResource SectionHeader}"/>
                        <TextBlock Text="Select the view where the element is currently visible." 
                                   Style="{StaticResource InfoText}" Margin="0,0,0,12"/>

                        <ComboBox x:Name="cmbSourceView"
                                  Style="{StaticResource ModernComboBox}"
                                  Height="40"
                                  IsEnabled="False"
                                  SelectionChanged="OnSourceViewChanged">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" TextWrapping="Wrap" Padding="2"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <!-- Selected Source View Display -->
                        <Border x:Name="selectedSourcePanel" 
                                Background="#E3F2FD" 
                                CornerRadius="4" 
                                Padding="12" 
                                Margin="0,12,0,0"
                                Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock Text="✓ Source View:" FontWeight="SemiBold" FontSize="11" Foreground="#1565C0"/>
                                <TextBlock x:Name="txtSelectedSource" 
                                           Text="Floor Plan • Level 1" 
                                           FontSize="12" 
                                           Foreground="#0D47A1"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Step 3: Target View -->
                <Border Background="White" CornerRadius="6" Padding="16" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Step 3: Target View (Element is MISSING)" Style="{StaticResource SectionHeader}"/>
                        <TextBlock Text="Select the view where the element is not visible." 
                                   Style="{StaticResource InfoText}" Margin="0,0,0,12"/>

                        <ComboBox x:Name="cmbTargetView"
                                  Style="{StaticResource ModernComboBox}"
                                  Height="40"
                                  IsEnabled="False"
                                  SelectionChanged="OnTargetViewChanged">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" TextWrapping="Wrap" Padding="2"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <!-- Selected Target View Display -->
                        <Border x:Name="selectedTargetPanel" 
                                Background="#FFF3E0" 
                                CornerRadius="4" 
                                Padding="12" 
                                Margin="0,12,0,0"
                                Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock Text="✓ Target View:" FontWeight="SemiBold" FontSize="11" Foreground="#E65100"/>
                                <TextBlock x:Name="txtSelectedTarget" 
                                           Text="Floor Plan • Level 2" 
                                           FontSize="12" 
                                           Foreground="#BF360C"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Action Buttons -->
        <Grid Grid.Row="2" Margin="0,20,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button x:Name="btnCancel" 
                    Grid.Column="0"
                    Content="Cancel" 
                    Style="{StaticResource SecondaryButton}"
                    Height="40"
                    Click="OnCancel"/>

            <Button x:Name="btnAnalyze" 
                    Grid.Column="2"
                    Content="Analyze Visibility" 
                    Style="{StaticResource ModernButton}"
                    Height="40"
                    Width="180"
                    IsEnabled="False"
                    Click="OnAnalyze"/>
        </Grid>
    </Grid>
</Window>