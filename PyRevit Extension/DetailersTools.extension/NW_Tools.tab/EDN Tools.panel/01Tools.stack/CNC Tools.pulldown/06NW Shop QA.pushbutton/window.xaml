<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NW Shop QA Standards" Height="900" Width="750" WindowStartupLocation="CenterScreen"
        Background="#F5F7FB" FontFamily="Segoe UI" FontSize="12" UseLayoutRounding="True">
    
    <Window.Resources>
        <!-- Palette -->
        <Color x:Key="ColBg">#F5F7FB</Color>
        <Color x:Key="ColCard">#FFFFFFFF</Color>
        <Color x:Key="ColStroke">#E5E8F0</Color>
        <Color x:Key="ColText">#1F2937</Color>
        <Color x:Key="ColSubtle">#6B7280</Color>
        <Color x:Key="ColAccent">#2563EB</Color>
        <Color x:Key="ColSuccess">#10B981</Color>
        <Color x:Key="ColWarning">#F59E0B</Color>
        
        <SolidColorBrush x:Key="BrushBg" Color="{StaticResource ColBg}"/>
        <SolidColorBrush x:Key="BrushCard" Color="{StaticResource ColCard}"/>
        <SolidColorBrush x:Key="BrushStroke" Color="{StaticResource ColStroke}"/>
        <SolidColorBrush x:Key="BrushText" Color="{StaticResource ColText}"/>
        <SolidColorBrush x:Key="BrushSubtle" Color="{StaticResource ColSubtle}"/>
        <SolidColorBrush x:Key="BrushAccent" Color="{StaticResource ColAccent}"/>

        <!-- Card Style -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource BrushCard}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrushStroke}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <!-- Header Text -->
        <Style x:Key="Header" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource BrushText}"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <!-- Label Style -->
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="{StaticResource BrushSubtle}"/>
            <Setter Property="Padding" Value="0,2,4,2"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>

        <!-- TextBox Style -->
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="24"/>
            <Setter Property="Width" Value="60"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrushStroke}"/>
            <Setter Property="Background" Value="#FCFCFD"/>
            <Setter Property="Padding" Value="4,0"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>

        <!-- CheckBox Style -->
        <Style TargetType="CheckBox">
            <Setter Property="Margin" Value="0,3,12,3"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>

        <!-- Button Styles -->
        <Style x:Key="BaseButton" TargetType="Button">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" TextElement.FontWeight="SemiBold"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
            <Setter Property="Background" Value="{StaticResource BrushAccent}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrushAccent}"/>
        </Style>

        <Style x:Key="GhostButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource BrushText}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrushStroke}"/>
        </Style>

        <Style x:Key="SmallButton" TargetType="Button" BasedOn="{StaticResource GhostButton}">
            <Setter Property="Height" Value="24"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="8,0"/>
        </Style>

        <!-- Tooltip Icon Style -->
        <Style x:Key="TooltipIcon" TargetType="Border">
            <Setter Property="Width" Value="16"/>
            <Setter Property="Height" Value="16"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Background" Value="#6B7280"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style x:Key="TooltipText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Text" Value="?"/>
        </Style>

    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title & Profile Actions -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <StackPanel Grid.Column="0">
                <TextBlock Text="NW Shop QA Configuration" FontSize="18" FontWeight="Bold" Foreground="{StaticResource BrushText}"/>
                <TextBlock Text="Configure shop standards and select which rules to enforce" FontSize="12" Foreground="{StaticResource BrushSubtle}" Margin="0,2,0,0"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                <Button x:Name="ImportBtn" Content="Import" Width="65" Style="{StaticResource GhostButton}" Click="Import_Click" Margin="0,0,6,0" ToolTip="Load settings from a file"/>
                <Button x:Name="ExportBtn" Content="Export" Width="65" Style="{StaticResource GhostButton}" Click="Export_Click" Margin="0,0,6,0" ToolTip="Save current settings to a file"/>
                <Button x:Name="SaveDefaultBtn" Content="Save Default" Width="85" Style="{StaticResource GhostButton}" Click="SaveDefault_Click" ToolTip="Save as default for future runs"/>
            </StackPanel>
        </Grid>

        <!-- Tab Control -->
        <TabControl Grid.Row="1" Margin="0,0,0,12">
            
            <!-- TAB 1: Selection & Settings -->
            <TabItem Header=" Settings ">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,8,0">
                    <StackPanel Margin="8">
                        
                        <!-- Selection & Profile -->
                        <Border Style="{StaticResource Card}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel Grid.Column="0">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                        <TextBlock Text="Selection" Style="{StaticResource Header}" Margin="0"/>
                                        <Border Style="{StaticResource TooltipIcon}">
                                            <Border.ToolTip>
                                                <ToolTip>
                                                    <TextBlock MaxWidth="260" TextWrapping="Wrap">
                                                        Pre-select fabrication ductwork before running, or click
                                                        "Pick from Model" to select interactively.
                                                        <LineBreak/><LineBreak/>
                                                        Leave selection empty to scan all visible elements in the
                                                        active view when you click Run Analysis.
                                                    </TextBlock>
                                                </ToolTip>
                                            </Border.ToolTip>
                                            <TextBlock Style="{StaticResource TooltipText}"/>
                                        </Border>
                                    </StackPanel>
                                    <TextBlock x:Name="SelectionCount" Text="0 elements selected" FontWeight="Bold" Foreground="{StaticResource BrushAccent}"/>
                                    <Button x:Name="PickBtn" Content="Pick from Model" Width="120" HorizontalAlignment="Left" Margin="0,6,0,0" Style="{StaticResource SmallButton}" Click="Pick_Click"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Database Profile" Style="{StaticResource Header}"/>
                                    <RadioButton x:Name="rb_enterprise" Content="Enterprise" IsChecked="True" Margin="0,0,0,4" GroupName="DB"/>
                                    <RadioButton x:Name="rb_legacy" Content="Legacy" GroupName="DB"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Geometric Limits -->
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="Geometric Limits (Inches)" Style="{StaticResource Header}" Margin="0"/>
                                    <Border Style="{StaticResource TooltipIcon}">
                                        <Border.ToolTip>
                                            <ToolTip>
                                                <TextBlock MaxWidth="260" TextWrapping="Wrap">
                                                    These thresholds drive the straight-duct length rules.
                                                    <LineBreak/><LineBreak/>
                                                    <Bold>Coil Max</Bold> -- pieces longer than this are flagged OVERSIZED.
                                                    <LineBreak/>
                                                    <Bold>Coil Min</Bold> -- pieces shorter than this are flagged TOO SHORT.
                                                    <LineBreak/>
                                                    <Bold>Transition Min/Max</Bold> -- valid length range for transitions.
                                                    <LineBreak/><LineBreak/>
                                                    All values in inches.
                                                </TextBlock>
                                            </ToolTip>
                                        </Border.ToolTip>
                                        <TextBlock Style="{StaticResource TooltipText}"/>
                                    </Border>
                                </StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="70"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <Label Grid.Row="0" Grid.Column="0" Content="Max Coil Width"/>
                                    <TextBox Grid.Row="0" Grid.Column="1" x:Name="max_coil_width"/>
                                    <Label Grid.Row="0" Grid.Column="3" Content="Min Spiral"/>
                                    <TextBox Grid.Row="0" Grid.Column="4" x:Name="min_spiral_length"/>
                                    <Label Grid.Row="0" Grid.Column="6" Content="Max Spiral Round"/>
                                    <TextBox Grid.Row="0" Grid.Column="7" x:Name="max_spiral_length_round"/>

                                    <Label Grid.Row="1" Grid.Column="0" Content="Max Rect Straight"/>
                                    <TextBox Grid.Row="1" Grid.Column="1" x:Name="max_rect_straight_length"/>
                                    <Label Grid.Row="1" Grid.Column="3" Content="Max Oval"/>
                                    <TextBox Grid.Row="1" Grid.Column="4" x:Name="max_spiral_length_oval"/>
                                    <Label Grid.Row="1" Grid.Column="6" Content="Tolerance"/>
                                    <TextBox Grid.Row="1" Grid.Column="7" x:Name="tolerance"/>

                                    <Label Grid.Row="2" Grid.Column="0" Content="Min Transition"/>
                                    <TextBox Grid.Row="2" Grid.Column="1" x:Name="min_transition_length"/>
                                    <Label Grid.Row="2" Grid.Column="3" Content="Max Transition"/>
                                    <TextBox Grid.Row="2" Grid.Column="4" x:Name="max_transition_length"/>
                                    <Label Grid.Row="2" Grid.Column="6" Content="Min TDC Straight"/>
                                    <TextBox Grid.Row="2" Grid.Column="7" x:Name="min_straight_tdc"/>

                                    <Label Grid.Row="3" Grid.Column="0" Content="Min Offset"/>
                                    <TextBox Grid.Row="3" Grid.Column="1" x:Name="min_offset_length"/>
                                    <Label Grid.Row="3" Grid.Column="3" Content="Max Offset"/>
                                    <TextBox Grid.Row="3" Grid.Column="4" x:Name="max_offset_length"/>
                                    <Label Grid.Row="3" Grid.Column="6" Content="Max DW Round"/>
                                    <TextBox Grid.Row="3" Grid.Column="7" x:Name="max_double_wall_round_length"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Straights & Connectors -->
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="Connectors and Extensions" Style="{StaticResource Header}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="70"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <Label Grid.Row="0" Grid.Column="0" Content="TDC Target"/>
                                    <TextBox Grid.Row="0" Grid.Column="1" x:Name="target_len_tdc"/>
                                    <Label Grid.Row="0" Grid.Column="3" Content="TDC Ext"/>
                                    <TextBox Grid.Row="0" Grid.Column="4" x:Name="ext_tdc"/>
                                    <Label Grid.Row="0" Grid.Column="6" Content="Ogee 1-Way"/>
                                    <TextBox Grid.Row="0" Grid.Column="7" x:Name="ext_ogee_1way"/>

                                    <Label Grid.Row="1" Grid.Column="0" Content="S and D Target"/>
                                    <TextBox Grid.Row="1" Grid.Column="1" x:Name="target_len_sd"/>
                                    <Label Grid.Row="1" Grid.Column="3" Content="S and D Ext"/>
                                    <TextBox Grid.Row="1" Grid.Column="4" x:Name="ext_sd"/>
                                    <Label Grid.Row="1" Grid.Column="6" Content="Flange Ext"/>
                                    <TextBox Grid.Row="1" Grid.Column="7" x:Name="ext_flange"/>

                                    <Label Grid.Row="2" Grid.Column="0" Content="S and D Lg Head"/>
                                    <TextBox Grid.Row="2" Grid.Column="1" x:Name="target_len_sd_large"/>
                                    <Label Grid.Row="2" Grid.Column="3" Content="TDC Tap Str In"/>
                                    <TextBox Grid.Row="2" Grid.Column="4" x:Name="tap_tdc_straight_in"/>
                                    <Label Grid.Row="2" Grid.Column="6" Content="Short Joint"/>
                                    <TextBox Grid.Row="2" Grid.Column="7" x:Name="short_joint_seam_threshold"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Elbows -->
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="Elbows" Style="{StaticResource Header}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="70"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <Label Grid.Row="0" Grid.Column="0" Content="Min Throat"/>
                                    <TextBox Grid.Row="0" Grid.Column="1" x:Name="min_elbow_throat_length"/>
                                    <Label Grid.Row="0" Grid.Column="3" Content="Sq Throat Std"/>
                                    <TextBox Grid.Row="0" Grid.Column="4" x:Name="sq_elbow_throat_std"/>
                                    <Label Grid.Row="0" Grid.Column="6" Content="Sq Throat Min"/>
                                    <TextBox Grid.Row="0" Grid.Column="7" x:Name="sq_elbow_throat_min"/>

                                    <Label Grid.Row="1" Grid.Column="0" Content="Sq Throat Max"/>
                                    <TextBox Grid.Row="1" Grid.Column="1" x:Name="sq_elbow_throat_max"/>
                                    <Label Grid.Row="1" Grid.Column="3" Content="Sq TDC Total"/>
                                    <TextBox Grid.Row="1" Grid.Column="4" x:Name="sq_elbow_throat_total_tdc"/>
                                    <Label Grid.Row="1" Grid.Column="6" Content="Throat Radius"/>
                                    <TextBox Grid.Row="1" Grid.Column="7" x:Name="elbow_throat_radius"/>

                                    <Label Grid.Row="2" Grid.Column="0" Content="Split Thresh A"/>
                                    <TextBox Grid.Row="2" Grid.Column="1" x:Name="elbow_split_threshold_a"/>
                                    <Label Grid.Row="2" Grid.Column="3" Content="Split Thresh B"/>
                                    <TextBox Grid.Row="2" Grid.Column="4" x:Name="elbow_split_threshold_b"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Square to Round -->
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="Square to Round" Style="{StaticResource Header}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="70"/>
                                    </Grid.ColumnDefinitions>

                                    <Label Grid.Row="0" Grid.Column="0" Content="Body Min"/>
                                    <TextBox Grid.Row="0" Grid.Column="1" x:Name="sq2rd_body_min"/>
                                    <Label Grid.Row="0" Grid.Column="3" Content="Body Max"/>
                                    <TextBox Grid.Row="0" Grid.Column="4" x:Name="sq2rd_body_max"/>
                                    <Label Grid.Row="0" Grid.Column="6" Content="Ratio Max"/>
                                    <TextBox Grid.Row="0" Grid.Column="7" x:Name="sq2rd_ratio_max"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Dampers -->
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="Dampers" Style="{StaticResource Header}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="70"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <Label Grid.Row="0" Grid.Column="0" Content="Buyout Height"/>
                                    <TextBox Grid.Row="0" Grid.Column="1" x:Name="damper_buyout_height"/>
                                    <Label Grid.Row="0" Grid.Column="3" Content="Single Max W"/>
                                    <TextBox Grid.Row="0" Grid.Column="4" x:Name="damper_single_blade_max_width"/>
                                    <Label Grid.Row="0" Grid.Column="6" Content="Single Max D"/>
                                    <TextBox Grid.Row="0" Grid.Column="7" x:Name="damper_single_blade_max_depth"/>

                                    <Label Grid.Row="1" Grid.Column="0" Content="Multi Width"/>
                                    <TextBox Grid.Row="1" Grid.Column="1" x:Name="damper_multi_blade_width"/>
                                    <Label Grid.Row="1" Grid.Column="3" Content="Multi Depth"/>
                                    <TextBox Grid.Row="1" Grid.Column="4" x:Name="damper_multi_blade_depth"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- TAB 2: Rule Toggles -->
            <TabItem Header=" Rules ">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,8,0">
                    <StackPanel Margin="8">

                        <!-- Quick Actions -->
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="Rule Toggles" Style="{StaticResource Header}" Margin="0"/>
                                    <Border Style="{StaticResource TooltipIcon}">
                                        <Border.ToolTip>
                                            <ToolTip>
                                                <TextBlock MaxWidth="260" TextWrapping="Wrap">
                                                    Enable or disable individual QA rules before running.
                                                    <LineBreak/><LineBreak/>
                                                    Disabled rules are skipped entirely -- no flags, no color
                                                    overrides for that check. Use this to suppress rules that
                                                    don't apply to a specific project or scope.
                                                    <LineBreak/><LineBreak/>
                                                    Use "Enable All" / "Disable All" to toggle everything at once.
                                                    "Reset to Defaults" restores the factory rule set.
                                                </TextBlock>
                                            </ToolTip>
                                        </Border.ToolTip>
                                        <TextBlock Style="{StaticResource TooltipText}"/>
                                    </Border>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Enable All" Width="80" Style="{StaticResource SmallButton}" Click="EnableAll_Click" Margin="0,0,8,0"/>
                                    <Button Content="Disable All" Width="80" Style="{StaticResource SmallButton}" Click="DisableAll_Click" Margin="0,0,8,0"/>
                                    <Button Content="Reset to Defaults" Width="100" Style="{StaticResource SmallButton}" Click="ResetRules_Click"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Rectangular Coil Fit -->
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="Rectangular Coil Fit" Style="{StaticResource Header}"/>
                                <CheckBox x:Name="rule_coil_panel_width" Content="R-COIL-PANEL-WIDTH: Rect panel width at or under max coil width" IsChecked="True"/>
                                <CheckBox x:Name="rule_rect_elbow_cheek" Content="R-RECT-ELBOW-CHEEK: Rect elbow cheek fits on coil" IsChecked="True"/>
                                <CheckBox x:Name="rule_rect_straight_length" Content="R-RECT-LENGTH-MAX: Rect straight at or under max length" IsChecked="True"/>
                            </StackPanel>
                        </Border>

                        <!-- Rectangular Elbows -->
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="Rectangular Elbows" Style="{StaticResource Header}"/>
                                <CheckBox x:Name="rule_rect_elbow_min_radius" Content="R-ELBOW-MIN-RADIUS: Rect elbow min CLR by angle" IsChecked="True"/>
                                <CheckBox x:Name="rule_rect_elbow_throat" Content="R-RECT-ELBOW-THROAT: Rect radius elbow throat length" IsChecked="True"/>
                                <CheckBox x:Name="rule_square_elbow_throat" Content="R-SQ-ELBOW-THROAT: Square elbow throat limits (1.5 to 24 in, 9 in TDC total)" IsChecked="True"/>
                            </StackPanel>
                        </Border>

                        <!-- Round/Oval Duct -->
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="Round / Oval Duct" Style="{StaticResource Header}"/>
                                <CheckBox x:Name="rule_round_length_range" Content="R-ROUND-LENGTH-RANGE: Round/spiral length 4 to 240 in" IsChecked="True"/>
                                <CheckBox x:Name="rule_oval_length_max" Content="R-OVAL-LENGTH-MAX: Oval at or under 120 in" IsChecked="True"/>
                                <CheckBox x:Name="rule_lined_round_multiple" Content="R-ROUND-LINER-MULTIPLE: Joint multiple of liner width" IsChecked="True"/>
                                <CheckBox x:Name="rule_round_elbow_segmentation" Content="R-ELBOW-SEGMENTATION: Round 90 deg elbow segments (40-60 in = 2, 60+ in = 3)" IsChecked="True"/>
                                <CheckBox x:Name="rule_double_wall_round_length" Content="R-DW-ROUND-LENGTH: Double wall round at or under 144 in" IsChecked="True"/>
                            </StackPanel>
                        </Border>

                        <!-- Transitions & Offsets -->
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="Transitions and Offsets" Style="{StaticResource Header}"/>
                                <CheckBox x:Name="rule_rect_transition_length" Content="R-RECT-TRANS-LENGTH: Rect transition 12 to 48 in" IsChecked="True"/>
                                <CheckBox x:Name="rule_rect_offset_length" Content="R-RECT-OFFSET: Mitered offset 12 to 48 in" IsChecked="True"/>
                                <CheckBox x:Name="rule_ogee_offset_straight" Content="R-OGEE-OFFSET-STRAIGHT: Ogee straight requirements" IsChecked="True"/>
                            </StackPanel>
                        </Border>

                        <!-- Square to Round -->
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="Square to Round" Style="{StaticResource Header}"/>
                                <CheckBox x:Name="rule_sq2rd_body_limits" Content="R-SQ2RD-BODY: Body length 8 to 48 in and 1:2 ratio" IsChecked="True"/>
                            </StackPanel>
                        </Border>

                        <!-- Taps -->
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="Taps" Style="{StaticResource Header}"/>
                                <CheckBox x:Name="rule_tdc_tap_straight" Content="R-TDC-TAP-STRAIGHT: TDC tap 1.5 in straight in" IsChecked="True"/>
                                <CheckBox x:Name="rule_no_corner_tap_tdc" Content="R-NO-CORNER-TAP-TDC: No corner taps on TDC" IsChecked="True"/>
                            </StackPanel>
                        </Border>

                        <!-- Straights -->
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="Straights" Style="{StaticResource Header}"/>
                                <CheckBox x:Name="rule_rect_tdc_minjoint" Content="R-RECT-TDC-MINJOINT: TDC/TDC straight min 9 in" IsChecked="True"/>
                                <CheckBox x:Name="rule_short_joint_seam" Content="R-SHORT-JOINT-SEAM: Short joint seam advisory (under 7 in lap and spot)" IsChecked="True"/>
                                <CheckBox x:Name="rule_fullauto_sameconn" Content="R-FULLAUTO-SAMECONN: Full (Auto) same connector both ends" IsChecked="True"/>
                            </StackPanel>
                        </Border>

                        <!-- Dampers -->
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="Dampers" Style="{StaticResource Header}"/>
                                <CheckBox x:Name="rule_damper_buyout" Content="R-DAMPER-BUYOUT: Dampers over 12 in must be bought out" IsChecked="True"/>
                                <CheckBox x:Name="rule_damper_blade_sizing" Content="R-DAMPER-BLADE-SIZE: Single blade 36x12, multi over 36 or over 14 depth" IsChecked="True"/>
                            </StackPanel>
                        </Border>

                        <!-- Policy Checks -->
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="Policy and Notes" Style="{StaticResource Header}"/>
                                <CheckBox x:Name="rule_exposed_note" Content="R-EXPOSED-NOTE: Exposed flag requires Exposed in notes" IsChecked="True"/>
                            </StackPanel>
                        </Border>

                        <!-- Project Exceptions (Toggleable Policies) -->
                        <Border Style="{StaticResource Card}" Background="#FFF8E7">
                            <StackPanel>
                                <TextBlock Text="Project Exceptions (Allow if checked)" Style="{StaticResource Header}" Foreground="#B45309"/>
                                <CheckBox x:Name="allow_ogee" Content="Allow Ogee Offsets (otherwise fail all ogee fittings)"/>
                                <CheckBox x:Name="allow_sq2rd_straight" Content="Allow Straight on Sq2Rd (rect end)"/>
                                <CheckBox x:Name="allow_trans_straight" Content="Allow Straight on Transitions"/>
                                <CheckBox x:Name="allow_bullhead_tees" Content="Allow Bullhead Tees / Pants"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- TAB 3: CID Database -->
            <TabItem Header=" CID Database ">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Header & Stats -->
                    <Border Grid.Row="0" Style="{StaticResource Card}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Part Identification Database" Style="{StaticResource Header}"/>
                                <TextBlock x:Name="CidConfigPath" Text="Config: Not loaded" FontSize="10" Foreground="{StaticResource BrushSubtle}" TextWrapping="Wrap"/>
                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <TextBlock x:Name="CidTotalCount" Text="0 total" FontWeight="Bold" Foreground="{StaticResource BrushAccent}" Margin="0,0,16,0"/>
                                    <TextBlock x:Name="CidPreferredCount" Text="0 preferred" Foreground="#10B981" Margin="0,0,16,0"/>
                                    <TextBlock x:Name="CidNonPreferredCount" Text="0 non-preferred" Foreground="#EF4444"/>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                                <Button x:Name="RefreshCidBtn" Content="Refresh" Width="70" Style="{StaticResource SmallButton}" Click="RefreshCid_Click" Margin="0,0,6,0" ToolTip="Reload from config file"/>
                                <Button x:Name="OpenCidFileBtn" Content="Open File" Width="70" Style="{StaticResource SmallButton}" Click="OpenCidFile_Click" ToolTip="Open config in default editor"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- CID List -->
                    <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,0,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <!-- Filter -->
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                                <Label Content="Filter:"/>
                                <TextBox x:Name="CidFilterBox" Width="150" TextChanged="CidFilter_Changed" ToolTip="Filter by CID, part type, or description"/>
                                <Label Content="Show:" Margin="16,0,0,0"/>
                                <ComboBox x:Name="CidFilterType" Width="100" SelectionChanged="CidFilterType_Changed" SelectedIndex="0">
                                    <ComboBoxItem Content="All"/>
                                    <ComboBoxItem Content="Preferred"/>
                                    <ComboBoxItem Content="Non-Preferred"/>
                                    <ComboBoxItem Content="Elbows"/>
                                    <ComboBoxItem Content="Straights"/>
                                    <ComboBoxItem Content="Transitions"/>
                                    <ComboBoxItem Content="Taps"/>
                                    <ComboBoxItem Content="Tees"/>
                                </ComboBox>
                            </StackPanel>

                            <!-- DataGrid -->
                            <DataGrid Grid.Row="1" x:Name="CidDataGrid" 
                                      AutoGenerateColumns="False" 
                                      IsReadOnly="True"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="Horizontal"
                                      BorderThickness="1"
                                      BorderBrush="{StaticResource BrushStroke}"
                                      Background="White"
                                      RowBackground="White"
                                      AlternatingRowBackground="#F9FAFB">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="CID" Binding="{Binding CID}" Width="60"/>
                                    <DataGridTextColumn Header="Part Type" Binding="{Binding PartType}" Width="100"/>
                                    <DataGridTextColumn Header="Pref" Binding="{Binding PrefDisplay}" Width="45"/>
                                    <DataGridTextColumn Header="Alias" Binding="{Binding Alias}" Width="50"/>
                                    <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*"/>
                                    <DataGridTextColumn Header="Service" Binding="{Binding ServiceName}" Width="80"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>

                    <!-- Actions -->
                    <Border Grid.Row="2" Style="{StaticResource Card}" Margin="0,12,0,0" Padding="8">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="To add parts: Select in Revit → Run 'Dump FabPart Info' tool" 
                                       Foreground="{StaticResource BrushSubtle}" 
                                       VerticalAlignment="Center" 
                                       FontStyle="Italic"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

        </TabControl>

        <!-- Footer Actions -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <TextBlock Text="v2.0 - NW SMS Standards" Foreground="{StaticResource BrushSubtle}" VerticalAlignment="Center"/>
            
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button x:Name="CancelBtn" Content="Cancel" Width="90" Style="{StaticResource GhostButton}" Click="Cancel_Click" Margin="0,0,10,0"/>
                <Button x:Name="RunBtn" Content="Run Analysis" Width="120" Style="{StaticResource PrimaryButton}" Click="Run_Click" IsDefault="True"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
