<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Legend / Detail Converter"
    Width="560"
    Height="690"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterScreen"
    Background="#F5F7FB"
    FontFamily="Segoe UI">

    <Window.Resources>
        <SolidColorBrush x:Key="BrushBg" Color="#F5F7FB"/>
        <SolidColorBrush x:Key="BrushCard" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="BrushStroke" Color="#E5E7EB"/>
        <SolidColorBrush x:Key="BrushText" Color="#0F172A"/>
        <SolidColorBrush x:Key="BrushSubtle" Color="#475569"/>
        <SolidColorBrush x:Key="BrushAccent" Color="#2563EB"/>
        <SolidColorBrush x:Key="BrushWarn" Color="#92400E"/>
        <SolidColorBrush x:Key="BrushSuccess" Color="#166534"/>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource BrushCard}"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrushStroke}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
        </Style>

        <Style x:Key="TooltipIcon" TargetType="Border">
            <Setter Property="Width" Value="16"/>
            <Setter Property="Height" Value="16"/>
            <Setter Property="Background" Value="#E2E8F0"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Margin" Value="8,0,0,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="TooltipText" TargetType="TextBlock">
            <Setter Property="Text" Value="?"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#334155"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FAFBFF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SuccessButton" TargetType="Button" BasedOn="{StaticResource GhostButton}">
            <Setter Property="Background" Value="#ECFDF5"/>
            <Setter Property="BorderBrush" Value="#A7F3D0"/>
            <Setter Property="Foreground" Value="{StaticResource BrushSuccess}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="DirButton" TargetType="RadioButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd"
                                Background="{StaticResource BrushCard}"
                                BorderBrush="{StaticResource BrushStroke}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="16,12"
                                Cursor="Hand">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock x:Name="IconTxt"
                                           Text="{TemplateBinding Tag}"
                                           FontSize="20"
                                           HorizontalAlignment="Center"
                                           Foreground="{StaticResource BrushSubtle}"/>
                                <TextBlock Text="{TemplateBinding Content}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           Foreground="{StaticResource BrushSubtle}"
                                           Margin="0,6,0,0"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#EDF2FE"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#93C5FD"/>
                                <Setter TargetName="IconTxt" Property="Foreground" Value="{StaticResource BrushAccent}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F5F8FF"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#CBD7FB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrushStroke}"/>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource BrushBg}" Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,18">
            <TextBlock Text="Legend / Detail Converter"
                       FontSize="22"
                       FontWeight="Bold"
                       Foreground="{StaticResource BrushText}"/>
            <TextBlock Text="Convert between Legend views and Drafting Detail views with direct element rebuilding for supported annotation classes"
                       FontSize="12"
                       Foreground="{StaticResource BrushSubtle}"
                       Margin="0,2,0,0"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <TextBlock Text="Direction"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource BrushText}"
                                       VerticalAlignment="Center"/>
                            <Border Style="{StaticResource TooltipIcon}">
                                <Border.ToolTip>
                                    <ToolTip>
                                        <TextBlock MaxWidth="280" TextWrapping="Wrap">
                                            Choose which direction to convert.
                                            Legend to Detail creates a new Drafting view.
                                            Detail to Legend creates a new Legend view.
                                        </TextBlock>
                                    </ToolTip>
                                </Border.ToolTip>
                                <TextBlock Style="{StaticResource TooltipText}"/>
                            </Border>
                        </StackPanel>
                        <UniformGrid Columns="2" Rows="1">
                            <RadioButton x:Name="DirLegendToDetail"
                                         Style="{StaticResource DirButton}"
                                         Content="Legend  &#x2192;  Detail"
                                         Tag="&#x1F4CB; &#x2192; &#x1F4D0;"
                                         GroupName="Direction"
                                         IsChecked="True"
                                         Margin="0,0,6,0"
                                         Checked="OnDirectionChanged"/>
                            <RadioButton x:Name="DirDetailToLegend"
                                         Style="{StaticResource DirButton}"
                                         Content="Detail  &#x2192;  Legend"
                                         Tag="&#x1F4D0; &#x2192; &#x1F4CB;"
                                         GroupName="Direction"
                                         Checked="OnDirectionChanged"/>
                        </UniformGrid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock x:Name="SourceLabel"
                                       Text="Source Legend"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource BrushText}"
                                       VerticalAlignment="Center"/>
                            <Border Style="{StaticResource TooltipIcon}">
                                <Border.ToolTip>
                                    <ToolTip>
                                        <TextBlock MaxWidth="280" TextWrapping="Wrap">
                                            Select the view to convert. The list shows
                                            all views of the appropriate type in the project.
                                        </TextBlock>
                                    </ToolTip>
                                </Border.ToolTip>
                                <TextBlock Style="{StaticResource TooltipText}"/>
                            </Border>
                        </StackPanel>
                        <ComboBox x:Name="SourceViewCombo"
                                  SelectionChanged="OnSourceViewChanged"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Options"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource BrushText}"
                                   Margin="0,0,0,14"/>

                        <CheckBox x:Name="DeleteSourceChk"
                                  Content="Delete source view after conversion"
                                  Margin="0,0,0,10"
                                  IsChecked="False"/>

                        <CheckBox x:Name="OpenResultChk"
                                  Content="Open converted view when done"
                                  Margin="0,0,0,10"
                                  IsChecked="True"/>

                        <CheckBox x:Name="ZoomResultChk"
                                  Content="Zoom to fit result view when done"
                                  IsChecked="True"/>
                    </StackPanel>
                </Border>

                <Border x:Name="WarnCard"
                        Background="#FFFBEB"
                        CornerRadius="10"
                        BorderBrush="#FDE68A"
                        BorderThickness="1"
                        Padding="16"
                        Margin="0,0,0,14"
                        Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#x26A0;"
                                   FontSize="18"
                                   Foreground="{StaticResource BrushWarn}"
                                   VerticalAlignment="Top"
                                   Margin="0,0,10,0"/>
                        <TextBlock x:Name="WarnText"
                                   Foreground="{StaticResource BrushWarn}"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border x:Name="ResultHintCard"
                        Style="{StaticResource Card}"
                        Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="Transfer Method"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource BrushText}"
                                   Margin="0,0,0,10"/>
                        <TextBlock x:Name="ResultHintText"
                                   Foreground="{StaticResource BrushSubtle}"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   LineHeight="20"/>
                    </StackPanel>
                </Border>

                <Border x:Name="SummaryCard"
                        Style="{StaticResource Card}"
                        Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="Summary"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource BrushText}"
                                   Margin="0,0,0,10"/>
                        <TextBlock x:Name="SummaryText"
                                   Foreground="{StaticResource BrushSubtle}"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   LineHeight="20"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,14,0,0">
            <Button x:Name="CancelBtn"
                    Style="{StaticResource GhostButton}"
                    Content="Cancel"
                    Width="90"
                    Height="36"
                    IsCancel="True"
                    Click="OnCancel"/>
            <Button x:Name="ConvertBtn"
                    Style="{StaticResource SuccessButton}"
                    Content="Convert"
                    Width="110"
                    Height="36"
                    Margin="8,0,0,0"
                    IsDefault="True"
                    IsEnabled="False"
                    Click="OnConvert"/>
        </StackPanel>
    </Grid>
</Window>
