<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Renumber" Height="1000" Width="1050" MinWidth="950"
        WindowStartupLocation="CenterScreen"
        Background="#F5F7FB"
        FontFamily="Segoe UI"
        FontSize="12"
        ShowInTaskbar="False"
        ResizeMode="CanResize">
    
    <Window.Resources>
        <!-- Color Palette -->
        <SolidColorBrush x:Key="BrushBg" Color="#F5F7FB"/>
        <SolidColorBrush x:Key="BrushCard" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="BrushStroke" Color="#E5E8F0"/>
        <SolidColorBrush x:Key="BrushAccent" Color="#2563EB"/>
        
        <!-- Tooltip Icon Style -->
        <Style x:Key="TooltipIcon" TargetType="Border">
            <Setter Property="Width" Value="16"/>
            <Setter Property="Height" Value="16"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Background" Value="#6B7280"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="4,0,0,0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        
        <Style x:Key="TooltipText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Text" Value="?"/>
        </Style>
        
        <!-- Subtle TextBox styling -->
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrushStroke}"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource BrushAccent}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <!-- Subtle ComboBox styling -->
        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="6,4"/>
        </Style>
        
        <!-- Subtle Button styling -->
        <Style TargetType="Button">
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>
    
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="540"/>
            <ColumnDefinition Width="10"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ===== LEFT PANEL: SET OPTIONS ===== -->
        <GroupBox Grid.Column="0" Grid.Row="0" Padding="10">
            <GroupBox.Header>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Set Options" FontWeight="SemiBold"/>
                    <Border Style="{StaticResource TooltipIcon}">
                        <Border.ToolTip>
                            <ToolTip>
                                <TextBlock MaxWidth="280" TextWrapping="Wrap">
                                    Configure renumbering settings, including target parameters, numbering options, and ordering modes.
                                    <LineBreak/><LineBreak/>
                                    Supports multiple workflows: manual picking, automatic ordering, and grouping by category/family/type.
                                </TextBlock>
                            </ToolTip>
                        </Border.ToolTip>
                        <TextBlock Style="{StaticResource TooltipText}"/>
                    </Border>
                </StackPanel>
            </GroupBox.Header>
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <!-- Pick Elements and Profile Buttons -->
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="65"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="115"/>
                            <ColumnDefinition Width="115"/>
                        </Grid.ColumnDefinitions>

                        <Label Name="PickedCountLbl" 
                               Grid.Column="0"
                               Content="(none)" 
                               VerticalAlignment="Center"
                               HorizontalAlignment="Left"
                               Padding="0"/>

                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Name="PickElemsBtn" 
                                    Content="Pick Elements"
                                    Padding="8,5"
                                    Click="OnPickElements"/>
                            <Border Style="{StaticResource TooltipIcon}" Margin="3,0,0,0">
                                <Border.ToolTip>
                                    <ToolTip>
                                        <TextBlock MaxWidth="280" TextWrapping="Wrap">
                                            Click to select elements in the model that you want to renumber.
                                            <LineBreak/><LineBreak/>
                                            <Bold>Usage:</Bold> Select multiple elements using standard Revit selection methods (click, window, filter).
                                            <LineBreak/><LineBreak/>
                                            Works with Fabrication Parts, standard Revit elements, and all element types.
                                        </TextBlock>
                                    </ToolTip>
                                </Border.ToolTip>
                                <TextBlock Style="{StaticResource TooltipText}"/>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Name="SaveProfileBtn" 
                                    Content="Save Profile"
                                    Padding="5,5"
                                    Width="92"
                                    Click="OnSaveProfile"/>
                            <Border Style="{StaticResource TooltipIcon}" Margin="3,0,0,0">
                                <Border.ToolTip>
                                    <ToolTip>
                                        <TextBlock MaxWidth="280" TextWrapping="Wrap">
                                            Save the current configuration as a reusable profile.
                                            <LineBreak/><LineBreak/>
                                            <Bold>Saves:</Bold> All numbering options, target parameters, compare fields, and grouping settings.
                                            <LineBreak/><LineBreak/>
                                            Profiles are saved as XML files and can be loaded later for quick reuse.
                                        </TextBlock>
                                    </ToolTip>
                                </Border.ToolTip>
                                <TextBlock Style="{StaticResource TooltipText}"/>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Column="3" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Name="LoadProfileBtn" 
                                    Content="Load Profile"
                                    Padding="5,5"
                                    Width="92"
                                    Click="OnLoadProfile"/>
                            <Border Style="{StaticResource TooltipIcon}" Margin="3,0,0,0">
                                <Border.ToolTip>
                                    <ToolTip>
                                        <TextBlock MaxWidth="280" TextWrapping="Wrap">
                                            Load a previously saved configuration profile.
                                            <LineBreak/><LineBreak/>
                                            <Bold>Action:</Bold> Opens a file browser to select an XML profile file.
                                            <LineBreak/><LineBreak/>
                                            All settings from the profile will be restored, including targets, compare options, and numbering preferences.
                                        </TextBlock>
                                    </ToolTip>
                                </Border.ToolTip>
                                <TextBlock Style="{StaticResource TooltipText}"/>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <!-- NEW: Filter Selection Box (Collapsible) - STYLED -->
                    <Expander Name="FilterBox" 
                              Margin="0,0,0,10" 
                              Padding="5"
                              IsExpanded="False"
                              BorderBrush="#F59E0B"
                              BorderThickness="1">
                        <Expander.Header>
                            <StackPanel Orientation="Horizontal">
                                <Border Background="#F59E0B" CornerRadius="3" Padding="6,2" Margin="0,0,8,0">
                                    <TextBlock Text="▼" Foreground="White" FontSize="10" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Filter Selection" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="#F59E0B"/>
                                <Border Style="{StaticResource TooltipIcon}">
                                    <Border.ToolTip>
                                        <ToolTip>
                                            <TextBlock MaxWidth="280" TextWrapping="Wrap">
                                                Filter picked elements by a specific parameter value.
                                                <LineBreak/><LineBreak/>
                                                <Bold>Use Case:</Bold> Narrow down your selection after picking elements.
                                                <LineBreak/><LineBreak/>
                                                Example: Filter to only "6 inch" pipe sizes, or only "Domestic Cold Water" services.
                                            </TextBlock>
                                        </ToolTip>
                                    </Border.ToolTip>
                                    <TextBlock Style="{StaticResource TooltipText}"/>
                                </Border>
                            </StackPanel>
                        </Expander.Header>
                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="110"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <TextBlock Grid.Row="0" Grid.Column="0" 
                                     Text="Parameter:" 
                                     VerticalAlignment="Center" 
                                     Margin="0,0,10,5"/>
                            <ComboBox Name="FilterParamBox" 
                                    Grid.Row="0" Grid.Column="1"
                                    IsEditable="True"
                                    Margin="0,0,5,5"/>
                            
                            <StackPanel Grid.Row="0" Grid.Column="2" Grid.RowSpan="2" 
                                       Orientation="Vertical" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Name="FilterApplyBtn" 
                                            Content="Apply Filter"
                                            Width="90"
                                            Padding="5"
                                            Click="OnFilterApply"/>
                                    <Border Style="{StaticResource TooltipIcon}" Margin="3,0,0,0">
                                        <Border.ToolTip>
                                            <ToolTip>
                                                <TextBlock MaxWidth="280" TextWrapping="Wrap">
                                                    Apply the filter to reduce the element list.
                                                    <LineBreak/><LineBreak/>
                                                    Only elements matching the parameter value will remain selected.
                                                    <LineBreak/><LineBreak/>
                                                    Click again to clear the filter and restore all picked elements.
                                                </TextBlock>
                                            </ToolTip>
                                        </Border.ToolTip>
                                        <TextBlock Style="{StaticResource TooltipText}"/>
                                    </Border>
                                </StackPanel>
                                <TextBlock Name="FilterStatusLbl" 
                                         Text="(clear filter)" 
                                         HorizontalAlignment="Center"
                                         FontSize="10"
                                         Foreground="Gray"
                                         Margin="0,3,0,0"/>
                            </StackPanel>

                            <TextBlock Grid.Row="1" Grid.Column="0" 
                                     Text="Value:" 
                                     VerticalAlignment="Center" 
                                     Margin="0,0,10,5"/>
                            <ComboBox Name="FilterValueBox" 
                                    Grid.Row="1" Grid.Column="1"
                                    IsEditable="True"
                                    Margin="0,0,5,5"/>
                        </Grid>
                    </Expander>

                    <!-- Target Parameters -->
                    <GroupBox Margin="0,0,0,10" 
                              Padding="10">
                        <GroupBox.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Target Parameters (write number to up to 3)" FontWeight="SemiBold"/>
                                <Border Style="{StaticResource TooltipIcon}">
                                    <Border.ToolTip>
                                        <ToolTip>
                                            <TextBlock MaxWidth="280" TextWrapping="Wrap">
                                                Specify up to 3 parameters where the renumbered value will be written.
                                                <LineBreak/><LineBreak/>
                                                <Bold>Common Targets:</Bold> Item Number, Mark, Assembly Mark, Number, Tag, or any custom parameter.
                                                <LineBreak/><LineBreak/>
                                                All three targets will receive the same generated number (prefix + number + suffix).
                                            </TextBlock>
                                        </ToolTip>
                                    </Border.ToolTip>
                                    <TextBlock Style="{StaticResource TooltipText}"/>
                                </Border>
                            </StackPanel>
                        </GroupBox.Header>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" 
                                     Text="Target A:" 
                                     VerticalAlignment="Center" 
                                     Margin="0,0,10,5"/>
                            <ComboBox Name="TargetParamBoxA" 
                                    Grid.Row="0" Grid.Column="1"
                                    IsEditable="True"
                                    Margin="0,0,0,5"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" 
                                     Text="Target B:" 
                                     VerticalAlignment="Center" 
                                     Margin="0,0,10,5"/>
                            <ComboBox Name="TargetParamBoxB" 
                                    Grid.Row="1" Grid.Column="1"
                                    IsEditable="True"
                                    Margin="0,0,0,5"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" 
                                     Text="Target C:" 
                                     VerticalAlignment="Center" 
                                     Margin="0,0,10,5"/>
                            <ComboBox Name="TargetParamBoxC" 
                                    Grid.Row="2" Grid.Column="1"
                                    IsEditable="True"
                                    Margin="0,0,0,5"/>
                        </Grid>
                    </GroupBox>

                    <!-- Numbering Options -->
                    <GroupBox Margin="0,0,0,10" 
                              Padding="10">
                        <GroupBox.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Numbering Options" FontWeight="SemiBold"/>
                                <Border Style="{StaticResource TooltipIcon}">
                                    <Border.ToolTip>
                                        <ToolTip>
                                            <TextBlock MaxWidth="280" TextWrapping="Wrap">
                                                Configure prefix, suffix, and starting number for the renumbering sequence.
                                                <LineBreak/><LineBreak/>
                                                These settings determine the format of each generated number.
                                            </TextBlock>
                                        </ToolTip>
                                    </Border.ToolTip>
                                    <TextBlock Style="{StaticResource TooltipText}"/>
                                </Border>
                            </StackPanel>
                        </GroupBox.Header>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="15"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Row 1: Prefix and Start Number -->
                            <TextBlock Grid.Row="0" Grid.Column="0" 
                                     Text="Prefix:" 
                                     VerticalAlignment="Center" 
                                     Margin="0,0,8,5"/>
                            <TextBox Name="PrefixBox" 
                                   Grid.Row="0" Grid.Column="1"
                                   Margin="0,0,0,5"/>

                            <TextBlock Grid.Row="0" Grid.Column="3" 
                                     Text="Start #:" 
                                     VerticalAlignment="Center" 
                                     Margin="0,0,8,5"/>
                            <TextBox Name="StartNumberBox" 
                                   Grid.Row="0" Grid.Column="4"
                                   Text="1"
                                   Margin="0,0,0,5"/>

                            <!-- Row 2: Suffix and Zero Padding -->
                            <TextBlock Grid.Row="1" Grid.Column="0" 
                                     Text="Suffix:" 
                                     VerticalAlignment="Center" 
                                     Margin="0,0,8,0"/>
                            <TextBox Name="SuffixBox" 
                                   Grid.Row="1" Grid.Column="1"/>

                            <TextBlock Grid.Row="1" Grid.Column="3" 
                                     Text="Padding:" 
                                     VerticalAlignment="Center" 
                                     Margin="0,0,8,0"
                                     ToolTip="Number of digits to pad to (e.g., 3 for 001, 002, 003). Leave empty for no padding."/>
                            <TextBox Name="ZeroPadBox" 
                                   Grid.Row="1" Grid.Column="4"
                                   Text=""
                                   ToolTip="Enter number of digits (e.g., 3 for 001). Leave empty for no padding."/>
                        </Grid>
                    </GroupBox>

                    <!-- Ordering Options -->
                    <GroupBox Margin="0,0,0,10" 
                              Padding="10">
                        <GroupBox.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Ordering Options" FontWeight="SemiBold"/>
                                <Border Style="{StaticResource TooltipIcon}">
                                    <Border.ToolTip>
                                        <ToolTip>
                                            <TextBlock MaxWidth="280" TextWrapping="Wrap">
                                                Configure how elements are grouped and ordered for numbering.
                                                <LineBreak/><LineBreak/>
                                                Includes grouping mode, group order, and element ordering method.
                                            </TextBlock>
                                        </ToolTip>
                                    </Border.ToolTip>
                                    <TextBlock Style="{StaticResource TooltipText}"/>
                                </Border>
                            </StackPanel>
                        </GroupBox.Header>
                        <StackPanel>
                            <!-- Row 1: Numbering Group and Order Mode side by side -->
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="15"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" 
                                         Text="Group:" 
                                         VerticalAlignment="Center"
                                         Margin="0,0,8,0"/>
                                <ComboBox Name="GroupingModeBox" 
                                        Grid.Column="1"/>

                                <TextBlock Grid.Column="3" 
                                         Text="Order:" 
                                         VerticalAlignment="Center"
                                         Margin="0,0,8,0"/>
                                <ComboBox Name="OrderModeBox" 
                                        Grid.Column="4"/>
                            </Grid>

                            <!-- Group Order ListBox (Collapsible) - STYLED -->
                            <Expander Name="GroupOrderBox" 
                                      Margin="0,0,0,8" 
                                      Padding="5"
                                      IsExpanded="False"
                                      BorderBrush="#3B82F6"
                                      BorderThickness="1"
                                      Visibility="Collapsed">
                                <Expander.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <Border Background="#3B82F6" CornerRadius="3" Padding="6,2" Margin="0,0,8,0">
                                            <TextBlock Text="▼" Foreground="White" FontSize="10" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="Group Order" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="#3B82F6"/>
                                        <Border Style="{StaticResource TooltipIcon}">
                                            <Border.ToolTip>
                                                <ToolTip>
                                                    <TextBlock MaxWidth="280" TextWrapping="Wrap">
                                                        Define the order in which groups are numbered.
                                                        <LineBreak/><LineBreak/>
                                                        <Bold>Available when:</Bold> Numbering Group is "By Category", "By Family", "By Type", or "Order by Parameter"
                                                        <LineBreak/><LineBreak/>
                                                        Use Move Up/Down buttons to reorder. Numbers increment across groups in this order.
                                                        <LineBreak/><LineBreak/>
                                                        For "Order by Parameter" mode, this shows the distinct parameter values found in your selection.
                                                    </TextBlock>
                                                </ToolTip>
                                            </Border.ToolTip>
                                            <TextBlock Style="{StaticResource TooltipText}"/>
                                        </Border>
                                    </StackPanel>
                                </Expander.Header>
                                <Grid Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <ListBox Name="GroupOrderList" 
                                             Grid.Column="0" 
                                             Height="120"
                                             DisplayMemberPath="Name"/>
                                    
                                    <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                                        <Button Name="MoveUpBtn" 
                                                Content="Move Up" 
                                                Width="80" 
                                                Padding="5" 
                                                Margin="0,0,0,5"
                                                Click="OnMoveUp"/>
                                        <Button Name="MoveDownBtn" 
                                                Content="Move Down" 
                                                Width="80" 
                                                Padding="5"
                                                Click="OnMoveDown"/>
                                    </StackPanel>
                                </Grid>
                            </Expander>

                            <!-- Pick Curve Row (compact) -->
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Name="CurvePickedLabel" 
                                         Grid.Column="0"
                                         Text="(not applicable)" 
                                         VerticalAlignment="Center"
                                         FontSize="10"
                                         Foreground="Gray"/>

                                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Name="PickCurveBtn" 
                                          Content="Pick Curve"
                                          Padding="6,3"
                                          IsEnabled="False"
                                          Click="OnPickCurve"/>
                                    <Border Style="{StaticResource TooltipIcon}" Margin="3,0,0,0">
                                        <Border.ToolTip>
                                            <ToolTip>
                                                <TextBlock MaxWidth="280" TextWrapping="Wrap">
                                                    Pick a spline or curve to follow when ordering elements.
                                                    <LineBreak/><LineBreak/>
                                                    <Bold>Enabled when:</Bold> Order Mode is set to "Follow spline"
                                                    <LineBreak/><LineBreak/>
                                                    Elements will be numbered based on their distance along the selected curve.
                                                </TextBlock>
                                            </ToolTip>
                                        </Border.ToolTip>
                                        <TextBlock Style="{StaticResource TooltipText}"/>
                                    </Border>
                                </StackPanel>
                            </Grid>
                            
                            <!-- Order by Parameter Controls - STYLED -->
                            <Expander Name="OrderByParameterBox" 
                                      Margin="0,0,0,0" 
                                      Padding="5"
                                      IsExpanded="True"
                                      BorderBrush="#8B5CF6"
                                      BorderThickness="1"
                                      Visibility="Collapsed">
                                <Expander.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <Border Background="#8B5CF6" CornerRadius="3" Padding="6,2" Margin="0,0,8,0">
                                            <TextBlock Text="▼" Foreground="White" FontSize="10" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="Parameter Grouping" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="#8B5CF6"/>
                                        <Border Style="{StaticResource TooltipIcon}">
                                            <Border.ToolTip>
                                                <ToolTip>
                                                    <TextBlock MaxWidth="280" TextWrapping="Wrap">
                                                        Select which parameter to use for grouping elements.
                                                        <LineBreak/><LineBreak/>
                                                        <Bold>Enabled when:</Bold> Numbering Group is set to "Order by Parameter"
                                                        <LineBreak/><LineBreak/>
                                                        Elements will be grouped by this parameter's value. Each unique value becomes a group in the Group Order list, which you can reorder.
                                                        <LineBreak/><LineBreak/>
                                                        Within each group, elements are ordered by the selected Order Mode.
                                                    </TextBlock>
                                                </ToolTip>
                                            </Border.ToolTip>
                                            <TextBlock Style="{StaticResource TooltipText}"/>
                                        </Border>
                                    </StackPanel>
                                </Expander.Header>
                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <TextBlock Grid.Column="0" 
                                             Text="Parameter:" 
                                             VerticalAlignment="Center"
                                             Margin="0,0,8,0"/>
                                    <ComboBox Name="OrderParameterBox" 
                                            Grid.Column="1"
                                            IsEditable="True"/>
                                </Grid>
                            </Expander>
                        </StackPanel>
                    </GroupBox>

                    <!-- Additional Options -->
                    <GroupBox Margin="0,0,0,10" 
                              Padding="10">
                        <GroupBox.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Additional Options" FontWeight="SemiBold"/>
                                <Border Style="{StaticResource TooltipIcon}">
                                    <Border.ToolTip>
                                        <ToolTip>
                                            <TextBlock MaxWidth="280" TextWrapping="Wrap">
                                                Special renumbering options and behaviors.
                                                <LineBreak/><LineBreak/>
                                                Includes TextNote placement, identical part matching, and manual ordering.
                                            </TextBlock>
                                        </ToolTip>
                                    </Border.ToolTip>
                                    <TextBlock Style="{StaticResource TooltipText}"/>
                                </Border>
                            </StackPanel>
                        </GroupBox.Header>
                        <StackPanel>
                            <!-- Row 1: Place Tags and Prompt Positions -->
                            <Grid Margin="0,0,0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <CheckBox Name="PlaceTagsChk" 
                                        Grid.Column="0"
                                        Content="Place tags (TextNotes)">
                                    <CheckBox.ToolTip>
                                        <ToolTip>
                                            <TextBlock MaxWidth="280" TextWrapping="Wrap">
                                                Creates TextNote elements in the active view showing the assigned numbers.
                                            </TextBlock>
                                        </ToolTip>
                                    </CheckBox.ToolTip>
                                </CheckBox>

                                <CheckBox Name="PromptPosChk" 
                                        Grid.Column="1"
                                        Content="Prompt for positions">
                                    <CheckBox.ToolTip>
                                        <ToolTip>
                                            <TextBlock MaxWidth="280" TextWrapping="Wrap">
                                                When enabled with "Place tags", you will be prompted to click a location for each TextNote.
                                            </TextBlock>
                                        </ToolTip>
                                    </CheckBox.ToolTip>
                                </CheckBox>
                            </Grid>

                            <!-- Row 2: Same Identical and Include Nested -->
                            <Grid Margin="0,0,0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <CheckBox Name="SameIdentChk" 
                                        Grid.Column="0"
                                        Content="Same # for identical">
                                    <CheckBox.ToolTip>
                                        <ToolTip>
                                            <TextBlock MaxWidth="300" TextWrapping="Wrap">
                                                When enabled, elements that match ALL checked fields in "Item Compare Options" (right panel) will receive the same number.
                                                <LineBreak/><LineBreak/>
                                                <Bold>Example:</Bold> If you check Size, CutType, and Gauge but uncheck Length, all 12x12 straight duct pieces of the same gauge get the same item number regardless of their length.
                                            </TextBlock>
                                        </ToolTip>
                                    </CheckBox.ToolTip>
                                </CheckBox>
                            
                                <CheckBox Name="IncludeNestedChk" 
                                        Grid.Column="1"
                                        Content="Include nested families">
                                    <CheckBox.ToolTip>
                                        <ToolTip>
                                            <TextBlock MaxWidth="280" TextWrapping="Wrap">
                                                When checked, automatically includes nested components within selected families.
                                            </TextBlock>
                                        </ToolTip>
                                    </CheckBox.ToolTip>
                                </CheckBox>
                            </Grid>
                            
                            <!-- Row 3: Manual Pick Order -->
                            <Grid Margin="0,3,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <CheckBox Name="SpecifyOrderChk" 
                                        Grid.Column="0"
                                        Content="Manual pick order"
                                        VerticalAlignment="Center">
                                    <CheckBox.ToolTip>
                                        <ToolTip>
                                            <TextBlock MaxWidth="280" TextWrapping="Wrap">
                                                Override automatic ordering by manually clicking elements in the desired sequence.
                                            </TextBlock>
                                        </ToolTip>
                                    </CheckBox.ToolTip>
                                </CheckBox>

                                <TextBlock Name="OrderStatusLabel" 
                                         Grid.Column="1"
                                         Text="(not set)" 
                                         VerticalAlignment="Center"
                                         FontSize="10"
                                         Foreground="Gray"
                                         Margin="10,0,0,0"/>

                                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Name="PickOrderBtn" 
                                          Content="Pick Order"
                                          Padding="6,3"
                                          IsEnabled="False"
                                          Click="OnPickOrder"/>
                                    <Border Style="{StaticResource TooltipIcon}" Margin="3,0,0,0">
                                        <Border.ToolTip>
                                            <ToolTip>
                                                <TextBlock MaxWidth="280" TextWrapping="Wrap">
                                                    Click to manually pick elements in numbering order.
                                                    <LineBreak/><LineBreak/>
                                                    <Bold>Instructions:</Bold>
                                                    <LineBreak/>
                                                    1. Click elements in the model in the desired order
                                                    <LineBreak/>
                                                    2. Press ESC when finished
                                                    <LineBreak/>
                                                    3. Elements will be numbered in the exact order picked
                                                    <LineBreak/><LineBreak/>
                                                    <Bold>Enabled when:</Bold> "Manual pick order" is checked
                                                </TextBlock>
                                            </ToolTip>
                                        </Border.ToolTip>
                                        <TextBlock Style="{StaticResource TooltipText}"/>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </GroupBox>

                </StackPanel>
            </ScrollViewer>
        </GroupBox>

        <!-- ===== RIGHT PANEL: COMPARE OPTIONS ===== -->
        <GroupBox Grid.Column="2" Grid.Row="0" 
                  Padding="10">
            <GroupBox.Header>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Item Compare Options" FontWeight="SemiBold"/>
                    <Border Style="{StaticResource TooltipIcon}">
                        <Border.ToolTip>
                            <ToolTip>
                                <TextBlock MaxWidth="320" TextWrapping="Wrap">
                                    Select which fields to compare when determining if elements are "identical".
                                    <LineBreak/><LineBreak/>
                                    <Bold>Used when:</Bold> "Same number for identical parts" is enabled
                                    <LineBreak/><LineBreak/>
                                    <Bold>How it works:</Bold>
                                    <LineBreak/>• Elements must match ALL checked fields to receive the same number
                                    <LineBreak/>• More fields checked = stricter matching = more unique numbers
                                    <LineBreak/>• Fewer fields checked = looser matching = more shared numbers
                                    <LineBreak/><LineBreak/>
                                    <Bold>Example:</Bold> For ductwork, check Size, CutType, Gauge, Connectors but uncheck Length. All 12x12 duct with same connectors get the same item number regardless of length.
                                </TextBlock>
                            </ToolTip>
                        </Border.ToolTip>
                        <TextBlock Style="{StaticResource TooltipText}"/>
                    </Border>
                </StackPanel>
            </GroupBox.Header>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Options List -->
                <Border Grid.Row="0" 
                        BorderBrush="LightGray" 
                        BorderThickness="1"
                        Padding="5"
                        MaxHeight="400">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <!-- Fab Section Header with Buttons -->
                            <DockPanel Margin="3,0,3,5">
                                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                                    <TextBlock Text="Fabrication Parts Only" 
                                               FontWeight="SemiBold" 
                                               Foreground="#2563EB"
                                               VerticalAlignment="Center"/>
                                    <Border Style="{StaticResource TooltipIcon}" Margin="3,0,0,0">
                                        <Border.ToolTip>
                                            <ToolTip>
                                                <TextBlock MaxWidth="320" TextWrapping="Wrap">
                                                    These fields only work with MEP Fabrication Parts (ITM database elements). They read native FabricationPart class properties.
                                                    <LineBreak/><LineBreak/>
                                                    <Bold>Fields:</Bold>
                                                    <LineBreak/>• <Bold>Alias</Bold> - Alternate name from ITM
                                                    <LineBreak/>• <Bold>Angle</Bold> - Fitting angle
                                                    <LineBreak/>• <Bold>Cid</Bold> - Fabrication CID number
                                                    <LineBreak/>• <Bold>CutType</Bold> - Cut type (None, Straight, Mitered, etc.)
                                                    <LineBreak/>• <Bold>Extension</Bold> - Extension length
                                                    <LineBreak/>• <Bold>FabricationNotes</Bold> - Notes from fab data
                                                    <LineBreak/>• <Bold>Gauge</Bold> - Sheet metal gauge
                                                    <LineBreak/>• <Bold>Offset</Bold> - Offset value
                                                    <LineBreak/>• <Bold>Service</Bold> - Service name from config
                                                    <LineBreak/>• <Bold>SheetMetalArea</Bold> - Surface area
                                                    <LineBreak/>• <Bold>Specification</Bold> - Spec from ITM
                                                </TextBlock>
                                            </ToolTip>
                                        </Border.ToolTip>
                                        <TextBlock Style="{StaticResource TooltipText}"/>
                                    </Border>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right">
                                    <Button Name="FabCheckAllBtn" 
                                            Content="All" 
                                            Width="40" 
                                            Padding="2" 
                                            FontSize="10"
                                            Click="OnFabCheckAll"/>
                                    <Button Name="FabCheckNoneBtn" 
                                            Content="None" 
                                            Width="40" 
                                            Padding="2" 
                                            FontSize="10"
                                            Margin="3,0,0,0"
                                            Click="OnFabCheckNone"/>
                                </StackPanel>
                            </DockPanel>
                            <ItemsControl Name="FabOptionsList">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="2"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox Content="{Binding Name}"
                                                IsChecked="{Binding Include, Mode=TwoWay}"
                                                Margin="3"
                                                VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            
                            <!-- Separator -->
                            <Separator Margin="0,8,0,8"/>
                            
                            <!-- Common Section Header with Buttons -->
                            <DockPanel Margin="3,0,3,5">
                                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                                    <TextBlock Text="Common (All Element Types)" 
                                               FontWeight="SemiBold" 
                                               Foreground="#10B981"
                                               VerticalAlignment="Center"/>
                                    <Border Style="{StaticResource TooltipIcon}" Margin="3,0,0,0">
                                        <Border.ToolTip>
                                            <ToolTip>
                                                <TextBlock MaxWidth="320" TextWrapping="Wrap">
                                                    These fields work with Fabrication Parts AND standard Revit MEP elements (ducts, pipes, fittings, equipment). They use ConnectorManager, parameter lookups, or universal properties.
                                                    <LineBreak/><LineBreak/>
                                                    <Bold>Fields:</Bold>
                                                    <LineBreak/>• <Bold>Category</Bold> - Element category name
                                                    <LineBreak/>• <Bold>CenterlineLength</Bold> - Centerline length
                                                    <LineBreak/>• <Bold>Connectors</Bold> - All connector descriptions/sizes
                                                    <LineBreak/>• <Bold>Dimensions</Bold> - Dimension parameter
                                                    <LineBreak/>• <Bold>EndConnector1/2</Bold> - Individual connector info
                                                    <LineBreak/>• <Bold>FamilyInfo</Bold> - Family and Type name
                                                    <LineBreak/>• <Bold>InsulationSpecification</Bold> - Insulation spec
                                                    <LineBreak/>• <Bold>InsulationType</Bold> - Insulation type
                                                    <LineBreak/>• <Bold>Length</Bold> - Element length
                                                    <LineBreak/>• <Bold>LiningThickness</Bold> - Duct lining
                                                    <LineBreak/>• <Bold>Material</Bold> - Material parameter
                                                    <LineBreak/>• <Bold>Size</Bold> - Size parameter
                                                    <LineBreak/>• <Bold>Status</Bold> - Status parameter
                                                    <LineBreak/>• <Bold>Weight</Bold> - Element weight
                                                </TextBlock>
                                            </ToolTip>
                                        </Border.ToolTip>
                                        <TextBlock Style="{StaticResource TooltipText}"/>
                                    </Border>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right">
                                    <Button Name="CommonCheckAllBtn" 
                                            Content="All" 
                                            Width="40" 
                                            Padding="2" 
                                            FontSize="10"
                                            Click="OnCommonCheckAll"/>
                                    <Button Name="CommonCheckNoneBtn" 
                                            Content="None" 
                                            Width="40" 
                                            Padding="2" 
                                            FontSize="10"
                                            Margin="3,0,0,0"
                                            Click="OnCommonCheckNone"/>
                                </StackPanel>
                            </DockPanel>
                            <ItemsControl Name="CommonOptionsList">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="2"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox Content="{Binding Name}"
                                                IsChecked="{Binding Include, Mode=TwoWay}"
                                                Margin="3"
                                                VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <!-- NEW Separator -->
                <Separator Grid.Row="1" Margin="0,10,0,5" />

                <!-- Deselect Elements Section -->
                <GroupBox Grid.Row="2" Padding="10" MaxHeight="330">
                    <GroupBox.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Deselect Elements" FontWeight="SemiBold"/>
                            <Border Style="{StaticResource TooltipIcon}">
                                <Border.ToolTip>
                                    <ToolTip>
                                        <TextBlock MaxWidth="320" TextWrapping="Wrap">
                                            Remove elements from the current selection using multiple deselection methods.
                                            <LineBreak/><LineBreak/>
                                            <Bold>Deselect By:</Bold>
                                            <LineBreak/>• <Bold>Individual</Bold> - Select and remove specific elements by ID
                                            <LineBreak/>• <Bold>Category</Bold> - Remove all elements of selected categories
                                            <LineBreak/>• <Bold>Family</Bold> - Remove all elements of selected families
                                            <LineBreak/>• <Bold>Type</Bold> - Remove all elements of selected types
                                            <LineBreak/>• <Bold>Parameter Value</Bold> - Remove elements by parameter values (choose parameter, select values to exclude)
                                            <LineBreak/><LineBreak/>
                                            <Bold>Workflow:</Bold>
                                            <LineBreak/>1. Select deselection mode
                                            <LineBreak/>2. For Parameter Value mode: choose parameter from dropdown
                                            <LineBreak/>3. Select item(s) from list (Ctrl+Click for multiple)
                                            <LineBreak/>4. Click "Deselect" to remove selected items
                                            <LineBreak/><LineBreak/>
                                            List shows element counts for each item. Use "Deselect All" to clear entire selection.
                                        </TextBlock>
                                    </ToolTip>
                                </Border.ToolTip>
                                <TextBlock Style="{StaticResource TooltipText}"/>
                            </Border>
                        </StackPanel>
                    </GroupBox.Header>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Row 0: Deselect Mode Selector - 2 column stacked layout -->
                        <Grid Grid.Row="0" Margin="0,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <TextBlock Grid.Column="0"
                                     Text="Deselect by:" 
                                     VerticalAlignment="Top" 
                                     Margin="0,2,10,0"/>
                            
                            <!-- 2-column radio button grid -->
                            <Grid Grid.Column="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                
                                <RadioButton Name="DeselectIndividualRadio" 
                                           Grid.Row="0" Grid.Column="0"
                                           Content="Individual" 
                                           GroupName="DeselectMode"
                                           Margin="0,0,0,3"
                                           Checked="OnDeselectModeChanged"/>
                                <RadioButton Name="DeselectCategoryRadio" 
                                           Grid.Row="0" Grid.Column="1"
                                           Content="Category" 
                                           GroupName="DeselectMode"
                                           IsChecked="True"
                                           Margin="0,0,0,3"
                                           Checked="OnDeselectModeChanged"/>
                                <RadioButton Name="DeselectFamilyRadio" 
                                           Grid.Row="1" Grid.Column="0"
                                           Content="Family" 
                                           GroupName="DeselectMode"
                                           Margin="0,0,0,3"
                                           Checked="OnDeselectModeChanged"/>
                                <RadioButton Name="DeselectTypeRadio" 
                                           Grid.Row="1" Grid.Column="1"
                                           Content="Type" 
                                           GroupName="DeselectMode"
                                           Margin="0,0,0,3"
                                           Checked="OnDeselectModeChanged"/>
                                <RadioButton Name="DeselectParameterRadio" 
                                           Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                                           Content="Parameter Value" 
                                           GroupName="DeselectMode"
                                           Checked="OnDeselectModeChanged"/>
                            </Grid>
                        </Grid>

                        <!-- Row 1: Parameter selection (only visible when Parameter mode is selected) -->
                        <Grid Name="DeselectParameterControls" 
                              Grid.Row="1" 
                              Margin="0,0,0,5"
                              Visibility="Collapsed">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                     Text="Parameter:" 
                                     VerticalAlignment="Center" 
                                     Margin="0,0,10,0"/>
                            <ComboBox Name="DeselectParameterCombo" 
                                    Grid.Column="1"
                                    IsEditable="True"
                                    StaysOpenOnEdit="False"/>
                        </Grid>

                        <!-- Row 2: List of items to deselect -->
                        <Border Grid.Row="2" 
                                BorderBrush="LightGray" 
                                BorderThickness="1"
                                Margin="0,0,0,5">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ListBox Name="DeselectItemsList" 
                                         SelectionMode="Extended"
                                         MinHeight="80">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Name}" 
                                                         Width="310"
                                                         Margin="0,0,10,0"
                                                         TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding Count}" 
                                                         Width="60"
                                                         Foreground="Gray"
                                                         TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </ScrollViewer>
                        </Border>

                        <!-- Deselect buttons -->
                        <StackPanel Grid.Row="3" 
                                   Orientation="Horizontal" 
                                   HorizontalAlignment="Right">
                            <StackPanel Orientation="Horizontal" Margin="0,0,3,0">
                                <Button Name="DeselectSelectedBtn" 
                                        Content="Deselect"
                                        Width="80"
                                        Padding="5"
                                        Click="OnDeselectSelected"/>
                                <Border Style="{StaticResource TooltipIcon}" Margin="2,0,0,0">
                                    <Border.ToolTip>
                                        <ToolTip>
                                            <TextBlock MaxWidth="280" TextWrapping="Wrap">
                                                Remove the selected items from the list.
                                                <LineBreak/><LineBreak/>
                                                Behavior depends on mode:
                                                <LineBreak/>• Individual: Removes specific elements
                                                <LineBreak/>• Category/Family/Type: Removes all elements matching selection
                                            </TextBlock>
                                        </ToolTip>
                                    </Border.ToolTip>
                                    <TextBlock Style="{StaticResource TooltipText}"/>
                                </Border>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Button Name="DeselectAllBtn" 
                                        Content="Deselect All"
                                        Width="80"
                                        Padding="5"
                                        Click="OnDeselectAll"/>
                                <Border Style="{StaticResource TooltipIcon}" Margin="2,0,0,0">
                                    <Border.ToolTip>
                                        <ToolTip>
                                            <TextBlock MaxWidth="280" TextWrapping="Wrap">
                                                Clear all selected elements.
                                                <LineBreak/><LineBreak/>
                                                Removes all elements from the selection, allowing you to start fresh.
                                            </TextBlock>
                                        </ToolTip>
                                    </Border.ToolTip>
                                    <TextBlock Style="{StaticResource TooltipText}"/>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </GroupBox>

                <!-- NEW Separator -->
                <Separator Grid.Row="3" Margin="0,10,0,5" />

                <!-- NEW GroupBox for Dynamic Compare Parameters (Collapsible) - STYLED -->
                <Expander Grid.Row="4" 
                          Padding="5"
                          IsExpanded="False"
                          BorderBrush="#EC4899"
                          BorderThickness="1">
                    <Expander.Header>
                        <StackPanel Orientation="Horizontal">
                            <Border Background="#EC4899" CornerRadius="3" Padding="6,2" Margin="0,0,8,0">
                                <TextBlock Text="▼" Foreground="White" FontSize="10" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Additional Compare Parameters" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="#EC4899"/>
                            <Border Style="{StaticResource TooltipIcon}">
                                <Border.ToolTip>
                                    <ToolTip>
                                        <TextBlock MaxWidth="280" TextWrapping="Wrap">
                                            Add custom parameters for comparing elements beyond the standard fields.
                                            <LineBreak/><LineBreak/>
                                            <Bold>Use Case:</Bold> Compare elements using project-specific or custom shared parameters.
                                            <LineBreak/><LineBreak/>
                                            Elements must match these parameters (in addition to checked fields above) to be considered identical.
                                        </TextBlock>
                                    </ToolTip>
                                </Border.ToolTip>
                                <TextBlock Style="{StaticResource TooltipText}"/>
                            </Border>
                        </StackPanel>
                    </Expander.Header>
                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" 
                                 Text="Param 1:" 
                                 VerticalAlignment="Center" 
                                 Margin="0,0,10,5"/>
                        <ComboBox Name="CompareParamBox1" 
                                Grid.Row="0" Grid.Column="1"
                                IsEditable="True"
                                Margin="0,0,0,5"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" 
                                 Text="Param 2:" 
                                 VerticalAlignment="Center" 
                                 Margin="0,0,10,5"/>
                        <ComboBox Name="CompareParamBox2" 
                                Grid.Row="1" Grid.Column="1"
                                IsEditable="True"
                                Margin="0,0,0,5"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" 
                                 Text="Param 3:" 
                                 VerticalAlignment="Center" 
                                 Margin="0,0,10,5"/>
                        <ComboBox Name="CompareParamBox3" 
                                Grid.Row="2" Grid.Column="1"
                                IsEditable="True"
                                Margin="0,0,0,5"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" 
                                 Text="Param 4:" 
                                 VerticalAlignment="Center" 
                                 Margin="0,0,10,5"/>
                        <ComboBox Name="CompareParamBox4" 
                                Grid.Row="3" Grid.Column="1"
                                IsEditable="True"
                                Margin="0,0,0,5"/>
                    </Grid>
                </Expander>
            </Grid>
        </GroupBox>

        <!-- ===== BOTTOM BUTTONS ===== -->
        <StackPanel Grid.Column="0" 
                    Grid.ColumnSpan="3" 
                    Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0">
            <StackPanel Orientation="Horizontal" Margin="0,0,5,0">
                <Button Name="RunAndPlaceTagsBtn" 
                        Content="Run &amp; Place Tags"
                        Width="120"
                        Padding="10,8"
                        Click="OnRunAndPlaceTags"/>
                <Border Style="{StaticResource TooltipIcon}" Margin="3,0,0,0">
                    <Border.ToolTip>
                        <ToolTip>
                            <TextBlock MaxWidth="280" TextWrapping="Wrap">
                                Run renumbering, then open the Place Tags tool.
                                <LineBreak/><LineBreak/>
                                After renumbering completes, the Place Tags window will open with your currently selected elements.
                            </TextBlock>
                        </ToolTip>
                    </Border.ToolTip>
                    <TextBlock Style="{StaticResource TooltipText}"/>
                </Border>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,5,0">
                <Button Name="CancelBtn" 
                        Content="Cancel"
                        Width="90"
                        Padding="10,8"
                        IsCancel="True"
                        Click="OnCancel"/>
                <Border Style="{StaticResource TooltipIcon}" Margin="3,0,0,0">
                    <Border.ToolTip>
                        <ToolTip>
                            <TextBlock MaxWidth="280" TextWrapping="Wrap">
                                Close the dialog without making changes.
                                <LineBreak/><LineBreak/>
                                No elements will be renumbered and current settings will be preserved.
                            </TextBlock>
                        </ToolTip>
                    </Border.ToolTip>
                    <TextBlock Style="{StaticResource TooltipText}"/>
                </Border>
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <Button Name="OKBtn" 
                        Content="OK"
                        Width="90"
                        Padding="10,8"
                        IsDefault="True"
                        Click="OnOK"/>
                <Border Style="{StaticResource TooltipIcon}" Margin="3,0,0,0">
                    <Border.ToolTip>
                        <ToolTip>
                            <TextBlock MaxWidth="280" TextWrapping="Wrap">
                                Apply renumbering to all selected elements.
                                <LineBreak/><LineBreak/>
                                Elements will be renumbered according to your configured settings.
                                <LineBreak/><LineBreak/>
                                <Bold>Requirements:</Bold> At least one element must be selected and one target parameter must be specified.
                            </TextBlock>
                        </ToolTip>
                    </Border.ToolTip>
                    <TextBlock Style="{StaticResource TooltipText}"/>
                </Border>
            </StackPanel>
        </StackPanel>

    </Grid>
</Window>
