<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Upper Attachment Sync"
        Width="780" Height="480"
        MinWidth="600" MinHeight="360"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5"
        Foreground="#1E1E1E"
        FontFamily="Segoe UI"
        FontSize="12"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>

        <!-- DataGrid header -->
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background"   Value="#E0E0E0"/>
            <Setter Property="Foreground"   Value="#333333"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="FontSize"     Value="11"/>
            <Setter Property="Padding"      Value="8,4"/>
            <Setter Property="BorderBrush"  Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>

        <!-- DataGrid row -->
        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#E3F2FD"/>
                    <Setter Property="Foreground" Value="#1565C0"/>
                </Trigger>
                <Trigger Property="AlternationIndex" Value="1">
                    <Setter Property="Background" Value="#FAFAFA"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- DataGrid cell -->
        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="6,0"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderBrush" Value="Transparent"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Primary button -->
        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Background"      Value="#1565C0"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Padding"         Value="14,5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1976D2"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#BDBDBD"/>
                                <Setter Property="Foreground" Value="#757575"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Tooltip Icon Style -->
        <Style x:Key="TooltipIcon" TargetType="Border">
            <Setter Property="Width" Value="16"/>
            <Setter Property="Height" Value="16"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Background" Value="#6B7280"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style x:Key="TooltipText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Text" Value="?"/>
        </Style>

        <!-- Secondary button -->
        <Style x:Key="BtnSec" TargetType="Button">
            <Setter Property="Background"      Value="White"/>
            <Setter Property="Foreground"      Value="#333333"/>
            <Setter Property="FontWeight"      Value="Normal"/>
            <Setter Property="Padding"         Value="12,5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"     Value="#BDBDBD"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F5F5F5"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#F5F5F5"/>
                                <Setter Property="Foreground" Value="#BDBDBD"/>
                                <Setter Property="BorderBrush" Value="#E0E0E0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Info banner -->
        <Border Grid.Row="0"
                Background="#FFF9C4"
                BorderBrush="#F9A825"
                BorderThickness="0,0,0,1"
                Padding="12,8">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                    <TextBlock Text="Hangers matched to selected slope line are shown below."
                               FontWeight="SemiBold" Foreground="#333"/>
                    <Border Style="{StaticResource TooltipIcon}">
                        <Border.ToolTip>
                            <ToolTip>
                                <TextBlock MaxWidth="280" TextWrapping="Wrap">
                                    This tool moves the rod-top elevation of each RFA hanger
                                    so it follows a sloped structural member or model line.
                                    <LineBreak/><LineBreak/>
                                    It writes to <Bold>Top Offset</Bold> (not Base Offset) on
                                    each hanger family instance -- the same field you would edit
                                    manually in the Properties panel.
                                    <LineBreak/><LineBreak/>
                                    Hangers outside the slope line's XY extent are skipped
                                    and listed in the output panel.
                                </TextBlock>
                            </ToolTip>
                        </Border.ToolTip>
                        <TextBlock Style="{StaticResource TooltipText}"/>
                    </Border>
                </StackPanel>
                <TextBlock Text="Select row(s) and click Remove Selected to exclude hangers from the sync."
                           Foreground="#555" Margin="0,2,0,0"/>
                <TextBlock Text="Update All writes the projected Top Offset (slope-interpolated) to all Ready hangers."
                           Foreground="#555" Margin="0,1,0,0"/>
            </StackPanel>
        </Border>

        <!-- Toolbar: hangers + line picks -->
        <Grid Grid.Row="1" Margin="10,8,10,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="Hangers:"
                       VerticalAlignment="Center" Foreground="#555"
                       FontSize="11" Margin="0,0,6,0"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="Select Hangers"
                        Style="{StaticResource BtnSec}"
                        Click="pick_hangers_click"/>
                <Border Style="{StaticResource TooltipIcon}">
                    <Border.ToolTip>
                        <ToolTip>
                            <TextBlock MaxWidth="260" TextWrapping="Wrap">
                                Pick the Generic Model RFA hanger families whose rod-top
                                elevation you want to update.
                                <LineBreak/><LineBreak/>
                                Multi-select is supported. Box-select a run of hangers,
                                then click Select Hangers.
                            </TextBlock>
                        </ToolTip>
                    </Border.ToolTip>
                    <TextBlock Style="{StaticResource TooltipText}"/>
                </Border>
            </StackPanel>

            <TextBlock Grid.Column="3" Text="Slope line:"
                       VerticalAlignment="Center" Foreground="#555"
                       FontSize="11" Margin="0,0,6,0"/>
            <TextBlock Grid.Column="4" x:Name="LineLabel"
                       Text="No slope line selected"
                       VerticalAlignment="Center" Foreground="#1565C0"
                       FontWeight="SemiBold" FontSize="11"
                       TextTrimming="CharacterEllipsis" Margin="0,0,8,0"/>
            <StackPanel Grid.Column="5" Orientation="Horizontal">
                <Button Content="Pick Line"
                        Style="{StaticResource BtnSec}"
                        Click="pick_line_click"/>
                <Border Style="{StaticResource TooltipIcon}">
                    <Border.ToolTip>
                        <ToolTip>
                            <TextBlock MaxWidth="260" TextWrapping="Wrap">
                                Pick a <Bold>Model Line</Bold> (not a Detail Line) that defines
                                the structural slope. The line's two endpoints set the Z gradient.
                                <LineBreak/><LineBreak/>
                                Each hanger's XY position is projected onto this line and the
                                Z elevation is interpolated. Hangers outside the line's XY extent
                                are skipped.
                            </TextBlock>
                        </ToolTip>
                    </Border.ToolTip>
                    <TextBlock Style="{StaticResource TooltipText}"/>
                </Border>
            </StackPanel>
        </Grid>

        <!-- Separator -->
        <Border Grid.Row="2" Height="1" Background="#E0E0E0" Margin="10,0,10,0"/>

        <!-- DataGrid -->
        <DataGrid Grid.Row="3"
                  x:Name="HangerGrid"
                  Margin="10,6,10,0"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  RowHeight="24"
                  AlternationCount="2"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="#EEEEEE"
                  BorderBrush="#CCCCCC"
                  BorderThickness="1"
                  Background="White"
                  SelectionChanged="grid_selection_changed">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Hanger ID"      Binding="{Binding HangerID}"      Width="80"/>
                <DataGridTextColumn Header="Family"         Binding="{Binding Family}"         Width="*"/>
                <DataGridTextColumn Header="Type"           Binding="{Binding Type}"           Width="80"/>
                <DataGridTextColumn Header="Top Level"      Binding="{Binding TopLevel}"       Width="80"/>
                <DataGridTextColumn Header="Current Offset" Binding="{Binding CurrentOffset}"  Width="110"/>
                <DataGridTextColumn Header="New Offset"     Binding="{Binding NewOffset}"      Width="110"/>
                <DataGridTemplateColumn Header="Status"     Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Status}"
                                       Foreground="{Binding StatusColor}"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       Padding="6,0"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Footer: status bar + buttons -->
        <Grid Grid.Row="4" Margin="10,8,10,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" x:Name="RemoveBtn"
                    Content="Remove Selected"
                    Style="{StaticResource BtnSec}"
                    IsEnabled="False"
                    Margin="0,0,8,0"
                    Click="remove_selected_click"/>

            <Button Grid.Column="1" x:Name="DebugBtn"
                    Content="Debug Report"
                    Style="{StaticResource BtnSec}"
                    IsEnabled="False"
                    Click="debug_click"/>

            <TextBlock Grid.Column="2" x:Name="StatusBar"
                       Text="No hangers loaded"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       Foreground="#757575"
                       FontSize="11"/>

            <StackPanel Grid.Column="3" Orientation="Horizontal" Margin="0,0,8,0">
                <Button x:Name="UpdateBtn"
                        Content="Update All"
                        Style="{StaticResource BtnPrimary}"
                        IsEnabled="False"
                        Click="update_click"/>
                <Border Style="{StaticResource TooltipIcon}">
                    <Border.ToolTip>
                        <ToolTip>
                            <TextBlock MaxWidth="260" TextWrapping="Wrap">
                                Writes the interpolated Top Offset to every hanger showing
                                status "Ready" in the grid above.
                                <LineBreak/><LineBreak/>
                                All writes happen in a single undoable Revit transaction.
                                Use "Remove Selected" first to exclude any hangers you do
                                not want updated.
                            </TextBlock>
                        </ToolTip>
                    </Border.ToolTip>
                    <TextBlock Style="{StaticResource TooltipText}"/>
                </Border>
            </StackPanel>

            <Button Grid.Column="4" x:Name="CloseBtn"
                    Content="Close"
                    Style="{StaticResource BtnSec}"
                    Click="cancel_click"/>
        </Grid>

    </Grid>
</Window>
