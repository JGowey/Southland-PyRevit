<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="UpdateSleeve"
        Width="900" Height="600"
        MinWidth="720" MinHeight="480"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI" FontSize="13">

    <Window.Resources>
        <Style x:Key="AccentBtn" TargetType="Button">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1D4ED8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SmallBtn" TargetType="Button">
            <Setter Property="Background" Value="#F1F5F9"/>
            <Setter Property="Foreground" Value="#1E293B"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E2E8F0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DGHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F1F5F9"/>
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid Background="#F8FAFC">
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="32"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#1E293B">
            <Grid Margin="16,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="UpdateSleeve" Foreground="White"
                               FontSize="15" FontWeight="SemiBold"/>
                    <TextBlock Text="  Sync duct/pipe dimensions to sleeve families"
                               Foreground="#94A3B8" FontSize="13" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Text="v1.0.0" Foreground="#94A3B8" FontSize="11"
                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Tabs -->
        <!-- User's Guide -->
        <Expander Grid.Row="1"
                  Header="User's Guide"
                  Background="White"
                  Foreground="#1E293B"
                  FontSize="12"
                  FontWeight="SemiBold"
                  BorderBrush="#E2E8F0"
                  BorderThickness="0,0,0,1"
                  Padding="16,8"
                  Margin="0">
            <Border Padding="4,6,16,10">
                <StackPanel>
                    <TextBlock FontSize="11" Foreground="#374151" FontWeight="SemiBold"
                               Margin="0,0,0,2">Pick Part + Sleeve  (quick)</TextBlock>
                    <TextBlock FontSize="11" Foreground="#64748B" TextWrapping="Wrap"
                               Margin="8,0,0,8">Click the launch button, pick a duct or pipe, then pick one sleeve. Moves the sleeve to the content centerpoint and writes size params instantly using saved settings. No window interaction needed.</TextBlock>

                    <TextBlock FontSize="11" Foreground="#374151" FontWeight="SemiBold"
                               Margin="0,0,0,2">Pick in Viewport  (full window)</TextBlock>
                    <TextBlock FontSize="11" Foreground="#64748B" TextWrapping="Wrap"
                               Margin="8,0,0,8">Pick a duct or pipe. The window opens showing matching sleeve families. Click a sleeve row to load its writable parameters into the dropdowns. Adjust if needed, then Apply.</TextBlock>

                    <TextBlock FontSize="11" Foreground="#374151" FontWeight="SemiBold"
                               Margin="0,0,0,2">Param dropdowns</TextBlock>
                    <TextBlock FontSize="11" Foreground="#64748B" TextWrapping="Wrap"
                               Margin="8,0,0,8">Shows writable Double parameters on that sleeve. Select the param that controls each dimension. Set to -- none -- to skip. Saved per family name across sessions.</TextBlock>

                    <TextBlock FontSize="11" Foreground="#374151" FontWeight="SemiBold"
                               Margin="0,0,0,2">OS (Oversize)</TextBlock>
                    <TextBlock FontSize="11" Foreground="#64748B" TextWrapping="Wrap"
                               Margin="8,0,0,8">Inches added to each written dimension. Rectangular content and round pipe each remember separate oversize values.</TextBlock>

                    <TextBlock FontSize="11" Foreground="#374151" FontWeight="SemiBold"
                               Margin="0,0,0,2">Rules tab</TextBlock>
                    <TextBlock FontSize="11" Foreground="#64748B" TextWrapping="Wrap"
                               Margin="8,0,0,8">Match column must be a substring of the Revit category name (e.g. "Fabrication Ductwork"). AND keyword must appear in the sleeve family name. OR keywords narrow by shape -- use "rect/rec" for rectangular, "round/rd/rnd" for round. Shape is used automatically to pick the correct rule.</TextBlock>

                    <TextBlock FontSize="11" Foreground="#374151" FontWeight="SemiBold"
                               Margin="0,0,0,2">Export / Import Settings</TextBlock>
                    <TextBlock FontSize="11" Foreground="#64748B" TextWrapping="Wrap"
                               Margin="8,0,0,0">Save param mappings, oversize values, and rules to JSON for sharing or backup. Import restores all settings and re-scans immediately.</TextBlock>
                </StackPanel>
            </Border>
        </Expander>

        <TabControl Grid.Row="2" Background="Transparent" BorderThickness="0">

            <!-- ═══ SYNC ═══ -->
            <TabItem Header="  Sync  ">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Source card -->
                    <Border Grid.Row="0"
                            Background="White" BorderBrush="#E2E8F0"
                            BorderThickness="1" CornerRadius="8"
                            Padding="12,8" Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="SOURCE" FontSize="10" FontWeight="SemiBold"
                                       Foreground="#64748B" VerticalAlignment="Center" Margin="0,0,14,0"/>
                            <TextBlock x:Name="SrcFamily" Text="--" FontWeight="SemiBold"
                                       Foreground="#1E293B" VerticalAlignment="Center" Margin="0,0,14,0"/>
                            <TextBlock x:Name="SrcShape" Text="--" Foreground="#64748B"
                                       VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock x:Name="SrcSize" Text="--" FontWeight="SemiBold"
                                       Foreground="#1E293B" VerticalAlignment="Center" Margin="0,0,14,0"/>
                            <TextBlock x:Name="SrcElev" Text="--" Foreground="#64748B"
                                       VerticalAlignment="Center" Margin="0,0,14,0"/>
                            <TextBlock x:Name="SrcCat" Text="--" Foreground="#94A3B8"
                                       FontSize="11" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Param row -->
                    <Border Grid.Row="1"
                            Background="White" BorderBrush="#E2E8F0"
                            BorderThickness="1" CornerRadius="8"
                            Padding="10,8" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock x:Name="PreviewLabel" Text=""
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="#2563EB" Margin="0,0,0,6"/>
                            <TextBlock x:Name="ParamCount"
                                       Text="Click a sleeve row to detect its params."
                                       FontSize="11" Foreground="#64748B" Margin="0,0,0,6"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="30"/>
                                    <ColumnDefinition Width="52"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Width:"
                                           FontSize="12" Foreground="#64748B" VerticalAlignment="Center"/>
                                <ComboBox Grid.Column="1" x:Name="WidthCombo"
                                          FontSize="11" Height="26" VerticalContentAlignment="Center"/>
                                <TextBlock Grid.Column="3" Text="Height/Depth:"
                                           FontSize="12" Foreground="#64748B" VerticalAlignment="Center"/>
                                <ComboBox Grid.Column="4" x:Name="HeightCombo"
                                          FontSize="11" Height="26" VerticalContentAlignment="Center"/>
                                <TextBlock Grid.Column="6" Text="Diameter:"
                                           FontSize="12" Foreground="#64748B" VerticalAlignment="Center"/>
                                <ComboBox Grid.Column="7" x:Name="DiaCombo"
                                          FontSize="11" Height="26" VerticalContentAlignment="Center"/>
                                <TextBlock Grid.Column="9" Text="OS:"
                                           FontSize="12" Foreground="#64748B"
                                           VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <TextBox Grid.Column="10" x:Name="OversizeBox"
                                         Text="2.0" FontSize="12"
                                         HorizontalContentAlignment="Center"
                                         ToolTip="Oversize in inches"/>
                                <TextBlock Grid.Column="11" Text=" in" FontSize="12"
                                           Foreground="#64748B" VerticalAlignment="Center"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Sleeve grid -->
                    <DataGrid Grid.Row="2"
                              x:Name="SleeveGrid"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              CanUserResizeRows="False"
                              SelectionMode="Single"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              AlternatingRowBackground="#F8FAFC"
                              RowHeight="26" FontSize="12"
                              BorderBrush="#E2E8F0" BorderThickness="1"
                              Background="White"
                              HorizontalGridLinesBrush="#F1F5F9"
                              ColumnHeaderStyle="{StaticResource DGHeader}">
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Header="" Binding="{Binding Selected}" Width="34"/>
                            <DataGridTextColumn Header="Family"    Binding="{Binding Family}"   Width="*"   IsReadOnly="True"/>
                            <DataGridTextColumn Header="Type"      Binding="{Binding TypeName}" Width="160" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Category"  Binding="{Binding Category}" Width="120" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Size"      Binding="{Binding Size}"     Width="80"  IsReadOnly="True"/>
                            <DataGridTextColumn Header="Elevation" Binding="{Binding Elev}"     Width="90"  IsReadOnly="True"/>
                            <DataGridTextColumn Header="ID"        Binding="{Binding ElemId}"   Width="70"  IsReadOnly="True"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Apply + Export/Import -->
                    <Grid Grid.Row="3" Margin="0,8,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Button Grid.Row="0" x:Name="BtnApply"
                                Content="Apply to Selected Sleeves"
                                Style="{StaticResource AccentBtn}"
                                Height="36"  ToolTip="Move each checked sleeve to source centerpoint and write size params. Window closes after apply."/>
                        <StackPanel Grid.Row="1" Orientation="Horizontal"
                                    HorizontalAlignment="Right" Margin="0,6,0,0">
                            <Button x:Name="BtnExport" Content="Export Settings" Style="{StaticResource SmallBtn}"
                                    Height="26" Margin="0,0,6,0" ToolTip="Save param mappings, oversize values, and rules to a JSON file."/>
                            <Button x:Name="BtnImport" Content="Import Settings" Style="{StaticResource SmallBtn}"
                                    Height="26" ToolTip="Load param mappings, oversize values, and rules from a JSON file."/>
                        </StackPanel>
                    </Grid>


                </Grid>
            </TabItem>

            <!-- ═══ RULES ═══ -->
            <TabItem Header="  Rules  ">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="#EFF6FF" BorderBrush="#BFDBFE"
                            BorderThickness="1" CornerRadius="6"
                            Padding="10,6" Margin="0,0,0,8">
                        <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="#1D4ED8">
                            <Run FontWeight="SemiBold">How rules work:</Run>
                            <Run> When you pick content, the tool checks its category and family name against the Match column. The first enabled match determines the Sleeve Keyword used to find sleeves. If nothing matches, "sleeve" is used as the fallback.</Run>
                        </TextBlock>
                    </Border>

                    <TextBlock Grid.Row="1" x:Name="KeywordLabel"
                               Text="Active keyword: sleeve"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="#2563EB" Margin="0,0,0,6"/>

                    <DataGrid Grid.Row="2"
                              x:Name="RulesGrid"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              CanUserResizeRows="False"
                              SelectionMode="Single"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              AlternatingRowBackground="#F8FAFC"
                              RowHeight="28" FontSize="12"
                              BorderBrush="#E2E8F0" BorderThickness="1"
                              Background="White"
                              HorizontalGridLinesBrush="#F1F5F9"
                              ColumnHeaderStyle="{StaticResource DGHeader}">
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Header="On"
                                                    Binding="{Binding Enabled}" Width="40"/>
                            <DataGridTextColumn Header="Match"
                                                Binding="{Binding MatchText}" Width="160"/>
                            <DataGridTextColumn Header="AND (required)"
                                                Binding="{Binding Kw1}" Width="110"/>
                            <DataGridTextColumn Header="OR"
                                                Binding="{Binding Kw2}" Width="90"/>
                            <DataGridTextColumn Header="OR"
                                                Binding="{Binding Kw3}" Width="90"/>
                            <DataGridTextColumn Header="OR"
                                                Binding="{Binding Kw4}" Width="90"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Grid Grid.Row="3" Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" x:Name="BtnAddRule" Content="+ Add Rule"
                                Style="{StaticResource SmallBtn}"
                                Height="28"/>
                        <Button Grid.Column="2" x:Name="BtnRemoveRule" Content="- Remove Selected"
                                Style="{StaticResource SmallBtn}"
                                Height="28"/>
                        <Button Grid.Column="4" x:Name="BtnSaveRules" Content="Save Rules"
                                Style="{StaticResource AccentBtn}"
                                Height="28" Padding="14,0"/>
                    </Grid>
                </Grid>
            </TabItem>

        </TabControl>

        <!-- Status bar -->
        <Border Grid.Row="3" Background="#1E293B" Padding="16,0">
            <TextBlock x:Name="StatusBar" Text="Ready."
                       Foreground="#CBD5E1" FontSize="11" VerticalAlignment="Center"/>
        </Border>
    </Grid>
</Window>
