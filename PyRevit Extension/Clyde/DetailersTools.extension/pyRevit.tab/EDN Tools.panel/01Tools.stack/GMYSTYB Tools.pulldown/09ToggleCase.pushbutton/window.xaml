<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Toggle Case"
    Width="480" Height="620"
    MinWidth="420" MinHeight="520"
    WindowStartupLocation="CenterScreen"
    Background="#F5F7FB"
    FontFamily="Segoe UI"
    FontSize="13"
    SnapsToDevicePixels="True"
    UseLayoutRounding="True">

    <Window.Resources>
        <!-- Palette -->
        <SolidColorBrush x:Key="BrushBg"      Color="#F5F7FB"/>
        <SolidColorBrush x:Key="BrushCard"    Color="#FFFFFF"/>
        <SolidColorBrush x:Key="BrushStroke"  Color="#E5E8F0"/>
        <SolidColorBrush x:Key="BrushText"    Color="#1F2937"/>
        <SolidColorBrush x:Key="BrushSubtle"  Color="#6B7280"/>
        <SolidColorBrush x:Key="BrushAccent"  Color="#2563EB"/>
        <SolidColorBrush x:Key="BrushSuccess" Color="#10B981"/>

        <!-- Tooltip icon -->
        <Style x:Key="TooltipIcon" TargetType="Border">
            <Setter Property="Width" Value="16"/>
            <Setter Property="Height" Value="16"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Background" Value="#A0AEC0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style x:Key="TooltipText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Text" Value="?"/>
        </Style>

        <!-- Card -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource BrushCard}"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrushStroke}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
        </Style>

        <!-- Ghost button -->
        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource BrushText}"/>
            <Setter Property="Background" Value="{StaticResource BrushCard}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrushStroke}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="#C9CFDA"/>
                                <Setter Property="Background" Value="#FAFBFF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource GhostButton}">
            <Setter Property="Background" Value="#EDF2FE"/>
            <Setter Property="BorderBrush" Value="#CBD7FB"/>
            <Setter Property="Foreground" Value="{StaticResource BrushAccent}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="SuccessButton" TargetType="Button" BasedOn="{StaticResource GhostButton}">
            <Setter Property="Background" Value="#ECFDF5"/>
            <Setter Property="BorderBrush" Value="#A7F3D0"/>
            <Setter Property="Foreground" Value="{StaticResource BrushSuccess}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- Mode radio-style toggle -->
        <Style x:Key="ModeButton" TargetType="RadioButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd"
                                Background="{StaticResource BrushCard}"
                                BorderBrush="{StaticResource BrushStroke}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="10,10"
                                Cursor="Hand">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock x:Name="IconTxt"
                                           Text="{TemplateBinding Tag}"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           Foreground="{StaticResource BrushSubtle}"/>
                                <TextBlock Text="{TemplateBinding Content}"
                                           FontSize="11"
                                           HorizontalAlignment="Center"
                                           Foreground="{StaticResource BrushSubtle}"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#EDF2FE"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#93C5FD"/>
                                <Setter TargetName="IconTxt" Property="Foreground" Value="{StaticResource BrushAccent}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F5F8FF"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#CBD7FB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrushStroke}"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrushStroke}"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource BrushAccent}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource BrushBg}" Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ===== HEADER ===== -->
        <DockPanel Grid.Row="0" Margin="0,0,0,18">
            <StackPanel DockPanel.Dock="Left" VerticalAlignment="Center">
                <TextBlock Text="Toggle Case"
                           FontSize="22" FontWeight="Bold"
                           Foreground="{StaticResource BrushText}"/>
                <TextBlock Text="Transform selected TextNote elements"
                           FontSize="12"
                           Foreground="{StaticResource BrushSubtle}"
                           Margin="0,2,0,0"/>
            </StackPanel>

            <!-- Select Elements button + count pill -->
            <StackPanel DockPanel.Dock="Right"
                        Orientation="Horizontal"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Right">
                <Border x:Name="CountPill"
                        Background="#EDF2FE"
                        BorderBrush="#CBD7FB"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="10,4"
                        Margin="0,0,8,0"
                        Visibility="Collapsed">
                    <TextBlock x:Name="CountLabel"
                               Foreground="{StaticResource BrushAccent}"
                               FontWeight="SemiBold"
                               FontSize="12"/>
                </Border>
                <Button x:Name="SelectElementsBtn"
                        Style="{StaticResource AccentButton}"
                        Content="Select Elements in Revit"
                        Height="36"
                        FontSize="13"
                        Padding="16,0"
                        Click="OnSelectElements"/>
            </StackPanel>
        </DockPanel>

        <!-- ===== MAIN CONTENT ===== -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- PROFILE CARD -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock Text="Profile"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource BrushText}"
                                       VerticalAlignment="Center"/>
                            <Border Style="{StaticResource TooltipIcon}">
                                <Border.ToolTip>
                                    <ToolTip>
                                        <TextBlock MaxWidth="260" TextWrapping="Wrap">
                                            Save and load named configurations.
                                            Profiles store your selected case mode and preview text.
                                        </TextBlock>
                                    </ToolTip>
                                </Border.ToolTip>
                                <TextBlock Style="{StaticResource TooltipText}"/>
                            </Border>
                        </StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox x:Name="ProfileCombo"
                                      Grid.Column="0"
                                      Margin="0,0,8,0"
                                      SelectionChanged="OnProfileSelected"/>
                            <Button x:Name="SaveProfileBtn"
                                    Grid.Column="1"
                                    Style="{StaticResource AccentButton}"
                                    Content="Save"
                                    Width="70" Height="32"
                                    Click="OnSaveProfile"/>
                            <Button x:Name="DeleteProfileBtn"
                                    Grid.Column="2"
                                    Style="{StaticResource GhostButton}"
                                    Content="Delete"
                                    Width="70" Height="32"
                                    Margin="6,0,0,0"
                                    Click="OnDeleteProfile"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- CASE MODE CARD -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <TextBlock Text="Case Mode"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource BrushText}"
                                       VerticalAlignment="Center"/>
                            <Border Style="{StaticResource TooltipIcon}">
                                <Border.ToolTip>
                                    <ToolTip>
                                        <TextBlock MaxWidth="260" TextWrapping="Wrap">
                                            Choose how to transform the selected TextNote elements.
                                            Auto-Cycle advances each note through the
                                            UPPERCASE - Title Case - lowercase cycle,
                                            matching the Windows Shift+F3 behavior.
                                        </TextBlock>
                                    </ToolTip>
                                </Border.ToolTip>
                                <TextBlock Style="{StaticResource TooltipText}"/>
                            </Border>
                        </StackPanel>
                        <UniformGrid Columns="4" Rows="1">
                            <RadioButton x:Name="ModeUpper"
                                         Style="{StaticResource ModeButton}"
                                         Content="UPPERCASE"
                                         Tag="ABC"
                                         GroupName="CaseMode"
                                         Margin="0,0,6,0"
                                         Checked="OnModeChanged"/>
                            <RadioButton x:Name="ModeTitle"
                                         Style="{StaticResource ModeButton}"
                                         Content="Title Case"
                                         Tag="Abc"
                                         GroupName="CaseMode"
                                         Margin="0,0,6,0"
                                         Checked="OnModeChanged"/>
                            <RadioButton x:Name="ModeLower"
                                         Style="{StaticResource ModeButton}"
                                         Content="lowercase"
                                         Tag="abc"
                                         GroupName="CaseMode"
                                         Margin="0,0,6,0"
                                         Checked="OnModeChanged"/>
                            <RadioButton x:Name="ModeCycle"
                                         Style="{StaticResource ModeButton}"
                                         Content="Auto-Cycle"
                                         Tag="&#x21BB;"
                                         GroupName="CaseMode"
                                         IsChecked="True"
                                         Checked="OnModeChanged"/>
                        </UniformGrid>
                    </StackPanel>
                </Border>

                <!-- PREVIEW CARD -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock Text="Preview"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource BrushText}"
                                       VerticalAlignment="Center"/>
                            <Border Style="{StaticResource TooltipIcon}">
                                <Border.ToolTip>
                                    <ToolTip>
                                        <TextBlock MaxWidth="260" TextWrapping="Wrap">
                                            Type sample text to see how the selected
                                            mode will transform it before applying.
                                        </TextBlock>
                                    </ToolTip>
                                </Border.ToolTip>
                                <TextBlock Style="{StaticResource TooltipText}"/>
                            </Border>
                        </StackPanel>
                        <TextBox x:Name="PreviewInput"
                                 Text="Sample Text Here"
                                 Margin="0,0,0,10"
                                 TextChanged="OnPreviewChanged"/>
                        <Border Background="#F3F5FA"
                                CornerRadius="6"
                                BorderBrush="{StaticResource BrushStroke}"
                                BorderThickness="1"
                                Padding="12,10">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Result: "
                                           Foreground="{StaticResource BrushSubtle}"
                                           FontSize="12"
                                           VerticalAlignment="Center"/>
                                <TextBlock x:Name="PreviewOutput"
                                           Foreground="{StaticResource BrushAccent}"
                                           FontWeight="SemiBold"
                                           FontSize="13"
                                           VerticalAlignment="Center"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- ===== FOOTER ===== -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,14,0,0">
            <Button x:Name="CancelBtn"
                    Style="{StaticResource GhostButton}"
                    Content="Cancel"
                    Width="90" Height="36"
                    IsCancel="True"
                    Click="OnCancel"/>
            <Button x:Name="ApplyBtn"
                    Style="{StaticResource SuccessButton}"
                    Content="Apply"
                    Width="90" Height="36"
                    Margin="8,0,0,0"
                    IsDefault="True"
                    Click="OnApply"/>
        </StackPanel>

    </Grid>
</Window>
