<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Coil Duct Analyzer" Height="720" Width="740" WindowStartupLocation="CenterScreen"
        Background="#F5F7FB" FontFamily="Segoe UI" FontSize="12" UseLayoutRounding="True">
    
    <Window.Resources>
        <!-- Palette (matches Shop QA) -->
        <Color x:Key="ColBg">#F5F7FB</Color>
        <Color x:Key="ColCard">#FFFFFFFF</Color>
        <Color x:Key="ColStroke">#E5E8F0</Color>
        <Color x:Key="ColText">#1F2937</Color>
        <Color x:Key="ColSubtle">#6B7280</Color>
        <Color x:Key="ColAccent">#2563EB</Color>
        
        <SolidColorBrush x:Key="BrushBg" Color="{StaticResource ColBg}"/>
        <SolidColorBrush x:Key="BrushCard" Color="{StaticResource ColCard}"/>
        <SolidColorBrush x:Key="BrushStroke" Color="{StaticResource ColStroke}"/>
        <SolidColorBrush x:Key="BrushText" Color="{StaticResource ColText}"/>
        <SolidColorBrush x:Key="BrushSubtle" Color="{StaticResource ColSubtle}"/>
        <SolidColorBrush x:Key="BrushAccent" Color="{StaticResource ColAccent}"/>

        <!-- Card Style -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource BrushCard}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrushStroke}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <!-- Header Text -->
        <Style x:Key="Header" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource BrushText}"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <!-- Label Style -->
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="{StaticResource BrushSubtle}"/>
            <Setter Property="Padding" Value="0,2,4,2"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>

        <!-- TextBox Style -->
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="24"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrushStroke}"/>
            <Setter Property="Background" Value="#FCFCFD"/>
            <Setter Property="Padding" Value="4,0"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>

        <!-- CheckBox Style -->
        <Style TargetType="CheckBox">
            <Setter Property="Margin" Value="0,3,12,3"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>

        <!-- Button Styles -->
        <Style x:Key="BaseButton" TargetType="Button">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" 
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" 
                                              TextElement.FontWeight="SemiBold"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
            <Setter Property="Background" Value="{StaticResource BrushAccent}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrushAccent}"/>
        </Style>

        <Style x:Key="GhostButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource BrushText}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrushStroke}"/>
        </Style>

        <Style x:Key="SmallButton" TargetType="Button" BasedOn="{StaticResource GhostButton}">
            <Setter Property="Height" Value="24"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="8,0"/>
        </Style>

        <!-- Tooltip icon styles -->
        <Style x:Key="TooltipIcon" TargetType="Border">
            <Setter Property="Width" Value="14"/>
            <Setter Property="Height" Value="14"/>
            <Setter Property="CornerRadius" Value="7"/>
            <Setter Property="Background" Value="#E5E8F0"/>
            <Setter Property="Margin" Value="4,0,0,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="TooltipText" TargetType="TextBlock">
            <Setter Property="Text" Value="?"/>
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#6B7280"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Title -->
        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="Coil Duct Analyzer" FontSize="18" FontWeight="Bold" 
                       Foreground="{StaticResource BrushText}"/>
            <TextBlock Text="Calculate overall cut lengths for coil machine production" 
                       Foreground="{StaticResource BrushSubtle}" FontSize="11"/>
        </StackPanel>

        <!-- Row 1: Settings Card -->
        <Border Grid.Row="1" Style="{StaticResource Card}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Top row: Coil width + selection count -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Label Grid.Column="0" Content="Coil Width:"/>
                    <TextBox x:Name="CoilWidth" Grid.Column="1" Width="55" Text="60"/>
                    <Label Grid.Column="2" Content=" in" Margin="0,0,20,0"/>

                    <Border Grid.Column="3" Style="{StaticResource TooltipIcon}" 
                            ToolTip="Overall Cut Length = Body Length + End 1 Allowance + End 2 Allowance. Must fit within coil width.">
                        <TextBlock Style="{StaticResource TooltipText}"/>
                    </Border>

                    <TextBlock x:Name="SelectionCount" Grid.Column="5" 
                               Text="0 elements selected" 
                               Foreground="{StaticResource BrushSubtle}" 
                               VerticalAlignment="Center" FontSize="11"/>
                </Grid>

                <!-- Bottom row: Tag parameter dropdown -->
                <Grid Grid.Row="1" Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Label Grid.Column="0" Content="Write tags to:"/>
                    <ComboBox x:Name="TagParamCombo" Grid.Column="1" Height="24" 
                              Margin="4,0,8,0" FontSize="11"
                              VerticalContentAlignment="Center"
                              BorderBrush="{StaticResource BrushStroke}"/>
                    <Border Grid.Column="2" Style="{StaticResource TooltipIcon}" 
                            ToolTip="Select which text parameter receives 'Should be Coil' or 'Should not be Coil' tags. Only writable text parameters on fabrication parts are shown.">
                        <TextBlock Style="{StaticResource TooltipText}"/>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <!-- Row 2: Connectors Card -->
        <Border Grid.Row="2" Style="{StaticResource Card}" Margin="0,0,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header row -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBlock Grid.Column="0" Style="{StaticResource Header}" Text="Valid Coil Connectors"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button x:Name="ScanModelBtn" Content="Scan Model" Width="85" 
                                Style="{StaticResource SmallButton}" Click="ScanModel_Click" Margin="0,0,4,0"
                                ToolTip="Discover rectangular connectors used on elements in the current model"/>
                        <Button x:Name="ScanDbBtn" Content="Scan Database" Width="95" 
                                Style="{StaticResource SmallButton}" Click="ScanDb_Click" Margin="0,0,4,0"
                                ToolTip="Discover all connectors from the fabrication database"/>
                        <Button Content="All" Width="35" Style="{StaticResource SmallButton}" 
                                Click="EnableAll_Click" Margin="0,0,4,0"/>
                        <Button Content="None" Width="42" Style="{StaticResource SmallButton}" 
                                Click="DisableAll_Click"/>
                    </StackPanel>
                </Grid>

                <!-- Info text -->
                <TextBlock Grid.Row="1" Foreground="{StaticResource BrushSubtle}" FontSize="10" 
                           Margin="0,0,0,6" TextWrapping="Wrap"
                           Text="Check connectors valid for coil production. Edit allowances as needed. Unrecognized connectors from model will appear after scanning."/>

                <!-- Connector DataGrid -->
                <DataGrid Grid.Row="2" x:Name="ConnectorGrid"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          CanUserSortColumns="True"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          BorderThickness="1"
                          BorderBrush="{StaticResource BrushStroke}"
                          Background="White"
                          RowBackground="White"
                          AlternatingRowBackground="#F9FAFB"
                          SelectionMode="Single"
                          VerticalScrollBarVisibility="Auto">
                    <DataGrid.Columns>
                        <!-- Enabled checkbox -->
                        <DataGridTemplateColumn Header="&#x2713;" Width="35" SortMemberPath="IsEnabled">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                              HorizontalAlignment="Center" Margin="0"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Short connector name -->
                        <DataGridTextColumn Header="Connector" Binding="{Binding ShortName}" 
                                            IsReadOnly="True" Width="140"/>

                        <!-- Full connector name -->
                        <DataGridTextColumn Header="Full Name" Binding="{Binding FullName}" 
                                            IsReadOnly="True" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#6B7280"/>
                                    <Setter Property="FontSize" Value="10"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- Editable allowance -->
                        <DataGridTemplateColumn Header="Allowance (in)" Width="95" SortMemberPath="Allowance">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBox Text="{Binding Allowance, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat=F3}" 
                                             BorderThickness="1" BorderBrush="#E5E8F0" Background="#FCFCFD"
                                             Height="20" Padding="4,0" FontSize="11"
                                             HorizontalAlignment="Stretch" VerticalContentAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- Row 3: Profile Actions -->
        <Border Grid.Row="3" Style="{StaticResource Card}" Padding="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="Import" Width="70" Style="{StaticResource SmallButton}" 
                        Click="Import_Click" Margin="0,0,6,0"
                        ToolTip="Load connector profile from JSON file"/>
                <Button Grid.Column="1" Content="Export" Width="70" Style="{StaticResource SmallButton}" 
                        Click="Export_Click" Margin="0,0,6,0"
                        ToolTip="Save current connector profile to JSON file"/>
                <Button Grid.Column="2" Content="Save Default" Width="90" Style="{StaticResource SmallButton}" 
                        Click="SaveDefault_Click"
                        ToolTip="Save current settings as default for future runs"/>

                <TextBlock Grid.Column="4" x:Name="ProfileStatus" 
                           Foreground="{StaticResource BrushSubtle}" 
                           VerticalAlignment="Center" FontSize="10" FontStyle="Italic"/>
            </Grid>
        </Border>

        <!-- Row 4: Color Legend -->
        <Border Grid.Row="4" Style="{StaticResource Card}" Padding="10,8">
            <StackPanel>
                <TextBlock Text="Result Colors" Style="{StaticResource Header}" Margin="0,0,0,6"/>
                <StackPanel Orientation="Horizontal">
                    <!-- Green = Should be Coil -->
                    <Border Width="14" Height="14" CornerRadius="3" Margin="0,0,6,0">
                        <Border.Background>
                            <SolidColorBrush Color="#00B400"/>
                        </Border.Background>
                    </Border>
                    <TextBlock Text="Should be Coil" VerticalAlignment="Center" FontSize="11"
                               Foreground="{StaticResource BrushText}" Margin="0,0,20,0"/>

                    <!-- Red = Should not be Coil -->
                    <Border Width="14" Height="14" CornerRadius="3" Margin="0,0,6,0">
                        <Border.Background>
                            <SolidColorBrush Color="#DC2828"/>
                        </Border.Background>
                    </Border>
                    <TextBlock Text="Should not be Coil" VerticalAlignment="Center" FontSize="11"
                               Foreground="{StaticResource BrushText}" Margin="0,0,20,0"/>

                    <!-- Purple = Fitting too Long -->
                    <Border Width="14" Height="14" CornerRadius="3" Margin="0,0,6,0">
                        <Border.Background>
                            <SolidColorBrush Color="#9600C8"/>
                        </Border.Background>
                    </Border>
                    <TextBlock Text="Fitting too Long" VerticalAlignment="Center" FontSize="11"
                               Foreground="{StaticResource BrushText}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Row 5: Footer Actions -->
        <Grid Grid.Row="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button x:Name="PickBtn" Grid.Column="0" Content="Pick Elements" Width="100" 
                    Style="{StaticResource GhostButton}" Click="Pick_Click"/>
            
            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <Button Content="Cancel" Width="80" Style="{StaticResource GhostButton}" 
                        Click="Cancel_Click" Margin="0,0,8,0"/>
                <Button x:Name="RunBtn" Content="Run Analysis" Width="110" 
                        Style="{StaticResource PrimaryButton}" Click="Run_Click" IsDefault="True"/>
            </StackPanel>
        </Grid>

    </Grid>
</Window>
