<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nested Link Scanner — DetailersTools"
        Width="940" Height="600"
        MinWidth="720" MinHeight="440"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="#F5F5F5"
        FontFamily="Segoe UI"
        FontSize="12">

    <Window.Resources>

        <!-- Primary action button (blue) -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background"      Value="#1565C0"/>
            <Setter Property="Foreground"      Value="#FFFFFF"/>
            <Setter Property="BorderBrush"     Value="#1565C0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="18,7"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1976D2"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#0D47A1"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Secondary button (light gray) -->
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background"      Value="#E0E0E0"/>
            <Setter Property="Foreground"      Value="#333333"/>
            <Setter Property="BorderBrush"     Value="#BDBDBD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="14,7"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#D6D6D6"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#BDBDBD"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Fix button (amber, conveys "attempt / caution") -->
        <Style x:Key="FixButton" TargetType="Button">
            <Setter Property="Background"      Value="#E65100"/>
            <Setter Property="Foreground"      Value="#FFFFFF"/>
            <Setter Property="BorderBrush"     Value="#E65100"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="14,7"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#F57C00"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#BF360C"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DataGrid global style -->
        <Style TargetType="DataGrid">
            <Setter Property="Background"               Value="#FFFFFF"/>
            <Setter Property="Foreground"               Value="#212121"/>
            <Setter Property="BorderBrush"              Value="#E0E0E0"/>
            <Setter Property="BorderThickness"          Value="0"/>
            <Setter Property="RowBackground"            Value="#FFFFFF"/>
            <Setter Property="AlternatingRowBackground" Value="#FAFAFA"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#EEEEEE"/>
            <Setter Property="VerticalGridLinesBrush"   Value="#E8E8E8"/>
            <Setter Property="HeadersVisibility"        Value="Column"/>
            <Setter Property="SelectionMode"            Value="Extended"/>
            <Setter Property="AutoGenerateColumns"      Value="False"/>
            <Setter Property="CanUserAddRows"           Value="False"/>
            <Setter Property="CanUserDeleteRows"        Value="False"/>
            <Setter Property="IsReadOnly"               Value="True"/>
            <Setter Property="SelectionUnit"            Value="FullRow"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background"      Value="#EEEEEE"/>
            <Setter Property="Foreground"      Value="#555555"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Padding"         Value="8,6"/>
            <Setter Property="BorderBrush"     Value="#DDDDDD"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#BBDEFB"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        </Style>

        <!-- Tooltip Icon Style -->
        <Style x:Key="TooltipIcon" TargetType="Border">
            <Setter Property="Width" Value="16"/>
            <Setter Property="Height" Value="16"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Background" Value="#6B7280"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style x:Key="TooltipText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Text" Value="?"/>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ROW 0: Header banner -->
        <Border Grid.Row="0" Background="#1565C0" Padding="18,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Nested Link Scanner"
                               FontSize="17" FontWeight="Bold" Foreground="#FFFFFF"/>
                    <TextBlock Margin="0,4,0,0" Foreground="#90CAF9" FontSize="11"
                               Text="Inspects each loaded Overlay link and reports Attachment-type sub-links bleeding into the host model."/>
                </StackPanel>
                <TextBlock Grid.Column="1" VerticalAlignment="Bottom"
                           Foreground="#64B5F6" FontSize="10" Text="v1.0.0"/>
            </Grid>
        </Border>

        <!-- ROW 1: Summary metrics strip -->
        <Border Grid.Row="1" Background="#E3F2FD" Padding="18,10">
            <StackPanel Orientation="Horizontal">

                <StackPanel Orientation="Horizontal" Margin="0,0,36,0">
                    <TextBlock x:Name="OverlayCount" Text="--"
                               FontSize="22" FontWeight="Bold"
                               Foreground="#1565C0" VerticalAlignment="Bottom"/>
                    <TextBlock Text="  Overlay Links" Foreground="#5C7A9A"
                               VerticalAlignment="Bottom" Margin="0,0,0,3"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,0,36,0">
                    <TextBlock x:Name="ScannedCount" Text="--"
                               FontSize="22" FontWeight="Bold"
                               Foreground="#546E7A" VerticalAlignment="Bottom"/>
                    <TextBlock Text="  Loaded &amp; Scanned" Foreground="#78909C"
                               VerticalAlignment="Bottom" Margin="0,0,0,3"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="ProblemCount" Text="--"
                               FontSize="22" FontWeight="Bold"
                               Foreground="#E65100" VerticalAlignment="Bottom"/>
                    <TextBlock Text="  Nested Attachments" Foreground="#5C7A9A"
                               VerticalAlignment="Bottom" Margin="0,0,0,3"/>
                </StackPanel>

            </StackPanel>
        </Border>

        <!-- ROW 2: Results DataGrid -->
        <Border Grid.Row="2" Margin="12,8,12,4"
                Background="#FFFFFF" BorderBrush="#E0E0E0"
                BorderThickness="1" CornerRadius="2">
            <DataGrid x:Name="ResultsGrid" RowHeight="22"
                      SelectionChanged="ResultsGrid_SelectionChanged">
                <DataGrid.Columns>

                    <!-- Parent Link -->
                    <DataGridTemplateColumn Header="Parent Link (Overlay in Host)"
                                            Width="*" MinWidth="160">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding ParentLink}"
                                           Foreground="{Binding ParentColor}"
                                           VerticalAlignment="Center"
                                           Padding="8,1"
                                           TextTrimming="CharacterEllipsis"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Nested Sub-Link -->
                    <DataGridTemplateColumn Header="Nested Sub-Link"
                                            Width="*" MinWidth="160">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding NestedLink}"
                                           Foreground="{Binding NestedColor}"
                                           FontStyle="{Binding NestedStyle}"
                                           VerticalAlignment="Center"
                                           Padding="8,1"
                                           TextTrimming="CharacterEllipsis"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Reference type -->
                    <DataGridTemplateColumn Header="Ref Type" Width="90">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding RefType}"
                                           Foreground="{Binding RefTypeColor}"
                                           FontWeight="{Binding RefTypeWeight}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Padding="4,1"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Parent loaded -->
                    <DataGridTemplateColumn Header="Loaded" Width="70">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding ParentLoaded}"
                                           Foreground="{Binding LoadedColor}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Padding="4,1"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Recommended action -->
                    <DataGridTemplateColumn Header="Action Required" Width="220">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Action}"
                                           Foreground="{Binding ActionColor}"
                                           VerticalAlignment="Center"
                                           Padding="8,1"
                                           TextTrimming="CharacterEllipsis"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- ROW 3: Button bar -->
        <Border Grid.Row="3" Background="#F5F5F5" Padding="12,8,12,8"
                BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Button x:Name="ScanBtn"
                            Content="&#9658;  Scan Links" MinWidth="130"
                            Style="{StaticResource PrimaryButton}"
                            Click="Scan_Click"/>
                    <Border Style="{StaticResource TooltipIcon}">
                        <Border.ToolTip>
                            <ToolTip>
                                <TextBlock MaxWidth="280" TextWrapping="Wrap">
                                    Inspects every loaded Overlay-type Revit link in the active model.
                                    <LineBreak/><LineBreak/>
                                    For each Overlay link, the tool opens its linked document and checks
                                    whether any of its own sub-links are set to <Bold>Attachment</Bold>.
                                    Attachment sub-links bleed into the host model as uncontrolled loads.
                                    <LineBreak/><LineBreak/>
                                    Results appear in the grid above. Orange rows are problems.
                                    Unloaded links are skipped and noted in the status bar.
                                </TextBlock>
                            </ToolTip>
                        </Border.ToolTip>
                        <TextBlock Style="{StaticResource TooltipText}"/>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button x:Name="FixBtn"
                            Content="&#9881;  Fix Selected" MinWidth="120"
                            Style="{StaticResource FixButton}"
                            IsEnabled="False"
                            Click="Fix_Click"/>
                    <Border Style="{StaticResource TooltipIcon}">
                        <Border.ToolTip>
                            <ToolTip>
                                <TextBlock MaxWidth="280" TextWrapping="Wrap">
                                    Attempts to change the selected nested sub-link(s) from
                                    Attachment to Overlay by writing directly to the linked document.
                                    <LineBreak/><LineBreak/>
                                    <Bold>This only works if the linked file is locally modifiable.</Bold>
                                    It will fail gracefully on workshared files hosted on ACC or a
                                    central server -- those files must be fixed by their owner.
                                    <LineBreak/><LineBreak/>
                                    Use Export Report to share the scan results with the BIM team
                                    responsible for each flagged file.
                                </TextBlock>
                            </ToolTip>
                        </Border.ToolTip>
                        <TextBlock Style="{StaticResource TooltipText}"/>
                    </Border>
                </StackPanel>

                <Button x:Name="ExportBtn" Grid.Column="4"
                        Content="Export Report" MinWidth="110"
                        Style="{StaticResource SecondaryButton}"
                        IsEnabled="False"
                        Click="Export_Click"/>

                <!-- Help icon — why automatic fixing is limited -->
                <Border Grid.Column="6" Style="{StaticResource TooltipIcon}"
                        Width="20" Height="20" CornerRadius="10"
                        Background="#9E9E9E"
                        ToolTipService.InitialShowDelay="100"
                        ToolTipService.ShowDuration="20000">
                    <Border.ToolTip>
                        <ToolTip Background="#FFFFFF" Foreground="#333333"
                                 BorderBrush="#BDBDBD" Padding="12,10" MaxWidth="340">
                            <StackPanel>
                                <TextBlock Text="Why can't nested links be fixed automatically?"
                                           FontWeight="Bold" FontSize="12"
                                           Foreground="#1565C0" TextWrapping="Wrap"/>
                                <TextBlock Margin="0,8,0,0" TextWrapping="Wrap"
                                           FontSize="11" LineHeight="18" Foreground="#444444">
                                    The Attachment vs. Overlay setting for a nested link is
                                    stored inside the linked file itself. The Revit API can
                                    read this setting from a loaded linked document, but
                                    writing to it requires that document to be open and
                                    modifiable (not the case for workshared files
                                    hosted on ACC or a central server).
                                </TextBlock>
                                <TextBlock Margin="0,8,0,0" TextWrapping="Wrap"
                                           FontSize="11" LineHeight="18" Foreground="#777777">
                                    To fix: ask the team who owns each flagged file to open
                                    their model, go to Manage &gt; Manage Links, and change
                                    the listed sub-link(s) from Attachment to Overlay.
                                    Export this report and attach it to your coordination
                                    request as documentation.
                                </TextBlock>
                            </StackPanel>
                        </ToolTip>
                    </Border.ToolTip>
                    <TextBlock Style="{StaticResource TooltipText}" FontSize="11"/>
                </Border>

                <Button x:Name="CloseBtn" Grid.Column="8"
                        Content="Close" MinWidth="80"
                        Style="{StaticResource SecondaryButton}"
                        Click="Close_Click"/>

            </Grid>
        </Border>

        <!-- ROW 4: Status bar -->
        <Border Grid.Row="4" Background="#EEEEEE" Padding="14,5"
                BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
            <TextBlock x:Name="StatusText"
                       Text="Ready -- click Scan to begin."
                       Foreground="#78909C" FontSize="11"/>
        </Border>

    </Grid>
</Window>
