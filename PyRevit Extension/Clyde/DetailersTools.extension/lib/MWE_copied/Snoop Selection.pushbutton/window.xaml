<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Snoop Selection - Advanced Inspector"
    Width="1240" Height="760"
    WindowStartupLocation="CenterScreen"
    Background="#F5F7FB"
    FontFamily="Segoe UI"
    FontSize="13"
    SnapsToDevicePixels="True"
    UseLayoutRounding="True">

    <!-- ========= THEME & STYLES ========= -->
    <Window.Resources>
        <!-- Palette -->
        <Color x:Key="ColBg">#F5F7FB</Color>
        <Color x:Key="ColCard">#FFFFFFFF</Color>
        <Color x:Key="ColStroke">#E5E8F0</Color>
        <Color x:Key="ColText">#1F2937</Color>
        <Color x:Key="ColSubtle">#6B7280</Color>
        <Color x:Key="ColAccent">#2563EB</Color>
        <Color x:Key="ColSuccess">#10B981</Color>
        <Color x:Key="ColWarning">#F59E0B</Color>
        <SolidColorBrush x:Key="BrushBg" Color="{StaticResource ColBg}"/>
        <SolidColorBrush x:Key="BrushCard" Color="{StaticResource ColCard}"/>
        <SolidColorBrush x:Key="BrushStroke" Color="{StaticResource ColStroke}"/>
        <SolidColorBrush x:Key="BrushText" Color="{StaticResource ColText}"/>
        <SolidColorBrush x:Key="BrushSubtle" Color="{StaticResource ColSubtle}"/>
        <SolidColorBrush x:Key="BrushAccent" Color="{StaticResource ColAccent}"/>
        <SolidColorBrush x:Key="BrushSuccess" Color="{StaticResource ColSuccess}"/>
        <SolidColorBrush x:Key="BrushWarning" Color="{StaticResource ColWarning}"/>

        <!-- Buttons -->
        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource BrushText}"/>
            <Setter Property="Background" Value="{StaticResource BrushCard}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrushStroke}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="#C9CFDA"/>
                                <Setter Property="Background" Value="#FFFDFEFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#F0F3F9"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource GhostButton}">
            <Setter Property="Background" Value="#EDF2FE"/>
            <Setter Property="BorderBrush" Value="#CBD7FB"/>
            <Setter Property="Foreground" Value="{StaticResource BrushAccent}"/>
        </Style>

        <Style x:Key="SuccessButton" TargetType="Button" BasedOn="{StaticResource GhostButton}">
            <Setter Property="Background" Value="#ECFDF5"/>
            <Setter Property="BorderBrush" Value="#A7F3D0"/>
            <Setter Property="Foreground" Value="{StaticResource BrushSuccess}"/>
        </Style>

        <Style x:Key="WarningButton" TargetType="Button" BasedOn="{StaticResource GhostButton}">
            <Setter Property="Background" Value="#FFFBEB"/>
            <Setter Property="BorderBrush" Value="#FCD34D"/>
            <Setter Property="Foreground" Value="{StaticResource BrushWarning}"/>
        </Style>

        <!-- Card container -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource BrushCard}"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrushStroke}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12"/>
        </Style>

        <!-- TreeView -->
        <Style TargetType="TreeView">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="{StaticResource BrushCard}"/>
        </Style>
        <Style TargetType="TreeViewItem">
            <Setter Property="Margin" Value="0,2,0,2"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="IsExpanded" Value="True"/>
        </Style>

        <!-- DataGrid -->
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="{StaticResource BrushCard}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrushStroke}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="RowBackground" Value="#FFFFFFFF"/>
            <Setter Property="AlternatingRowBackground" Value="#FAFBFF"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#EEF1F7"/>
            <Setter Property="ColumnHeaderHeight" Value="34"/>
            <Setter Property="RowHeight" Value="26"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F3F5FA"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrushStroke}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Foreground" Value="{StaticResource BrushSubtle}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- Hyperlink-like cells -->
        <Style x:Key="LinkCellText" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding State}" Value="link">
                    <Setter Property="Foreground" Value="{StaticResource BrushAccent}"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="TextDecorations" Value="Underline"/>
                    <Setter Property="Cursor" Value="Hand"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding State}" Value="error">
                    <Setter Property="Foreground" Value="#DC2626"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding State}" Value="null">
                    <Setter Property="Foreground" Value="{StaticResource BrushSubtle}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Section row -->
        <Style x:Key="SectionRowStyle" TargetType="DataGridRow">
            <Style.Triggers>
                <DataTrigger Binding="{Binding State}" Value="section">
                    <Setter Property="Background" Value="#FAFAFC"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- RowDetails template -->
        <DataTemplate x:Key="DetailsTemplate">
            <Border Style="{StaticResource Card}" Padding="8" Margin="8,4,8,8">
                <DataGrid ItemsSource="{Binding Details}"
                          RowStyle="{StaticResource SectionRowStyle}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Member" Binding="{Binding Member}" Width="2*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource LinkCellText}"/>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="3*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource LinkCellText}"/>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <!-- ========= LAYOUT ========= -->
    <Grid Background="{StaticResource BrushBg}" Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Style="{StaticResource Card}" Padding="10" Margin="0,0,0,10">
            <DockPanel LastChildFill="True">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" Margin="0,0,12,0">
                    <Button x:Name="HomeBtn" Style="{StaticResource GhostButton}" Content="🏠 Home"/>
                    <Button x:Name="BackBtn" Style="{StaticResource GhostButton}" Content="← Back"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                    <Button x:Name="CopyBtn"   Style="{StaticResource GhostButton}" Content="📋 Copy"/>
                    <Button x:Name="ExportBtn" Style="{StaticResource AccentButton}" Content="📊 Export CSV"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="🔍 Search:" Margin="0,0,8,0" Foreground="{StaticResource BrushSubtle}" />
                    <TextBox x:Name="SearchBox" Width="280" Height="28"
                             Padding="8,4" BorderBrush="{StaticResource BrushStroke}" BorderThickness="1"
                             Background="#FFFCFEFF"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Comparison Mode Toggle -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="10" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="View Mode:" 
                          VerticalAlignment="Center" 
                          Margin="0,0,12,0"
                          FontWeight="SemiBold"
                          Foreground="{StaticResource BrushSubtle}"/>
                
                <Button x:Name="NormalModeBtn" 
                        Style="{StaticResource AccentButton}" 
                        Content="📋 Normal (Drill-Down)"
                        Width="180"
                        Margin="0,0,8,0"/>
                
                <Button x:Name="SimilaritiesBtn" 
                        Style="{StaticResource SuccessButton}" 
                        Content="✓ Similarities"
                        Width="140"
                        Margin="0,0,8,0"
                        ToolTip="Show properties with IDENTICAL values across all selected elements"/>
                
                <Button x:Name="DifferencesBtn" 
                        Style="{StaticResource WarningButton}" 
                        Content="✗ Differences"
                        Width="140"
                        ToolTip="Show properties with DIFFERENT values across selected elements"/>
            </StackPanel>
        </Border>

        <!-- Main split -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Selection tree -->
            <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,12,0">
                <DockPanel LastChildFill="True">
                    <TextBlock Text="📦 Selection" 
                              DockPanel.Dock="Top" 
                              Margin="2,0,0,8"
                               FontWeight="Bold" 
                               Foreground="{StaticResource BrushSubtle}"/>
                    <TreeView x:Name="ElemTree"/>
                </DockPanel>
            </Border>

            <!-- Right: Details grid -->
            <Border Grid.Column="1" Style="{StaticResource Card}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="RightTitle"
                               Grid.Row="0"
                               Text="Details"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource BrushText}"
                               Margin="2,0,0,8"/>

                    <DataGrid x:Name="MemberGrid" Grid.Row="1"
                              RowStyle="{StaticResource SectionRowStyle}"
                              RowDetailsTemplate="{StaticResource DetailsTemplate}"
                              RowDetailsVisibilityMode="Collapsed">
                        <!-- RowDetails toggle button -->
                        <DataGrid.RowHeaderTemplate>
                            <DataTemplate>
                                <Button Content="▸" Width="22" Height="22"
                                        Margin="2"
                                        ToolTip="Expand details"
                                        Click="ExpandBtn_Click"
                                        Tag="{Binding}"/>
                            </DataTemplate>
                        </DataGrid.RowHeaderTemplate>

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Member" Binding="{Binding Member}" Width="2*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource LinkCellText}"/>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="3*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource LinkCellText}"/>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>

        <!-- Footer -->
        <DockPanel Grid.Row="3" Margin="2,10,2,0">
            <TextBlock x:Name="StatusText"
                       Foreground="{StaticResource BrushSubtle}"
                       DockPanel.Dock="Left"
                       Text="Ready" />
            <TextBlock DockPanel.Dock="Right"
                       Foreground="{StaticResource BrushSubtle}"
                       Text="💡 Tip: Use Similarities/Differences to compare multiple elements"/>
        </DockPanel>
    </Grid>
</Window>